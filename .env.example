# ════════════════════════════════════════════════════════════════
#  Enomia — variables d'environnement (exemple)
#  Copie ce fichier en `.env` (local) et remplis les valeurs.
#
#  Légende sensibilité — pour Vercel ET pour un futur dev :
#    🔒 SENSIBLE → vraie clé. Sur Vercel : créer en "Sensitive" + rotater
#                  à la source. NE JAMAIS committer la valeur. NE JAMAIS
#                  donner la valeur de prod à un dev (lui donner ses propres
#                  clés de dev / un projet séparé).
#    🌐 PUBLIC   → exposé au navigateur / non secret. Peut rester en clair.
#    ⚙️  CONFIG   → réglage non secret. Peut rester en clair.
# ════════════════════════════════════════════════════════════════

# ─── Supabase ─────────────────────────────────────────────
SUPABASE_URL=https://xxxxx.supabase.co        # ⚙️ CONFIG (URL du projet)
SUPABASE_KEY=sb_publishable_xxxxx             # 🌐 PUBLIC (clé publishable, utilisée côté client)
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxx     # 🔒 SENSIBLE (accès BDD total, bypass RLS — serveur uniquement)
SUPABASE_JWT_SECRET=                          # 🔒 SENSIBLE (vérif JWT locale ; optionnel — rotation disruptive)

# ─── Email transactionnel (Resend) ────────────────────────
RESEND_API_KEY=re_xxxxx                       # 🔒 SENSIBLE (envoi d'emails en ton nom)

# ─── Newsletter & contacts (Brevo) ────────────────────────
BREVO_API_KEY=xkeysib-xxxxx                   # 🔒 SENSIBLE (accès total aux contacts)
BREVO_LIST_ID=3                               # ⚙️ CONFIG — liste NL "Enomia-Blog" (newsletter, opt-in)
BREVO_LIST_OUTILS=4                           # ⚙️ CONFIG — liste "User-Outil" (comptes outils, transactionnel)
BREVO_LIST_CHANNEL=5                          # ⚙️ CONFIG — liste "Channel-Manager"
BREVO_LIST_WAITLIST_SITE=6                    # ⚙️ CONFIG — waitlist site de réservation directe
BREVO_LIST_WAITLIST_CM=7                      # ⚙️ CONFIG — waitlist channel manager

# ─── Keystatic (admin contenu, OAuth GitHub) ──────────────
KEYSTATIC_GITHUB_CLIENT_ID=xxxxx              # 🌐 PUBLIC (identifiant OAuth, non secret)
KEYSTATIC_GITHUB_CLIENT_SECRET=xxxxx          # 🔒 SENSIBLE (secret OAuth GitHub)

# ─── Divers ───────────────────────────────────────────────
APP_URL=https://enomia.app                    # ⚙️ CONFIG
PUBLIC_PREVIEW_SECRET=xxxxx                   # ⚠️ préfixe PUBLIC_ = exposé au navigateur → ne protège rien de sensible.
                                              #    Si la route /preview doit vraiment être protégée, utiliser un vrai
                                              #    secret vérifié côté serveur (sans préfixe PUBLIC_).

# NB : si d'autres clés existent dans Vercel et pas ici, ajoute-les avec le même marquage.

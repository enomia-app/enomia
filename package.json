{
  "name": "enomia",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "build": "node scripts/fix-keystatic.mjs && astro build",
    "preview": "astro preview",
    "postinstall": "node scripts/fix-keystatic.mjs",
    "test:e2e": "playwright test",
    "audit:blog-links": "node scripts/audit-blog-links.mjs",
    "audit:blog-links:fix": "node scripts/audit-blog-links.mjs --fix",
    "audit:external": "node scripts/audit-blog-links.mjs --external",
    "snapshot": "node scripts/generate-snapshots.mjs && open .claude/acquisition.html",
    "snapshot:gen": "node scripts/generate-snapshots.mjs",
    "gsc:refresh": "node scripts/gsc-fetch-index-status.mjs && node scripts/gsc-fetch-analytics.mjs && node scripts/generate-snapshots.mjs && open .claude/acquisition.html",
    "prepare": "husky"
  },
  "dependencies": {
    "@astrojs/markdoc": "^0.15.11",
    "@astrojs/react": "^5.0.2",
    "@astrojs/vercel": "^9.0.5",
    "@keystatic/astro": "5.0.6",
    "@keystatic/core": "0.5.50",
    "@supabase/supabase-js": "^2.49.4",
    "@vercel/analytics": "^2.0.1",
    "@vercel/og": "^0.6.2",
    "astro": "^5.18.1",
    "googleapis": "^171.4.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "husky": "^9.1.7",
    "patch-package": "^8.0.1"
  }
}

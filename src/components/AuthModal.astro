---
/**
 * Composant unique de connexion (Google + magic link).
 * Utilisé par tous les outils (simulateur, facture, contrat).
 *
 * Chaque outil expose deux fonctions globales appelées par le modal :
 *   window.toolSignInGoogle()                       -> lance OAuth Google
 *   window.toolSendMagicLink({email, prenom})       -> envoie magic link, throw si erreur
 *
 * Le modal expose :
 *   window.authOpen(label?)   -> ouvre (label optionnel pour le titre, ex: "Sauvegarder")
 *   window.authClose()        -> ferme
 *   window.authReset()        -> revient à l'étape 1 (formulaire)
 *
 * window.toolLogin est aliasé sur authOpen pour rétro-compat avec AuthPopup.astro.
 */
---

<div id="auth-modal" class="auth-modal-overlay" style="display:none">
  <div class="auth-modal-card">
    <button class="auth-modal-close" onclick="authClose()" aria-label="Fermer">&times;</button>

    <!-- Étape 1 : formulaire -->
    <div id="auth-modal-step-form">
      <div class="auth-modal-eyebrow" id="auth-modal-label">Se connecter</div>
      <div class="auth-modal-title">Accéder à votre espace</div>

      <button type="button" class="auth-modal-google" onclick="authGoogle()">
        <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
          <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
          <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
          <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z"/>
          <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
        </svg>
        Continuer avec Google
      </button>

      <div class="auth-modal-sep">
        <span class="auth-modal-sep-line"></span>
        <span class="auth-modal-sep-label">ou par email</span>
        <span class="auth-modal-sep-line"></span>
      </div>

      <form class="auth-modal-form" onsubmit="event.preventDefault(); authSubmitMagic();">
        <input type="text" id="auth-modal-prenom" placeholder="Votre prénom" autocomplete="given-name">
        <input type="email" id="auth-modal-email" placeholder="votre@email.fr" autocomplete="email" required>
        <div id="auth-modal-error" class="auth-modal-error" style="display:none"></div>
        <button type="submit" id="auth-modal-send" class="auth-modal-submit">Recevoir mon lien &rarr;</button>
      </form>

      <p class="auth-modal-note">Sans mot de passe · Gratuit · Données privées</p>
    </div>

    <!-- Étape 2 : confirmation -->
    <div id="auth-modal-step-sent" style="display:none">
      <div class="auth-modal-icon">✉️</div>
      <div class="auth-modal-title">Vérifiez vos emails</div>
      <p class="auth-modal-subtitle">Un lien de connexion a été envoyé à <strong id="auth-modal-email-sent"></strong>.<br>Cliquez dessus pour vous connecter automatiquement.</p>
      <p class="auth-modal-note">Pas reçu ? Vérifiez vos spams ou <button type="button" class="auth-modal-link" onclick="authReset()">réessayez</button>.</p>
    </div>
  </div>
</div>

<script is:inline>
  (function () {
    function focusFirst() {
      var prenom = document.getElementById('auth-modal-prenom');
      var email = document.getElementById('auth-modal-email');
      var target = (prenom && !prenom.value) ? prenom : email;
      if (target) try { target.focus(); } catch (_) {}
    }

    window.authOpen = function (label) {
      var el = document.getElementById('auth-modal');
      if (!el) return;
      document.getElementById('auth-modal-label').textContent = label || 'Se connecter';
      document.getElementById('auth-modal-step-form').style.display = '';
      document.getElementById('auth-modal-step-sent').style.display = 'none';
      document.getElementById('auth-modal-error').style.display = 'none';
      el.style.display = 'flex';
      setTimeout(focusFirst, 80);
    };

    window.authClose = function () {
      var el = document.getElementById('auth-modal');
      if (el) el.style.display = 'none';
    };

    window.authReset = function () {
      document.getElementById('auth-modal-step-form').style.display = '';
      document.getElementById('auth-modal-step-sent').style.display = 'none';
      document.getElementById('auth-modal-error').style.display = 'none';
    };

    window.authGoogle = function () {
      if (typeof window.toolSignInGoogle === 'function') {
        window.toolSignInGoogle();
      } else {
        console.warn('[AuthModal] window.toolSignInGoogle non défini');
      }
    };

    window.authSubmitMagic = async function () {
      var prenomEl = document.getElementById('auth-modal-prenom');
      var emailEl = document.getElementById('auth-modal-email');
      var errEl = document.getElementById('auth-modal-error');
      var btn = document.getElementById('auth-modal-send');
      var prenom = (prenomEl ? prenomEl.value : '').trim();
      var email = (emailEl ? emailEl.value : '').trim();
      errEl.style.display = 'none';
      if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
        errEl.textContent = 'Email invalide';
        errEl.style.display = '';
        return;
      }
      if (typeof window.toolSendMagicLink !== 'function') {
        errEl.textContent = 'Connexion indisponible. Rechargez la page.';
        errEl.style.display = '';
        return;
      }
      var origLabel = btn.textContent;
      btn.disabled = true;
      btn.textContent = 'Envoi…';
      try {
        await window.toolSendMagicLink({ email: email, prenom: prenom });
        document.getElementById('auth-modal-email-sent').textContent = email;
        document.getElementById('auth-modal-step-form').style.display = 'none';
        document.getElementById('auth-modal-step-sent').style.display = '';
      } catch (e) {
        errEl.textContent = (e && e.message) ? e.message : 'Erreur lors de l’envoi du lien';
        errEl.style.display = '';
      } finally {
        btn.disabled = false;
        btn.textContent = origLabel;
      }
    };

    // Rétro-compat avec AuthPopup.astro et autres déclencheurs existants
    window.toolLogin = function () { window.authOpen(); };

    // Fermer au clic sur l'overlay
    document.addEventListener('click', function (e) {
      var overlay = document.getElementById('auth-modal');
      if (overlay && e.target === overlay) window.authClose();
    });

    // Fermer avec Escape
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape') {
        var overlay = document.getElementById('auth-modal');
        if (overlay && overlay.style.display !== 'none') window.authClose();
      }
    });
  })();
</script>

<style is:global>
  .auth-modal-overlay {
    position: fixed; inset: 0; z-index: 600;
    background: rgba(0, 0, 0, 0.6); backdrop-filter: blur(4px);
    display: none; align-items: center; justify-content: center;
    padding: 20px;
  }
  .auth-modal-card {
    background: #1a1c1a; color: #fff;
    border: 1px solid #3e403e; border-radius: 14px;
    padding: 36px; max-width: 420px; width: 100%;
    position: relative; box-shadow: 0 24px 48px rgba(0, 0, 0, 0.2);
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
  }
  .auth-modal-close {
    position: absolute; top: 14px; right: 14px;
    background: none; border: none; font-size: 20px;
    color: #8a8985; cursor: pointer; padding: 4px;
    line-height: 1;
  }
  .auth-modal-close:hover { color: #fff; }
  .auth-modal-eyebrow {
    font-size: 11px; font-weight: 600; letter-spacing: 0.08em;
    text-transform: uppercase; color: #3fbd71; margin-bottom: 12px;
  }
  .auth-modal-title {
    font-family: 'Newsreader', Georgia, serif;
    font-size: 22px; font-weight: 600; margin-bottom: 14px;
    color: #fff;
  }
  .auth-modal-subtitle {
    font-size: 14px; color: #b8b6b1; line-height: 1.6;
    margin-bottom: 8px;
  }
  .auth-modal-google {
    width: 100%; display: flex; align-items: center; justify-content: center;
    gap: 10px; padding: 13px 14px;
    background: #fff; border: 1px solid #e0e0e0; border-radius: 8px;
    font-family: inherit; font-size: 14px; font-weight: 600; color: #1f1f1f;
    cursor: pointer; margin-bottom: 16px;
  }
  .auth-modal-google:hover { background: #f7f7f7; }
  .auth-modal-sep {
    display: flex; align-items: center; gap: 12px; margin-bottom: 14px;
  }
  .auth-modal-sep-line {
    flex: 1; height: 1px; background: #3e403e;
  }
  .auth-modal-sep-label {
    font-size: 12px; color: #8a8985;
  }
  .auth-modal-form {
    display: flex; flex-direction: column; gap: 10px;
  }
  .auth-modal-form input[type="text"],
  .auth-modal-form input[type="email"] {
    padding: 13px 14px;
    background: #2b2d2b; border: 1px solid #3e403e; border-radius: 8px;
    color: #fff; font-family: inherit; font-size: 14px;
    outline: none; transition: border-color 0.12s;
  }
  .auth-modal-form input[type="text"]:focus,
  .auth-modal-form input[type="email"]:focus {
    border-color: #3fbd71;
  }
  .auth-modal-form input::placeholder { color: #8a8985; }
  .auth-modal-error {
    font-size: 12px; color: #e05252;
    padding: 8px 12px; background: rgba(224, 82, 82, 0.08);
    border-radius: 6px;
  }
  .auth-modal-submit {
    padding: 14px;
    background: #3fbd71; color: #fff;
    border: none; border-radius: 8px;
    font-family: inherit; font-size: 14px; font-weight: 600;
    cursor: pointer; transition: background 0.12s;
  }
  .auth-modal-submit:hover { background: #36a361; }
  .auth-modal-submit:disabled { opacity: 0.6; cursor: wait; }
  .auth-modal-note {
    font-size: 11px; color: #8a8985;
    text-align: center; margin-top: 14px; line-height: 1.6;
  }
  .auth-modal-link {
    background: none; border: none;
    color: #3fbd71; cursor: pointer;
    text-decoration: underline; font: inherit; padding: 0;
  }
  .auth-modal-icon { font-size: 40px; margin-bottom: 16px; text-align: center; }
  #auth-modal-step-sent { text-align: center; }
</style>

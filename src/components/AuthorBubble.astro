---
// Bulle auteur réutilisable (pages outils) : photo + micro-bio FIGÉE.
// La bio vient de src/data/author.ts — ne JAMAIS écrire la bio en dur dans une page.
// Le schema Person + Book est embarqué : toute page qui affiche la bulle émet le JSON-LD.
// (Ne pas ajouter <AuthorSchema /> en plus sur ces pages, sinon doublon.)
import { AUTHOR_BIO_MICRO, authorPhoto } from '../data/author';
import AuthorSchema from './AuthorSchema.astro';

const bioHtml = AUTHOR_BIO_MICRO.replace('Marc Chenut', '<strong>Marc Chenut</strong>').replace(
  'La Méthode 97 %',
  '<em>La Méthode 97 %</em>'
);
---

<AuthorSchema />
<aside class="author-bubble">
  <img src={authorPhoto(112)} alt="Marc Chenut, investisseur en location courte durée" width="56" height="56" loading="lazy" />
  <p set:html={bioHtml} />
</aside>

<style>
  .author-bubble {
    display: flex;
    gap: 14px;
    align-items: flex-start;
    padding: 14px 16px;
    border: 1px solid #e2e0d8;
    border-radius: 12px;
    background: #faf9f6;
    margin: 24px 0;
  }
  .author-bubble img {
    border-radius: 50%;
    flex-shrink: 0;
    width: 56px;
    height: 56px;
    object-fit: cover;
  }
  .author-bubble p {
    margin: 0;
    font-size: 14px;
    line-height: 1.55;
    color: #374151;
  }
  @media (max-width: 420px) {
    .author-bubble {
      padding: 12px;
      gap: 10px;
    }
    .author-bubble img {
      width: 44px;
      height: 44px;
    }
    .author-bubble p {
      font-size: 13px;
    }
  }
</style>

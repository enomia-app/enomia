---
// Composant outil Contrat Location Courte Durée
// Partagé par les 4 pages SEO (contrat-location-saisonniere, contrat-airbnb,
// contrat-location-gite, contrat-location-mobil-home) et la page pivot
// /contrat-lcd-dashboard.
//
// 4 écrans : Dashboard, Biens, Nouveau contrat, Paramètres.
// Auth : Google OAuth ou magic link via Supabase.
// Storage : Supabase (tables contrat_bailleur, contrat_biens, contrats).
// Langues : FR + EN (templates de contrat traduits statiquement).
// Export : PDF (via window.print + @media print) + Word (.doc via Blob).
---

<style is:global>
  /* ============================================================
     CONTRAT TOOL — Design system aligné sur simulateur & facture
     ============================================================ */
  .ctr-wrap {
    --ct-bg: #f7f6f3; --ct-card: #ffffff; --ct-mid: #f0efec; --ct-mid2: #e8e6e1;
    --ct-border: #e5e3de; --ct-muted: #5c5c5c; --ct-muted2: #8a8985;
    --ct-text: #1a1a1a; --ct-text2: #52524e;
    --ct-accent: #2b2d2b; --ct-accent-dim: rgba(43,45,43,0.06);
    --ct-green: #3fbd71; --ct-red: #e05252; --ct-blue: #5b9bd5;
    --ct-yellow: #e6b740; --ct-orange: #e58a3c;
    --ct-display: 'Newsreader', Georgia, serif;
    --ct-mono: 'Inter', sans-serif;
    background: var(--ct-bg); color: var(--ct-text);
    font-family: var(--ct-mono); font-weight: 300; line-height: 1.6;
    -webkit-font-smoothing: antialiased;
    border: 1px solid var(--ct-border);
    border-radius: 12px;
    overflow: hidden;
    margin: 24px 0 40px;
    box-shadow: 0 2px 20px rgba(0,0,0,0.04);
  }
  .ctr-wrap *, .ctr-wrap *::before, .ctr-wrap *::after {
    box-sizing: border-box; margin: 0; padding: 0;
  }
  .ctr-wrap .screen { display: none; }
  .ctr-wrap .screen.active { display: block; }

  /* ─── TOP MINI-NAV ─── */
  .ctr-wrap .ctnav {
    display: flex; align-items: center; justify-content: space-between;
    padding: 14px 24px; border-bottom: 1px solid var(--ct-border);
    background: var(--ct-card); gap: 12px; flex-wrap: wrap;
  }
  .ctr-wrap .ctnav-title {
    font-family: var(--ct-display); font-size: 16px; font-weight: 700;
  }
  .ctr-wrap .ctnav-title em { font-style: italic; color: var(--ct-accent); }
  .ctr-wrap .ctnav-tabs { display: flex; gap: 4px; }
  .ctr-wrap .ctnav-tab {
    font-family: var(--ct-mono); font-size: 12px; font-weight: 500;
    padding: 8px 14px; border: 1px solid transparent;
    color: var(--ct-muted); background: transparent;
    cursor: pointer; transition: all 0.2s; border-radius: 8px;
    display: inline-flex; align-items: center; gap: 6px; white-space: nowrap;
  }
  .ctr-wrap .ctnav-tab:hover { color: var(--ct-text); background: var(--ct-mid); }
  .ctr-wrap .ctnav-tab.active {
    background: var(--ct-accent); color: #fff; border-color: var(--ct-accent);
  }
  .ctr-wrap .ctnav-user {
    display: flex; align-items: center; gap: 8px; padding: 6px 12px;
    border: 1px solid var(--ct-border); border-radius: 20px;
    font-size: 11px; color: var(--ct-muted); cursor: pointer;
  }
  .ctr-wrap .ctnav-user:hover { border-color: var(--ct-accent); }
  .ctr-wrap .ctnav-avatar {
    width: 22px; height: 22px; border-radius: 50%;
    background: var(--ct-accent); color: #fff;
    display: flex; align-items: center; justify-content: center;
    font-size: 10px; font-weight: 600;
  }

  /* ─── BUTTONS ─── */
  .ctr-wrap .btn {
    font-family: var(--ct-mono); font-size: 12px; font-weight: 500;
    padding: 9px 16px; border: 1px solid var(--ct-border);
    color: var(--ct-muted); background: transparent;
    cursor: pointer; transition: all 0.2s; border-radius: 8px;
    display: inline-flex; align-items: center; gap: 6px; text-decoration: none;
    white-space: nowrap;
  }
  .ctr-wrap .btn:hover { border-color: var(--ct-muted); color: var(--ct-text); }
  .ctr-wrap .btn.accent {
    background: var(--ct-accent); color: #fff; border-color: var(--ct-accent);
  }
  .ctr-wrap .btn.accent:hover { opacity: 0.88; color: #fff; background: var(--ct-accent); }
  .ctr-wrap .btn.ghost { border-color: transparent; }
  .ctr-wrap .btn.ghost:hover { background: var(--ct-mid); border-color: var(--ct-border); }
  .ctr-wrap .btn.sm { padding: 6px 10px; font-size: 11px; }
  .ctr-wrap .btn.lg { padding: 13px 22px; font-size: 13px; }
  .ctr-wrap .btn.danger:hover { border-color: var(--ct-red); color: var(--ct-red); }

  /* ─── PAGE / SECTION ─── */
  .ctr-wrap .page { padding: 32px 28px; min-height: 400px; }
  .ctr-wrap .page-header {
    display: flex; justify-content: space-between; align-items: flex-end;
    margin-bottom: 32px; flex-wrap: wrap; gap: 16px;
  }
  .ctr-wrap .page-title {
    font-family: var(--ct-display); font-size: 32px; font-weight: 900;
    line-height: 1.05;
  }
  .ctr-wrap .page-title em { font-style: italic; color: var(--ct-accent); }
  .ctr-wrap .page-sub {
    font-family: var(--ct-mono); font-size: 12px; color: var(--ct-muted);
    margin-top: 8px;
  }
  .ctr-wrap .tag {
    font-family: var(--ct-mono); font-size: 10px; letter-spacing: 0.16em;
    text-transform: uppercase; color: var(--ct-accent);
    display: inline-flex; align-items: center; gap: 12px; margin-bottom: 16px;
  }
  .ctr-wrap .tag::before {
    content: ''; width: 24px; height: 1px; background: var(--ct-accent);
  }
  .ctr-wrap .section-title {
    font-family: var(--ct-display); font-size: 16px; font-weight: 700;
    margin-bottom: 16px; display: flex; align-items: center; gap: 12px;
  }
  .ctr-wrap .section-title::after {
    content: ''; flex: 1; height: 1px; background: var(--ct-border);
  }
  .ctr-wrap .section-num {
    font-family: var(--ct-mono); font-size: 11px; color: var(--ct-accent);
  }

  /* ─── FIELDS ─── */
  .ctr-wrap .field { margin-bottom: 14px; }
  .ctr-wrap .field-label {
    font-family: var(--ct-mono); font-size: 10px; letter-spacing: 0.1em;
    text-transform: uppercase; color: var(--ct-muted);
    margin-bottom: 6px; display: block;
  }
  .ctr-wrap .field-label .req { color: var(--ct-red); }
  .ctr-wrap .field-hint {
    font-family: var(--ct-mono); font-size: 10px; color: var(--ct-muted2);
    margin-top: 4px;
  }
  .ctr-wrap .input, .ctr-wrap .select, .ctr-wrap .textarea {
    width: 100%; background: var(--ct-card); border: 1px solid var(--ct-border);
    color: var(--ct-text); font-family: var(--ct-mono); font-size: 13px;
    padding: 10px 14px; outline: none; transition: border-color 0.2s;
    border-radius: 6px;
  }
  .ctr-wrap .input:focus, .ctr-wrap .select:focus, .ctr-wrap .textarea:focus {
    border-color: var(--ct-accent);
  }
  .ctr-wrap .textarea {
    resize: vertical; min-height: 80px; line-height: 1.55;
  }
  .ctr-wrap .select { cursor: pointer; }
  .ctr-wrap .field-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  .ctr-wrap .field-row-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 12px; }
  .ctr-wrap .field-row-4 { display: grid; grid-template-columns: 1fr 1fr 1fr 1fr; gap: 12px; }
  @media (max-width: 640px) {
    .ctr-wrap .field-row, .ctr-wrap .field-row-3, .ctr-wrap .field-row-4 {
      grid-template-columns: 1fr;
    }
  }

  .ctr-wrap .radio-group { display: flex; gap: 6px; flex-wrap: wrap; }
  .ctr-wrap .radio-pill {
    font-family: var(--ct-mono); font-size: 11px; padding: 8px 14px;
    border: 1px solid var(--ct-border); color: var(--ct-muted);
    background: var(--ct-card); cursor: pointer; border-radius: 20px;
    transition: all 0.2s;
  }
  .ctr-wrap .radio-pill.active {
    border-color: var(--ct-accent); color: var(--ct-accent);
    background: var(--ct-accent-dim);
  }

  /* ─── PILLS (filtres dashboard) ─── */
  .ctr-wrap .pills { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 24px; }
  .ctr-wrap .pill {
    font-family: var(--ct-mono); font-size: 11px; padding: 7px 14px;
    border: 1px solid var(--ct-border); color: var(--ct-muted);
    background: var(--ct-card); cursor: pointer; border-radius: 20px;
    display: inline-flex; align-items: center; gap: 6px; transition: all 0.2s;
  }
  .ctr-wrap .pill:hover { border-color: var(--ct-muted); color: var(--ct-text); }
  .ctr-wrap .pill.active {
    background: var(--ct-accent); color: #fff; border-color: var(--ct-accent);
  }
  .ctr-wrap .pill-count {
    background: var(--ct-mid2); color: var(--ct-muted);
    font-size: 10px; font-weight: 600; border-radius: 10px;
    padding: 1px 7px; min-width: 20px; text-align: center;
  }
  .ctr-wrap .pill.active .pill-count {
    background: rgba(255,255,255,0.22); color: #fff;
  }

  /* ─── KPI ─── */
  .ctr-wrap .kpi-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 12px; margin-bottom: 28px;
  }
  .ctr-wrap .kpi {
    background: var(--ct-card); border: 1px solid var(--ct-border);
    border-radius: 10px; padding: 18px 20px;
  }
  .ctr-wrap .kpi-label {
    font-family: var(--ct-mono); font-size: 10px; letter-spacing: 0.1em;
    text-transform: uppercase; color: var(--ct-muted); margin-bottom: 6px;
  }
  .ctr-wrap .kpi-value {
    font-family: var(--ct-display); font-size: 26px; font-weight: 700;
    line-height: 1.1;
  }
  .ctr-wrap .kpi-delta {
    font-family: var(--ct-mono); font-size: 10px; color: var(--ct-muted2);
    margin-top: 4px;
  }
  .ctr-wrap .kpi.accent .kpi-value { color: var(--ct-accent); }
  .ctr-wrap .kpi.green .kpi-value { color: var(--ct-green); }

  /* ─── TABLE ─── */
  .ctr-wrap .table-wrap {
    background: var(--ct-card); border: 1px solid var(--ct-border);
    border-radius: 10px; overflow: hidden; overflow-x: auto;
  }
  .ctr-wrap table.data { width: 100%; border-collapse: collapse; min-width: 900px; }
  .ctr-wrap table.data th {
    font-family: var(--ct-mono); font-size: 10px; letter-spacing: 0.08em;
    text-transform: uppercase; color: var(--ct-muted);
    padding: 14px 16px; border-bottom: 1px solid var(--ct-border);
    text-align: left; font-weight: 500; background: var(--ct-card);
  }
  .ctr-wrap table.data td {
    padding: 14px 16px; border-bottom: 1px solid var(--ct-border);
    font-size: 13px; color: var(--ct-text2); vertical-align: middle;
  }
  .ctr-wrap table.data tr:last-child td { border-bottom: none; }
  .ctr-wrap table.data tr:hover td { background: var(--ct-mid); }
  .ctr-wrap table.data td .primary { color: var(--ct-text); font-weight: 500; display: block; }
  .ctr-wrap table.data td .secondary { font-family: var(--ct-mono); font-size: 10px; color: var(--ct-muted2); }
  .ctr-wrap .col-bien { min-width: 220px; }
  .ctr-wrap .col-money { width: 90px; padding-left: 8px; padding-right: 8px; }

  .ctr-wrap .badge {
    display: inline-flex; align-items: center; gap: 5px;
    font-family: var(--ct-mono); font-size: 10px; font-weight: 500;
    padding: 4px 9px; border-radius: 12px; border: 1px solid transparent;
    white-space: nowrap;
  }
  .ctr-wrap .badge.pending { background: rgba(230,183,64,0.12); color: #a07a10; border-color: rgba(230,183,64,0.3); }
  .ctr-wrap .badge.partial { background: rgba(91,155,213,0.12); color: #3a6c96; border-color: rgba(91,155,213,0.3); }
  .ctr-wrap .badge.paid { background: rgba(63,189,113,0.12); color: #1f7a3e; border-color: rgba(63,189,113,0.3); }
  .ctr-wrap .badge.overdue { background: rgba(224,82,82,0.12); color: #a03030; border-color: rgba(224,82,82,0.3); }
  .ctr-wrap .badge.archived { background: var(--ct-mid); color: var(--ct-muted); border-color: var(--ct-border); }

  .ctr-wrap .pay-chip {
    display: inline-flex; align-items: center; gap: 4px;
    font-family: var(--ct-mono); font-size: 9px; padding: 3px 7px;
    border-radius: 4px; white-space: nowrap; cursor: pointer; transition: all 0.2s;
  }
  .ctr-wrap .pay-chip.ok { background: rgba(63,189,113,0.12); color: #1f7a3e; }
  .ctr-wrap .pay-chip.wait { background: var(--ct-mid2); color: var(--ct-muted); }
  .ctr-wrap .pay-chip.late { background: rgba(224,82,82,0.12); color: #a03030; }
  .ctr-wrap .pay-chip:hover { filter: brightness(0.92); }

  .ctr-wrap .row-actions { display: flex; gap: 4px; opacity: 0.4; transition: opacity 0.2s; }
  .ctr-wrap table.data tr:hover .row-actions { opacity: 1; }
  .ctr-wrap .icon-btn {
    width: 28px; height: 28px; border: 1px solid var(--ct-border);
    background: var(--ct-card); border-radius: 6px;
    display: inline-flex; align-items: center; justify-content: center;
    cursor: pointer; color: var(--ct-muted); transition: all 0.2s; font-size: 13px;
  }
  .ctr-wrap .icon-btn:hover { border-color: var(--ct-accent); color: var(--ct-accent); }
  .ctr-wrap .icon-btn.danger:hover { border-color: var(--ct-red); color: var(--ct-red); }

  .ctr-wrap .upload-inline {
    display: inline-flex; align-items: center; gap: 6px;
    font-family: var(--ct-mono); font-size: 10px; padding: 5px 10px;
    border: 1px dashed var(--ct-border); border-radius: 6px;
    color: var(--ct-muted); cursor: pointer; background: var(--ct-card);
    white-space: nowrap; transition: all 0.2s;
  }
  .ctr-wrap .upload-inline:hover {
    border-color: var(--ct-accent); color: var(--ct-accent); background: var(--ct-accent-dim);
  }
  .ctr-wrap .upload-inline.uploaded {
    border-style: solid; border-color: var(--ct-green);
    color: var(--ct-green); background: rgba(63,189,113,0.08);
  }

  /* ─── EMPTY STATE ─── */
  .ctr-wrap .empty-state {
    text-align: center; padding: 60px 20px; border: 1px dashed var(--ct-border);
    border-radius: 10px; background: var(--ct-card);
  }
  .ctr-wrap .empty-icon { font-size: 32px; margin-bottom: 12px; opacity: 0.3; }
  .ctr-wrap .empty-title { font-family: var(--ct-display); font-size: 18px; font-weight: 700; margin-bottom: 6px; }
  .ctr-wrap .empty-desc { font-size: 13px; color: var(--ct-muted); margin-bottom: 20px; }

  /* ─── BIENS SIDEBAR + DETAIL ─── */
  .ctr-wrap .biens-layout {
    display: grid; grid-template-columns: 280px 1fr; gap: 24px;
  }
  @media (max-width: 900px) {
    .ctr-wrap .biens-layout { grid-template-columns: 1fr; }
  }
  .ctr-wrap .biens-sidebar {
    background: var(--ct-card); border: 1px solid var(--ct-border);
    border-radius: 10px; padding: 16px; height: fit-content;
  }
  .ctr-wrap .bien-item {
    display: flex; align-items: center; gap: 10px; padding: 10px 12px;
    border-radius: 8px; cursor: pointer; margin-bottom: 4px;
    transition: background 0.2s;
  }
  .ctr-wrap .bien-item:hover { background: var(--ct-mid); }
  .ctr-wrap .bien-item.active {
    background: var(--ct-accent-dim); border: 1px solid rgba(43,45,43,0.15);
  }
  .ctr-wrap .bien-item-icon {
    width: 34px; height: 34px; border-radius: 8px; background: var(--ct-mid2);
    display: flex; align-items: center; justify-content: center;
    font-size: 16px; flex-shrink: 0;
  }
  .ctr-wrap .bien-item.active .bien-item-icon { background: var(--ct-accent); color: #fff; }
  .ctr-wrap .bien-item-text { flex: 1; min-width: 0; }
  .ctr-wrap .bien-item-name {
    font-size: 13px; font-weight: 500; color: var(--ct-text);
    line-height: 1.2; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }
  .ctr-wrap .bien-item-meta {
    font-family: var(--ct-mono); font-size: 10px; color: var(--ct-muted);
    margin-top: 2px;
  }
  .ctr-wrap .add-bien-btn {
    width: 100%; padding: 12px; border: 1px dashed var(--ct-border);
    background: transparent; border-radius: 8px; color: var(--ct-muted);
    font-family: var(--ct-mono); font-size: 12px; cursor: pointer;
    margin-top: 8px; transition: all 0.2s;
  }
  .ctr-wrap .add-bien-btn:hover {
    border-color: var(--ct-accent); color: var(--ct-accent); background: var(--ct-accent-dim);
  }
  .ctr-wrap .bien-detail {
    background: var(--ct-card); border: 1px solid var(--ct-border);
    border-radius: 10px; padding: 28px;
  }
  .ctr-wrap .bien-detail-header {
    display: flex; align-items: flex-start; justify-content: space-between;
    gap: 16px; padding-bottom: 18px; border-bottom: 1px solid var(--ct-border);
    margin-bottom: 24px; flex-wrap: wrap;
  }
  .ctr-wrap .bien-detail-title {
    font-family: var(--ct-display); font-size: 26px; font-weight: 800; line-height: 1.1;
  }

  /* Accordéon sections */
  .ctr-wrap details.bien-section {
    border: 1px solid var(--ct-border); border-radius: 10px;
    background: var(--ct-bg); margin-bottom: 10px; overflow: hidden;
  }
  .ctr-wrap details.bien-section[open] { border-color: rgba(43,45,43,0.2); }
  .ctr-wrap details.bien-section summary {
    padding: 14px 20px; cursor: pointer; font-size: 14px; font-weight: 600;
    color: var(--ct-text); display: flex; align-items: center;
    justify-content: space-between; list-style: none;
  }
  .ctr-wrap details.bien-section summary::-webkit-details-marker { display: none; }
  .ctr-wrap details.bien-section summary::after {
    content: '+'; font-family: var(--ct-mono); font-size: 20px; color: var(--ct-muted);
  }
  .ctr-wrap details.bien-section[open] summary::after { content: '−'; }
  .ctr-wrap details.bien-section summary:hover { background: var(--ct-mid); }
  .ctr-wrap details.bien-section .section-content {
    padding: 16px 20px 20px; border-top: 1px solid var(--ct-border);
  }

  /* Équipements */
  .ctr-wrap .equip-grid {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 8px;
  }
  .ctr-wrap .equip-item {
    display: flex; align-items: center; gap: 10px; padding: 10px 12px;
    background: var(--ct-card); border: 1px solid var(--ct-border);
    border-radius: 8px; cursor: pointer; font-size: 12px;
    color: var(--ct-text2); transition: all 0.2s;
  }
  .ctr-wrap .equip-item:hover { border-color: var(--ct-muted); }
  .ctr-wrap .equip-item.checked {
    border-color: var(--ct-accent); background: var(--ct-accent-dim); color: var(--ct-text);
  }
  .ctr-wrap .equip-item input { accent-color: var(--ct-accent); cursor: pointer; }

  /* Inventaire */
  .ctr-wrap .inv-room {
    margin-bottom: 16px; background: var(--ct-card);
    border: 1px solid var(--ct-border); border-radius: 8px; overflow: hidden;
  }
  .ctr-wrap .inv-room-header {
    padding: 10px 14px; background: var(--ct-mid);
    display: flex; align-items: center; justify-content: space-between;
    border-bottom: 1px solid var(--ct-border);
  }
  .ctr-wrap .inv-room-title {
    font-family: var(--ct-mono); font-size: 11px; font-weight: 600;
    text-transform: uppercase; letter-spacing: 0.08em; color: var(--ct-accent);
  }
  .ctr-wrap .inv-room-total { font-family: var(--ct-mono); font-size: 11px; color: var(--ct-muted); }
  .ctr-wrap .inv-room-total strong { color: var(--ct-text); font-weight: 600; }
  .ctr-wrap .inv-table { width: 100%; border-collapse: collapse; }
  .ctr-wrap .inv-table th, .ctr-wrap .inv-table td {
    padding: 8px 14px; font-size: 12px; border-bottom: 1px solid var(--ct-border); text-align: left;
  }
  .ctr-wrap .inv-table th {
    font-family: var(--ct-mono); font-size: 9px; text-transform: uppercase;
    letter-spacing: 0.08em; color: var(--ct-muted); font-weight: 500;
  }
  .ctr-wrap .inv-table tr:last-child td { border-bottom: none; }
  .ctr-wrap .inv-table input.mini, .ctr-wrap .inv-table select.mini {
    background: transparent; border: none; color: var(--ct-text);
    font-family: var(--ct-mono); font-size: 12px; padding: 4px 6px;
    width: 100%; outline: none; border-radius: 4px;
  }
  .ctr-wrap .inv-table input.mini:focus { background: var(--ct-mid); }
  .ctr-wrap .inv-table .val-col { text-align: right; width: 80px; }
  .ctr-wrap .inv-table .qty-col { width: 50px; }
  .ctr-wrap .inv-table .state-col { width: 80px; }
  .ctr-wrap .inv-total-banner {
    background: var(--ct-accent-dim); border: 1px solid rgba(43,45,43,0.15);
    border-radius: 8px; padding: 14px 20px;
    display: flex; align-items: center; justify-content: space-between;
    margin-top: 8px;
  }
  .ctr-wrap .inv-total-banner .label {
    font-family: var(--ct-mono); font-size: 11px; color: var(--ct-muted);
    text-transform: uppercase; letter-spacing: 0.08em;
  }

  <div id="ct-save-popup" style="display:none;position:fixed;bottom:24px;left:50%;transform:translateX(-50%);z-index:10000;background:var(--ct-accent);color:#fff;padding:16px 24px;border-radius:12px;box-shadow:0 8px 30px rgba(0,0,0,0.2);font-family:var(--ct-mono);font-size:13px;align-items:center;gap:16px;max-width:560px;width:calc(100% - 48px)">
    <div style="flex:1">
      <strong style="display:block;margin-bottom:4px">Vos donnees sont stockees localement</strong>
      <span style="font-size:11px;opacity:0.8">Connectez-vous pour synchroniser entre vos appareils et ne rien perdre.</span>
    </div>
    <div style="display:flex;gap:8px;flex-shrink:0;margin-top:10px">
      <button onclick="ctSavePopupLogin()" style="background:#fff;color:var(--ct-accent);border:none;padding:8px 16px;border-radius:8px;font-family:var(--ct-mono);font-size:12px;font-weight:600;cursor:pointer">Se connecter</button>
      <button onclick="ctDismissSavePopup()" style="background:transparent;color:rgba(255,255,255,0.7);border:1px solid rgba(255,255,255,0.3);padding:8px 12px;border-radius:8px;font-family:var(--ct-mono);font-size:12px;cursor:pointer">Plus tard</button>
    </div>
  </div>

<!-- Inventory room modal -->
<div id="ct-inv-modal" style="display:none;position:fixed;inset:0;z-index:600;background:rgba(0,0,0,0.5);backdrop-filter:blur(4px);align-items:center;justify-content:center;padding:24px">
  <div style="background:#fff;border:1px solid #e5e3de;border-radius:14px;padding:32px;max-width:400px;width:100%;position:relative;box-shadow:0 24px 48px rgba(0,0,0,0.1)">
    <button onclick="document.getElementById('ct-inv-modal').style.display='none'" style="position:absolute;top:14px;right:14px;background:none;border:none;font-size:18px;color:#8a8985;cursor:pointer">×</button>
    <div style="font-size:11px;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:#3fbd71;margin-bottom:12px">Ajouter une pièce</div>
    <div style="font-family:'Newsreader',serif;font-size:20px;font-weight:600;margin-bottom:16px">Nom de la pièce</div>
    <input type="text" id="ct-inv-room-input" placeholder="Ex: Salon, Chambre 1, Cuisine…" style="width:100%;padding:12px 14px;border:1px solid #e5e3de;border-radius:8px;font-family:'Inter',sans-serif;font-size:14px;outline:none;box-sizing:border-box;margin-bottom:12px">
    <div style="display:flex;flex-wrap:wrap;gap:6px;margin-bottom:20px">
      <button onclick="document.getElementById('ct-inv-room-input').value='Salon'" style="padding:6px 12px;border-radius:20px;border:1px solid #e5e3de;background:#f7f6f3;font-size:12px;cursor:pointer;font-family:'Inter',sans-serif">Salon</button>
      <button onclick="document.getElementById('ct-inv-room-input').value='Chambre 1'" style="padding:6px 12px;border-radius:20px;border:1px solid #e5e3de;background:#f7f6f3;font-size:12px;cursor:pointer;font-family:'Inter',sans-serif">Chambre 1</button>
      <button onclick="document.getElementById('ct-inv-room-input').value='Chambre 2'" style="padding:6px 12px;border-radius:20px;border:1px solid #e5e3de;background:#f7f6f3;font-size:12px;cursor:pointer;font-family:'Inter',sans-serif">Chambre 2</button>
      <button onclick="document.getElementById('ct-inv-room-input').value='Cuisine'" style="padding:6px 12px;border-radius:20px;border:1px solid #e5e3de;background:#f7f6f3;font-size:12px;cursor:pointer;font-family:'Inter',sans-serif">Cuisine</button>
      <button onclick="document.getElementById('ct-inv-room-input').value='Salle de bain'" style="padding:6px 12px;border-radius:20px;border:1px solid #e5e3de;background:#f7f6f3;font-size:12px;cursor:pointer;font-family:'Inter',sans-serif">Salle de bain</button>
      <button onclick="document.getElementById('ct-inv-room-input').value='Terrasse'" style="padding:6px 12px;border-radius:20px;border:1px solid #e5e3de;background:#f7f6f3;font-size:12px;cursor:pointer;font-family:'Inter',sans-serif">Terrasse</button>
    </div>
    <button onclick="ctConfirmAddRoom()" style="width:100%;padding:14px;background:#2b2d2b;color:#fff;border:none;border-radius:10px;font-family:'Inter',sans-serif;font-size:14px;font-weight:600;cursor:pointer">Ajouter la pièce</button>
  </div>
</div>

<!-- Inventory item modal -->
<div id="ct-inv-item-modal" style="display:none;position:fixed;inset:0;z-index:600;background:rgba(0,0,0,0.5);backdrop-filter:blur(4px);align-items:center;justify-content:center;padding:24px">
  <div style="background:#fff;border:1px solid #e5e3de;border-radius:14px;padding:32px;max-width:440px;width:100%;position:relative;box-shadow:0 24px 48px rgba(0,0,0,0.1)">
    <button onclick="document.getElementById('ct-inv-item-modal').style.display='none'" style="position:absolute;top:14px;right:14px;background:none;border:none;font-size:18px;color:#8a8985;cursor:pointer">&times;</button>
    <div style="font-size:11px;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:#3fbd71;margin-bottom:12px">Ajouter un objet</div>
    <div style="font-family:'Newsreader',serif;font-size:20px;font-weight:600;margin-bottom:16px">Nouvel objet</div>

    <label style="font-size:12px;font-weight:600;color:#52524e;display:block;margin-bottom:4px">Nom de l'objet *</label>
    <input type="text" id="ct-inv-item-name" placeholder="Ex: Canape, Table basse, TV..." style="width:100%;padding:12px 14px;border:1px solid #e5e3de;border-radius:8px;font-family:'Inter',sans-serif;font-size:14px;outline:none;box-sizing:border-box;margin-bottom:12px">

    <div style="display:flex;flex-wrap:wrap;gap:6px;margin-bottom:16px">
      <button onclick="document.getElementById('ct-inv-item-name').value='Canape'" style="padding:5px 10px;border-radius:20px;border:1px solid #e5e3de;background:#f7f6f3;font-size:11px;cursor:pointer;font-family:'Inter',sans-serif">Canape</button>
      <button onclick="document.getElementById('ct-inv-item-name').value='Table'" style="padding:5px 10px;border-radius:20px;border:1px solid #e5e3de;background:#f7f6f3;font-size:11px;cursor:pointer;font-family:'Inter',sans-serif">Table</button>
      <button onclick="document.getElementById('ct-inv-item-name').value='Chaise'" style="padding:5px 10px;border-radius:20px;border:1px solid #e5e3de;background:#f7f6f3;font-size:11px;cursor:pointer;font-family:'Inter',sans-serif">Chaise</button>
      <button onclick="document.getElementById('ct-inv-item-name').value='Lit'" style="padding:5px 10px;border-radius:20px;border:1px solid #e5e3de;background:#f7f6f3;font-size:11px;cursor:pointer;font-family:'Inter',sans-serif">Lit</button>
      <button onclick="document.getElementById('ct-inv-item-name').value='TV'" style="padding:5px 10px;border-radius:20px;border:1px solid #e5e3de;background:#f7f6f3;font-size:11px;cursor:pointer;font-family:'Inter',sans-serif">TV</button>
      <button onclick="document.getElementById('ct-inv-item-name').value='Micro-ondes'" style="padding:5px 10px;border-radius:20px;border:1px solid #e5e3de;background:#f7f6f3;font-size:11px;cursor:pointer;font-family:'Inter',sans-serif">Micro-ondes</button>
    </div>

    <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;margin-bottom:16px">
      <div>
        <label style="font-size:12px;font-weight:600;color:#52524e;display:block;margin-bottom:4px">Quantite</label>
        <input type="number" id="ct-inv-item-qty" value="1" min="1" style="width:100%;padding:10px 12px;border:1px solid #e5e3de;border-radius:8px;font-family:'Inter',sans-serif;font-size:14px;outline:none;box-sizing:border-box">
      </div>
      <div>
        <label style="font-size:12px;font-weight:600;color:#52524e;display:block;margin-bottom:4px">Etat</label>
        <select id="ct-inv-item-state" style="width:100%;padding:10px 12px;border:1px solid #e5e3de;border-radius:8px;font-family:'Inter',sans-serif;font-size:14px;outline:none;box-sizing:border-box;background:#fff">
          <option>Neuf</option>
          <option selected>Bon</option>
          <option>Correct</option>
          <option>Use</option>
        </select>
      </div>
      <div>
        <label style="font-size:12px;font-weight:600;color:#52524e;display:block;margin-bottom:4px">Valeur (EUR)</label>
        <input type="number" id="ct-inv-item-val" value="0" min="0" style="width:100%;padding:10px 12px;border:1px solid #e5e3de;border-radius:8px;font-family:'Inter',sans-serif;font-size:14px;outline:none;box-sizing:border-box">
      </div>
    </div>

    <button onclick="ctConfirmAddItem()" style="width:100%;padding:14px;background:#2b2d2b;color:#fff;border:none;border-radius:10px;font-family:'Inter',sans-serif;font-size:14px;font-weight:600;cursor:pointer">Ajouter l'objet</button>
  </div>
</div>

</div>


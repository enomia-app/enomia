---
// Composant outil Contrat Location Courte Durée
// Partagé par les 4 pages SEO (contrat-location-saisonniere, contrat-airbnb,
// contrat-location-gite, contrat-location-mobil-home) et la page pivot
// /contrat-lcd-dashboard.
//
// 4 écrans : Dashboard, Biens, Nouveau contrat, Paramètres.
// Auth : Google OAuth ou magic link via Supabase.
// Storage : Supabase (tables contrat_bailleur, contrat_biens, contrats).
// Langues : FR + EN (templates de contrat traduits statiquement).
// Export : PDF (via window.print + @media print) + Word (.doc via Blob).
---

<link rel="stylesheet" href="/css/contrat-tool.css" />


<!-- ═══════════════════════════════════════════════════════════════════
     MARKUP — outil contrat (4 screens + auth landing + modal login)
     ═══════════════════════════════════════════════════════════════════ -->

<div class="ctr-wrap">

  <!-- ─── NAV interne ─── -->
  <nav class="ctnav" id="ctnav" style="display:none">
    <div class="ctnav-title">Contrats <em>LCD</em></div>
    <div class="ctnav-tabs">
      <button class="ctnav-tab" data-screen="ctscreen-dashboard" onclick="ctShowScreen('ctscreen-dashboard')">📄 Contrats</button>
      <button class="ctnav-tab" data-screen="ctscreen-biens" onclick="ctShowScreen('ctscreen-biens')">🏠 Mes biens</button>
      <button class="ctnav-tab" data-screen="ctscreen-settings" onclick="ctShowScreen('ctscreen-settings')">⚙ Paramètres</button>
    </div>
    <div class="ctnav-user" id="ctnav-user-badge" onclick="ctLogout()">
      <div class="ctnav-avatar" id="ctnav-avatar">?</div>
      <span id="ctnav-user-label">Se déconnecter</span>
    </div>
  </nav>

  <!-- ─── AUTH LANDING (invité) — hidden by default, tool loads directly ─── -->
  <div class="screen" id="ctscreen-auth">
    <div class="auth-wrap">
      <div class="tag" style="justify-content:center">Générateur de contrat de location saisonnière</div>
      <h1 class="auth-title">Créez votre <em>contrat</em> en 2 minutes</h1>
      <p class="auth-sub">Modèle gratuit conforme Loi Le Meur 2024. Dashboard de suivi des paiements, génération PDF et Word, versions FR et EN.</p>
      <div class="auth-stats">
        <div class="auth-stat"><div class="auth-stat-v">2 min</div><div class="auth-stat-l">par contrat</div></div>
        <div class="auth-stat"><div class="auth-stat-v">100%</div><div class="auth-stat-l">gratuit</div></div>
        <div class="auth-stat"><div class="auth-stat-v">FR / EN</div><div class="auth-stat-l">bilingue</div></div>
      </div>
      <button class="btn accent lg" onclick="ctOpenLoginModal()" style="font-size:14px">+ Créer mon contrat gratuit →</button>
      <p style="font-family:var(--ct-mono);font-size:11px;color:var(--ct-muted2);margin-top:14px">Compte gratuit · sauvegardé dans le cloud</p>
    </div>
  </div>

  <!-- ─── DASHBOARD ─── -->
  <div class="screen" id="ctscreen-dashboard">
    <div class="page">
      <div class="page-header">
        <div>
          <div class="tag">Mes contrats</div>
          <h1 class="page-title">Tous vos <em>contrats</em> en un coup d'œil</h1>
          <div class="page-sub" id="ctdash-sub">Aucun contrat pour le moment</div>
        </div>
        <button class="btn accent lg" onclick="ctNewContract()">+ Nouveau contrat</button>
      </div>

      <div class="kpi-grid" id="ctdash-kpis">
        <div class="kpi accent">
          <div class="kpi-label">CA total</div>
          <div class="kpi-value" id="ctkpi-ca">0 €</div>
          <div class="kpi-delta" id="ctkpi-ca-delta">Aucun contrat</div>
        </div>
        <div class="kpi green">
          <div class="kpi-label">Encaissé</div>
          <div class="kpi-value" id="ctkpi-encaisse">0 €</div>
          <div class="kpi-delta" id="ctkpi-encaisse-delta">—</div>
        </div>
        <div class="kpi">
          <div class="kpi-label">À encaisser</div>
          <div class="kpi-value" id="ctkpi-du">0 €</div>
          <div class="kpi-delta" id="ctkpi-du-delta">—</div>
        </div>
        <div class="kpi">
          <div class="kpi-label">Cautions en cours</div>
          <div class="kpi-value" id="ctkpi-cautions">0 €</div>
          <div class="kpi-delta" id="ctkpi-cautions-delta">—</div>
        </div>
      </div>

      <div class="pills" id="ctdash-pills">
        <button class="pill active" data-filter="all">Tous <span class="pill-count" id="ctcnt-all">0</span></button>
        <button class="pill" data-filter="upcoming">À venir <span class="pill-count" id="ctcnt-upcoming">0</span></button>
        <button class="pill" data-filter="ongoing">En cours <span class="pill-count" id="ctcnt-ongoing">0</span></button>
        <button class="pill" data-filter="done">Soldés <span class="pill-count" id="ctcnt-done">0</span></button>
        <button class="pill" data-filter="late">⚠ Impayés <span class="pill-count" id="ctcnt-late">0</span></button>
      </div>

      <div class="table-wrap" id="ctdash-table-wrap">
        <table class="data">
          <thead>
            <tr>
              <th>Locataire</th>
              <th class="col-bien">Bien</th>
              <th>Séjour</th>
              <th>Montant</th>
              <th class="col-money">Acompte</th>
              <th class="col-money">Solde</th>
              <th class="col-money">Caution</th>
              <th>Statut</th>
              <th>Signé</th>
              <th></th>
            </tr>
          </thead>
          <tbody id="ctdash-tbody">
            <tr><td colspan="10" style="text-align:center;padding:60px 20px;color:var(--ct-muted);font-size:13px">
              Chargement…
            </td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- ─── BIENS ─── -->
  <div class="screen" id="ctscreen-biens">
    <div class="page">
      <div class="page-header">
        <div>
          <div class="tag">Mes biens</div>
          <h1 class="page-title">Votre <em>bibliothèque</em> de biens</h1>
          <div class="page-sub">Saisissez une fois, réutilisez à chaque contrat</div>
        </div>
        <button class="btn accent lg" onclick="ctNewBien()">+ Ajouter un bien</button>
      </div>

      <div class="biens-layout">
        <aside class="biens-sidebar">
          <div style="font-family:var(--ct-mono);font-size:10px;text-transform:uppercase;letter-spacing:0.08em;color:var(--ct-muted);margin-bottom:10px" id="ctbiens-count-label">Vos biens (0)</div>
          <div id="ctbiens-list"></div>
          <button class="add-bien-btn" onclick="ctNewBien()">+ Ajouter un bien</button>
        </aside>

        <div class="bien-detail" id="ctbien-detail">
          <div style="text-align:center;padding:60px 20px;color:var(--ct-muted);font-size:13px">
            Aucun bien sélectionné. Cliquez sur "+ Ajouter un bien" pour commencer.
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ─── NOUVEAU CONTRAT ─── -->
  <div class="screen" id="ctscreen-new-contract">
    <div class="page">
      <div class="page-header">
        <div>
          <a onclick="ctShowScreen('ctscreen-dashboard')" style="font-family:var(--ct-mono);font-size:11px;color:var(--ct-muted);cursor:pointer;display:inline-flex;align-items:center;gap:6px;margin-bottom:8px;text-decoration:none">← Retour aux contrats</a>
          <h1 class="page-title">Nouveau <em>contrat</em></h1>
          <div class="page-sub">3 étapes · environ 1 minute</div>
        </div>
      </div>

      <div class="wizard-layout">
        <div class="wizard-left" id="ctwizard-body">
          <!-- Contenu injecté dynamiquement selon l'étape -->
        </div>

        <aside class="preview-pane">
          <div class="preview-header">
            <span class="preview-title">📄 Aperçu du contrat (live)</span>
          </div>
          <div class="preview-body" id="ctpreview-body">
            <div class="pdf-page">
              <div class="pdf-h1">CONTRAT DE LOCATION SAISONNIÈRE</div>
              <div class="pdf-p" style="color:#888;font-style:italic">Sélectionnez un bien et remplissez les étapes pour voir l'aperçu du contrat.</div>
            </div>
          </div>
          <div class="dl-actions">
            <button class="btn accent" id="ctbtn-pdf" onclick="ctExportPdf()" disabled>↓ PDF</button>
            <button class="btn" id="ctbtn-word" onclick="ctExportWord()" disabled>↓ Word</button>
          </div>
        </aside>
      </div>
    </div>
  </div>

  <!-- ─── SETTINGS (bailleur) ─── -->
  <div class="screen" id="ctscreen-settings">
    <div class="page">
      <div class="page-header">
        <div>
          <div class="tag">Paramètres</div>
          <h1 class="page-title">Vos infos de <em>bailleur</em></h1>
          <div class="page-sub">Utilisées automatiquement sur tous vos contrats</div>
        </div>
      </div>

      <div style="max-width:720px;margin:0 auto" id="ctsettings-body">
        <!-- Injecté dynamiquement -->
      </div>
    </div>
  </div>

  <!-- ─── MAGIC LINK MODAL ─── -->
  <div class="modal-overlay" id="ctmodal">
    <div class="modal">
      <button class="modal-close" onclick="ctCloseModal()">✕</button>
      <h3 class="modal-title">Créez votre compte gratuit</h3>
      <p class="modal-sub">Pour sauvegarder vos contrats et les retrouver depuis n'importe quel appareil.</p>
      <button class="btn-google" onclick="ctSignInGoogle()">
        <svg width="18" height="18" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
        Continuer avec Google
      </button>
      <div class="divider">ou</div>
      <div class="field">
        <label class="field-label">Email</label>
        <input type="email" class="input" id="ctmodal-email" placeholder="votre@email.fr">
      </div>
      <button class="btn accent" style="width:100%;justify-content:center;margin-top:10px" onclick="ctSendMagicLink()">Recevoir un lien de connexion →</button>
      <div id="ctmodal-feedback" style="display:none;font-size:12px;text-align:center;margin-top:12px"></div>
    </div>
  </div>

  <!-- ─── SAVE POPUP (guest mode — nudge to create account) ─── -->
  <div id="ct-save-popup" style="display:none;position:fixed;bottom:24px;left:50%;transform:translateX(-50%);z-index:10000;background:var(--ct-accent);color:#fff;padding:16px 24px;border-radius:12px;box-shadow:0 8px 30px rgba(0,0,0,0.2);font-family:var(--ct-mono);font-size:13px;align-items:center;gap:16px;max-width:560px;width:calc(100% - 48px)">
    <div style="flex:1">
      <strong style="display:block;margin-bottom:4px">Vos donnees sont stockees localement</strong>
      <span style="font-size:11px;opacity:0.8">Connectez-vous pour synchroniser entre vos appareils et ne rien perdre.</span>
    </div>
    <div style="display:flex;gap:8px;flex-shrink:0;margin-top:10px">
      <button onclick="ctSavePopupLogin()" style="background:#fff;color:var(--ct-accent);border:none;padding:8px 16px;border-radius:8px;font-family:var(--ct-mono);font-size:12px;font-weight:600;cursor:pointer">Se connecter</button>
      <button onclick="ctDismissSavePopup()" style="background:transparent;color:rgba(255,255,255,0.7);border:1px solid rgba(255,255,255,0.3);padding:8px 12px;border-radius:8px;font-family:var(--ct-mono);font-size:12px;cursor:pointer">Plus tard</button>
    </div>
  </div>

<!-- Inventory room modal -->
<div id="ct-inv-modal" style="display:none;position:fixed;inset:0;z-index:600;background:rgba(0,0,0,0.5);backdrop-filter:blur(4px);align-items:center;justify-content:center;padding:24px">
  <div style="background:#fff;border:1px solid #e5e3de;border-radius:14px;padding:32px;max-width:400px;width:100%;position:relative;box-shadow:0 24px 48px rgba(0,0,0,0.1)">
    <button onclick="document.getElementById('ct-inv-modal').style.display='none'" style="position:absolute;top:14px;right:14px;background:none;border:none;font-size:18px;color:#8a8985;cursor:pointer">×</button>
    <div style="font-size:11px;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:#3fbd71;margin-bottom:12px">Ajouter une pièce</div>
    <div style="font-family:'Newsreader',serif;font-size:20px;font-weight:600;margin-bottom:16px">Nom de la pièce</div>
    <input type="text" id="ct-inv-room-input" placeholder="Ex: Salon, Chambre 1, Cuisine…" style="width:100%;padding:12px 14px;border:1px solid #e5e3de;border-radius:8px;font-family:'Inter',sans-serif;font-size:14px;outline:none;box-sizing:border-box;margin-bottom:12px">
    <div style="display:flex;flex-wrap:wrap;gap:6px;margin-bottom:20px">
      <button onclick="document.getElementById('ct-inv-room-input').value='Salon'" style="padding:6px 12px;border-radius:20px;border:1px solid #e5e3de;background:#f7f6f3;font-size:12px;cursor:pointer;font-family:'Inter',sans-serif">Salon</button>
      <button onclick="document.getElementById('ct-inv-room-input').value='Chambre 1'" style="padding:6px 12px;border-radius:20px;border:1px solid #e5e3de;background:#f7f6f3;font-size:12px;cursor:pointer;font-family:'Inter',sans-serif">Chambre 1</button>
      <button onclick="document.getElementById('ct-inv-room-input').value='Chambre 2'" style="padding:6px 12px;border-radius:20px;border:1px solid #e5e3de;background:#f7f6f3;font-size:12px;cursor:pointer;font-family:'Inter',sans-serif">Chambre 2</button>
      <button onclick="document.getElementById('ct-inv-room-input').value='Cuisine'" style="padding:6px 12px;border-radius:20px;border:1px solid #e5e3de;background:#f7f6f3;font-size:12px;cursor:pointer;font-family:'Inter',sans-serif">Cuisine</button>
      <button onclick="document.getElementById('ct-inv-room-input').value='Salle de bain'" style="padding:6px 12px;border-radius:20px;border:1px solid #e5e3de;background:#f7f6f3;font-size:12px;cursor:pointer;font-family:'Inter',sans-serif">Salle de bain</button>
      <button onclick="document.getElementById('ct-inv-room-input').value='Terrasse'" style="padding:6px 12px;border-radius:20px;border:1px solid #e5e3de;background:#f7f6f3;font-size:12px;cursor:pointer;font-family:'Inter',sans-serif">Terrasse</button>
    </div>
    <button onclick="ctConfirmAddRoom()" style="width:100%;padding:14px;background:#2b2d2b;color:#fff;border:none;border-radius:10px;font-family:'Inter',sans-serif;font-size:14px;font-weight:600;cursor:pointer">Ajouter la pièce</button>
  </div>
</div>

<!-- Inventory item modal -->
<div id="ct-inv-item-modal" style="display:none;position:fixed;inset:0;z-index:600;background:rgba(0,0,0,0.5);backdrop-filter:blur(4px);align-items:center;justify-content:center;padding:24px">
  <div style="background:#fff;border:1px solid #e5e3de;border-radius:14px;padding:32px;max-width:440px;width:100%;position:relative;box-shadow:0 24px 48px rgba(0,0,0,0.1)">
    <button onclick="document.getElementById('ct-inv-item-modal').style.display='none'" style="position:absolute;top:14px;right:14px;background:none;border:none;font-size:18px;color:#8a8985;cursor:pointer">&times;</button>
    <div style="font-size:11px;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:#3fbd71;margin-bottom:12px">Ajouter un objet</div>
    <div style="font-family:'Newsreader',serif;font-size:20px;font-weight:600;margin-bottom:16px">Nouvel objet</div>

    <label style="font-size:12px;font-weight:600;color:#52524e;display:block;margin-bottom:4px">Nom de l'objet *</label>
    <input type="text" id="ct-inv-item-name" placeholder="Ex: Canape, Table basse, TV..." style="width:100%;padding:12px 14px;border:1px solid #e5e3de;border-radius:8px;font-family:'Inter',sans-serif;font-size:14px;outline:none;box-sizing:border-box;margin-bottom:12px">

    <div style="display:flex;flex-wrap:wrap;gap:6px;margin-bottom:16px">
      <button onclick="document.getElementById('ct-inv-item-name').value='Canape'" style="padding:5px 10px;border-radius:20px;border:1px solid #e5e3de;background:#f7f6f3;font-size:11px;cursor:pointer;font-family:'Inter',sans-serif">Canape</button>
      <button onclick="document.getElementById('ct-inv-item-name').value='Table'" style="padding:5px 10px;border-radius:20px;border:1px solid #e5e3de;background:#f7f6f3;font-size:11px;cursor:pointer;font-family:'Inter',sans-serif">Table</button>
      <button onclick="document.getElementById('ct-inv-item-name').value='Chaise'" style="padding:5px 10px;border-radius:20px;border:1px solid #e5e3de;background:#f7f6f3;font-size:11px;cursor:pointer;font-family:'Inter',sans-serif">Chaise</button>
      <button onclick="document.getElementById('ct-inv-item-name').value='Lit'" style="padding:5px 10px;border-radius:20px;border:1px solid #e5e3de;background:#f7f6f3;font-size:11px;cursor:pointer;font-family:'Inter',sans-serif">Lit</button>
      <button onclick="document.getElementById('ct-inv-item-name').value='TV'" style="padding:5px 10px;border-radius:20px;border:1px solid #e5e3de;background:#f7f6f3;font-size:11px;cursor:pointer;font-family:'Inter',sans-serif">TV</button>
      <button onclick="document.getElementById('ct-inv-item-name').value='Micro-ondes'" style="padding:5px 10px;border-radius:20px;border:1px solid #e5e3de;background:#f7f6f3;font-size:11px;cursor:pointer;font-family:'Inter',sans-serif">Micro-ondes</button>
    </div>

    <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;margin-bottom:16px">
      <div>
        <label style="font-size:12px;font-weight:600;color:#52524e;display:block;margin-bottom:4px">Quantite</label>
        <input type="number" id="ct-inv-item-qty" value="1" min="1" style="width:100%;padding:10px 12px;border:1px solid #e5e3de;border-radius:8px;font-family:'Inter',sans-serif;font-size:14px;outline:none;box-sizing:border-box">
      </div>
      <div>
        <label style="font-size:12px;font-weight:600;color:#52524e;display:block;margin-bottom:4px">Etat</label>
        <select id="ct-inv-item-state" style="width:100%;padding:10px 12px;border:1px solid #e5e3de;border-radius:8px;font-family:'Inter',sans-serif;font-size:14px;outline:none;box-sizing:border-box;background:#fff">
          <option>Neuf</option>
          <option selected>Bon</option>
          <option>Correct</option>
          <option>Use</option>
        </select>
      </div>
      <div>
        <label style="font-size:12px;font-weight:600;color:#52524e;display:block;margin-bottom:4px">Valeur (EUR)</label>
        <input type="number" id="ct-inv-item-val" value="0" min="0" style="width:100%;padding:10px 12px;border:1px solid #e5e3de;border-radius:8px;font-family:'Inter',sans-serif;font-size:14px;outline:none;box-sizing:border-box">
      </div>
    </div>

    <button onclick="ctConfirmAddItem()" style="width:100%;padding:14px;background:#2b2d2b;color:#fff;border:none;border-radius:10px;font-family:'Inter',sans-serif;font-size:14px;font-weight:600;cursor:pointer">Ajouter l'objet</button>
  </div>
</div>

</div>

<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/dist/umd/supabase.min.js" is:inline></script>
<script src="/jspdf.min.js" is:inline></script>
<script is:inline src="/contrat-translations.js"></script>
<script is:inline src="/contrat-tool.js"></script>

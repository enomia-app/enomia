---
// CTA réutilisable : réservation directe Enomia (liste d'attente) + popup d'inscription Brevo.
// À réutiliser inline dans les articles pertinents quand le produit sera shippé.
const waitlistSource = 'WaitlistSite';
---

<aside class="ecta">
  <span class="ecta-kicker">Le QR code « Réservez en direct »</span>
  <h3 class="ecta-title">Transformez vos voyageurs en clients directs</h3>
  <p class="ecta-text">Un voyageur qui réserve via Airbnb ou Booking vous coûte une commission à chaque séjour. Un QR code sur votre livret l'invite à réserver son <strong>prochain</strong> séjour en direct : il dort déjà chez vous, il est conquis. Commission : <strong>0%</strong> au lieu de <a href="/blog/commissions-airbnb">jusqu'à 15%</a>. Sur une nuit à 100&nbsp;€, c'est 15&nbsp;€ récupérés à chaque réservation directe.</p>
  <div class="ecta-stat">
    <span class="ecta-stat-from">~11%</span>
    <span class="ecta-stat-arrow">→</span>
    <span class="ecta-stat-to">24%+</span>
    <span class="ecta-stat-lbl">de réservations en direct, l'objectif visé (contre ~11% en moyenne, tous canaux confondus)</span>
  </div>
  <p class="ecta-text"><strong>Enomia arrive</strong> : votre propre site de réservation directe, avec contrat signé et caution prélevée automatiquement à la réservation, et le QR code généré pour vous. Dès 9&nbsp;€/mois.</p>
  <button class="ecta-btn" id="ecta-open" type="button">Rejoindre la liste d'attente →</button>
</aside>

<div id="ewl-overlay" class="ewl-overlay" style="display:none" role="dialog" aria-modal="true" aria-label="Liste d'attente Enomia">
  <div class="ewl-card">
    <button class="ewl-close" type="button" aria-label="Fermer">&times;</button>
    <div id="ewl-form-step">
      <span class="ewl-badge">Liste d'attente</span>
      <div class="ewl-title">Votre site de réservation directe, bientôt</div>
      <p class="ewl-desc">Soyez prévenu·e au lancement d'Enomia : votre site de réservation en direct, avec <strong class="ewl-hl">contrat et caution automatiques</strong>. Accès prioritaire et tarif de lancement.</p>
      <form id="ewl-form" class="ewl-form">
        <input type="text" placeholder="Prénom" required class="ewl-input" autocomplete="given-name" />
        <input type="email" placeholder="votre@email.com" required class="ewl-input" autocomplete="email" />
        <div id="ewl-error" class="ewl-error" style="display:none"></div>
        <button type="submit" class="ewl-submit">Rejoindre la liste d'attente &rarr;</button>
      </form>
      <p class="ewl-note">Aucun spam &middot; Désinscription en 1 clic</p>
    </div>
    <div id="ewl-done-step" style="display:none">
      <div class="ewl-done-icon">✓</div>
      <div class="ewl-title">Vous êtes sur la liste&nbsp;!</div>
      <p class="ewl-desc">On vous prévient en avant-première dès le lancement d'Enomia.</p>
      <button class="ewl-submit ewl-ghost" type="button" id="ewl-done-close">Fermer</button>
    </div>
  </div>
</div>

<script is:inline define:vars={{ waitlistSource }}>
  (function () {
    var btn = document.getElementById('ecta-open');
    var overlay = document.getElementById('ewl-overlay');
    if (!btn || !overlay || overlay.dataset.init) return;
    overlay.dataset.init = '1';
    if (overlay.parentElement !== document.body) document.body.appendChild(overlay);

    function open() {
      document.getElementById('ewl-form-step').style.display = '';
      document.getElementById('ewl-done-step').style.display = 'none';
      overlay.style.display = 'flex'; document.body.style.overflow = 'hidden';
    }
    function close() { overlay.style.display = 'none'; document.body.style.overflow = ''; }
    window.openEnomiaWaitlist = open;

    btn.addEventListener('click', open);
    overlay.querySelector('.ewl-close').addEventListener('click', close);
    var dc = document.getElementById('ewl-done-close');
    if (dc) dc.addEventListener('click', close);
    overlay.addEventListener('click', function (e) { if (e.target === overlay) close(); });
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && overlay.style.display !== 'none') close();
    });

    var form = document.getElementById('ewl-form');
    form.addEventListener('submit', async function (e) {
      e.preventDefault();
      var ins = form.querySelectorAll('input');
      var fn = ins[0].value.trim(), em = ins[1].value.trim();
      var err = document.getElementById('ewl-error');
      err.style.display = 'none';
      if (!fn || !em || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(em)) {
        err.textContent = 'Prénom et email valides requis.'; err.style.display = ''; return;
      }
      var b = form.querySelector('button'), orig = b.innerHTML;
      b.disabled = true; b.textContent = 'Envoi…';
      try {
        var r = await fetch('/api/subscribe', {
          method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email: em, firstName: fn, source: waitlistSource }),
        });
        if (r.ok) {
          document.getElementById('ewl-form-step').style.display = 'none';
          document.getElementById('ewl-done-step').style.display = '';
        } else {
          err.textContent = 'Une erreur est survenue. Réessayez.'; err.style.display = '';
          b.disabled = false; b.innerHTML = orig;
        }
      } catch (_) {
        err.textContent = 'Une erreur est survenue. Réessayez.'; err.style.display = '';
        b.disabled = false; b.innerHTML = orig;
      }
    });
  })();
</script>

<style>
  .ecta { margin: 2rem 0; padding: 1.7rem 1.6rem; border-radius: 16px;
    background: linear-gradient(135deg, #2b2d2b 0%, #3a3c3a 100%); color: #e8e4dc; }
  .ecta-kicker { display: inline-block; font-size: .78rem; letter-spacing: .04em;
    text-transform: uppercase; color: #3fbd71; font-weight: 700; margin-bottom: .4rem; }
  .ecta-title { margin: .1rem 0 .7rem; font-size: 1.4rem; color: #fff; line-height: 1.25;
    font-family: 'Newsreader', Georgia, serif; }
  .ecta-text { margin: 0 0 .9rem; color: #b8b6b1; font-size: 1rem; line-height: 1.55; }
  .ecta-text strong { color: #e8e4dc; }
  .ecta-text a { color: #6cd49a; text-decoration: underline; }
  .ecta-stat { display: flex; flex-wrap: wrap; align-items: baseline; gap: .5rem;
    margin: 0 0 1rem; padding: .9rem 1rem; background: rgba(255,255,255,.06); border-radius: 10px; }
  .ecta-stat-from { font-size: 1.4rem; font-weight: 800; color: #8a8985; }
  .ecta-stat-arrow { font-size: 1.3rem; color: #3fbd71; }
  .ecta-stat-to { font-size: 1.9rem; font-weight: 800; color: #fff; }
  .ecta-stat-lbl { flex: 1 1 220px; font-size: .82rem; color: #8a8985; line-height: 1.35; }
  .ecta-btn { display: inline-block; margin-top: .2rem; background: #3fbd71; color: #fff;
    border: none; cursor: pointer; font-weight: 700; font-size: 1rem;
    padding: .85rem 1.5rem; border-radius: 10px; font-family: inherit; }
  .ecta-btn:hover { background: #36a361; }

  /* Popup waitlist */
  .ewl-overlay { position: fixed; inset: 0; z-index: 9998; display: none;
    align-items: center; justify-content: center; padding: 20px;
    background: rgba(0,0,0,.55); backdrop-filter: blur(4px); }
  .ewl-card { position: relative; width: 100%; max-width: 400px; border-radius: 16px;
    padding: 32px 30px 24px; color: #e8e4dc;
    background: linear-gradient(135deg, #2b2d2b 0%, #3a3c3a 100%);
    box-shadow: 0 24px 60px rgba(0,0,0,.35); font-family: 'Inter', -apple-system, sans-serif; }
  .ewl-close { position: absolute; top: 12px; right: 14px; background: none; border: none;
    font-size: 22px; line-height: 1; color: #8a8985; cursor: pointer; padding: 4px; }
  .ewl-close:hover { color: #fff; }
  .ewl-badge { display: inline-block; font-size: 9.5px; font-weight: 700; letter-spacing: .08em;
    text-transform: uppercase; color: #3fbd71; background: rgba(63,189,113,.15);
    border: 1px solid rgba(63,189,113,.3); padding: 5px 11px; border-radius: 20px; margin-bottom: 14px; }
  .ewl-title { font-family: 'Newsreader', Georgia, serif; font-size: 21px; font-weight: 700;
    color: #fff; line-height: 1.25; margin-bottom: 8px; }
  .ewl-desc { font-size: 13px; color: #b8b6b1; line-height: 1.6; margin: 0 0 18px; }
  .ewl-hl { color: #fff; }
  .ewl-form { display: flex; flex-direction: column; gap: 9px; }
  .ewl-input { padding: 12px 14px; background: rgba(255,255,255,.07);
    border: 1px solid rgba(255,255,255,.15); border-radius: 8px; color: #fff;
    font-family: inherit; font-size: 14px; outline: none; box-sizing: border-box; }
  .ewl-input:focus { border-color: #3fbd71; }
  .ewl-input::placeholder { color: #8a8985; }
  .ewl-error { font-size: 12px; color: #e05252; padding: 8px 12px;
    background: rgba(224,82,82,.08); border-radius: 6px; }
  .ewl-submit { padding: 13px; background: #3fbd71; color: #fff; border: none; border-radius: 8px;
    font-family: inherit; font-size: 14px; font-weight: 700; cursor: pointer; }
  .ewl-submit:hover { background: #36a361; }
  .ewl-submit:disabled { opacity: .6; cursor: wait; }
  .ewl-ghost { background: transparent; border: 1px solid #4a4c4a; margin-top: 6px; }
  .ewl-ghost:hover { background: rgba(255,255,255,.06); }
  .ewl-note { font-size: 10.5px; color: #8a8985; text-align: center; margin: 12px 0 0; line-height: 1.5; }
  .ewl-done-icon { width: 46px; height: 46px; margin: 0 auto 14px; border-radius: 50%;
    background: rgba(63,189,113,.15); color: #3fbd71; font-size: 24px; font-weight: 700;
    display: flex; align-items: center; justify-content: center; }
  #ewl-done-step { text-align: center; }
</style>

    "Île de Ré": { nonClasse: 4.40, cat1: 1.10, cat2: 1.90, cat3: 3.00, cat4: 4.40, cat5: 4.40, chambreHotes: 1.90 },
    "Île d'Oléron": { nonClasse: 3.00, cat1: 0.90, cat2: 1.50, cat3: 2.10, cat4: 3.00, cat5: 3.00, chambreHotes: 1.50 },
    "Metz": { nonClasse: 1.80, cat1: 0.70, cat2: 1.10, cat3: 1.50, cat4: 1.80, cat5: 1.80, chambreHotes: 1.10 },

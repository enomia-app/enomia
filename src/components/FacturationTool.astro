---
// Composant outil de facturation LCD — partagé par les 3 pages SEO.
// Gère : dashboard, nouvelle facture, biens, aperçu PDF, settings.
// Auth : Google OAuth via Supabase. Mode invité = localStorage, migration au login.
---

<link rel="stylesheet" href="/css/facturation-tool.css" />

<div class="fact-wrap" id="fact-wrap">


  <!-- Mini-nav interne -->
  <div class="fnav">
    <div class="fnav-left">
      <div class="fnav-title">Facturation <em>LCD</em></div>
    </div>
    <div class="fnav-tabs">
      <button class="fnav-tab active" data-screen="fscreen-dashboard" onclick="fShowScreen('fscreen-dashboard')">📄 Factures</button>
      <button class="fnav-tab" data-screen="fscreen-biens" onclick="fShowScreen('fscreen-biens')">🏠 Mes biens</button>
      <button class="fnav-tab" data-screen="fscreen-settings" onclick="fShowScreen('fscreen-settings')">⚙ Paramètres</button>
    </div>
    <div class="fnav-right">
      <div class="fnav-user" id="fnav-user-badge" style="display:none" onclick="fLogout()">
        <div class="fnav-avatar" id="fnav-avatar">?</div>
        <span id="fnav-user-label">email</span>
      </div>
      <button class="btn-sm" id="fnav-login-btn" onclick="fOpenLoginModal()">Se connecter</button>
    </div>
  </div>

  <!-- SCREEN 1 — DASHBOARD -->
  <div id="fscreen-dashboard" class="screen active">
    <div class="dashboard">
      <div class="dash-header">
        <div>
          <h2 class="dash-title">Mes <em>factures</em></h2>
          <div class="dash-sub">Générez vos factures de location courte durée</div>
        </div>
        <button class="btn-sm accent" onclick="fShowScreen('fscreen-new'); fResetForm()">+ Nouvelle facture</button>
      </div>


      <div class="filter-row">
        <span class="filter-label">Exercice</span>
        <div class="mode-tabs">
          <button class="mode-tab on" onclick="fFilterYear(2026, this)">2026</button>
          <button class="mode-tab" onclick="fFilterYear(2027, this)">2027</button>
          <button class="mode-tab" onclick="fFilterYear(2028, this)">2028</button>
        </div>
      </div>

      <div class="stats-bar">
        <div class="stat-card">
          <div class="stat-card-l">Total encaissé <span id="fstats-year">2026</span></div>
          <div class="stat-card-v" id="fstat-total">— €</div>
          <div class="stat-card-sub">factures payées uniquement</div>
        </div>
        <div class="stat-card">
          <div class="stat-card-l">Nb factures</div>
          <div class="stat-card-v" id="fstat-count">—</div>
          <div class="stat-card-sub" id="fstat-sub-count">sur l'exercice sélectionné</div>
        </div>
        <div class="stat-card">
          <div class="stat-card-l">Moyenne / facture</div>
          <div class="stat-card-v" id="fstat-avg">— €</div>
          <div class="stat-card-sub">toutes factures</div>
        </div>
      </div>

      <div class="table-wrap">
        <table>
          <thead>
            <tr><th>Client</th><th>Bien</th><th>Séjour</th><th>Montant</th><th>Statut</th><th></th></tr>
          </thead>
          <tbody id="finvoice-tbody"></tbody>
        </table>
      </div>

      <div class="legal-disclaimer" style="margin-top:16px">
        ⚠ Cet outil est un générateur de documents d'aide à la facturation. Il ne constitue pas un logiciel de facturation certifié (NF 525). Pour une comptabilité officielle soumise à audit, utilisez un logiciel homologué.
      </div>
    </div>
  </div>

  <!-- SCREEN 2 — NEW INVOICE -->
  <div id="fscreen-new" class="screen">
    <div class="calc-topbar">
      <button class="calc-back" onclick="fShowScreen('fscreen-dashboard')">← Retour</button>
      <div class="calc-title" id="fnew-title">Nouvelle facture</div>
      <div class="calc-actions" style="display:flex;gap:8px">
        <button class="btn-sm" onclick="fOpenPdfModal()">Aperçu PDF</button>
        <button class="btn-sm accent" onclick="fSaveInvoice()">✓ Enregistrer</button>
      </div>
    </div>

    <div class="calc-main">
      <div class="calc-left">
        <div class="legal-disclaimer" style="margin-bottom:24px">
          ⚠ Générateur d'aide — non NF 525. Pour comptabilité soumise à audit, utilisez un logiciel homologué.
        </div>

        <div style="margin-bottom:34px">
          <div class="sec-t"><span class="sec-num">01</span> Loueur</div>
          <div class="sg">
            <label class="sg-label">Nom / Prénom ou Société</label>
            <input type="text" id="fl-nom" placeholder="Jean Dupont">
          </div>
          <div class="sg">
            <label class="sg-label">Adresse complète</label>
            <input type="text" id="fl-adresse" placeholder="12 rue de la Paix, 75001 Paris">
          </div>
          <div class="sg">
            <label class="sg-label">SIRET (optionnel)</label>
            <input type="text" id="fl-siret" placeholder="849 327 145 00018">
          </div>
        </div>

        <div style="margin-bottom:34px">
          <div class="sec-t"><span class="sec-num">02</span> Client</div>
          <div class="sg-row">
            <div class="sg">
              <label class="sg-label">Prénom</label>
              <input type="text" id="fc-prenom" placeholder="Marie">
            </div>
            <div class="sg">
              <label class="sg-label">Nom</label>
              <input type="text" id="fc-nom" placeholder="Martin">
            </div>
          </div>
          <div class="sg">
            <label class="sg-label">Email</label>
            <input type="email" id="fc-email" placeholder="marie.martin@email.com">
          </div>
          <div class="sg">
            <label class="sg-label">Adresse (optionnel)</label>
            <input type="text" id="fc-adresse" placeholder="45 avenue des Fleurs, 69001 Lyon">
          </div>
        </div>

        <div>
          <div class="sec-t"><span class="sec-num">03</span> Séjour</div>
          <div class="sg">
            <label class="sg-label">Bien loué</label>
            <div class="bien-select-row">
              <select id="fs-bien" onchange="fCalcTotal()">
                <option value="">— Sélectionner un bien —</option>
              </select>
              <button class="add-bien-link" onclick="fOpenBienModal(null)" title="Ajouter un bien">+</button>
            </div>
          </div>
          <div class="sg">
            <label class="sg-label">Nombre de personnes</label>
            <input type="number" id="fs-personnes" placeholder="2" min="1" max="20" oninput="fCalcTotal()">
          </div>
          <div class="sg-row">
            <div class="sg">
              <label class="sg-label">Date d'arrivée</label>
              <input type="date" id="fs-arrivee" onchange="fCalcNights()">
            </div>
            <div class="sg">
              <label class="sg-label">Date de départ</label>
              <input type="date" id="fs-depart" onchange="fCalcNights()">
            </div>
          </div>
          <div class="nights-display">
            <span class="nights-num" id="fnights-num">—</span>
            <span id="fnights-label" style="font-size:13px;color:var(--fa-muted)">nuit(s)</span>
          </div>
          <div style="height:16px"></div>
          <div class="sg-row">
            <div class="sg">
              <label class="sg-label">Prix par nuit (€)</label>
              <input type="number" id="fs-prixnuit" placeholder="85" min="0" step="0.01" oninput="fCalcTotal()">
            </div>
            <div class="sg">
              <label class="sg-label">Frais de ménage (€)</label>
              <input type="number" id="fs-menage" placeholder="50" min="0" step="0.01" oninput="fCalcTotal()">
            </div>
          </div>
          <div class="sg">
            <label class="sg-label">Caution (€) — non incluse dans le total</label>
            <input type="number" id="fs-caution" placeholder="300" min="0" step="0.01">
            <div class="caution-note">La caution apparaît sur la facture à titre informatif</div>
          </div>
          <div class="sg">
            <label class="sg-label">Frais supplémentaires (optionnel)</label>
            <div class="extra-row">
              <input type="text" id="fs-extra-label" placeholder="Ex : Frais de service">
              <input type="number" id="fs-extra-montant" placeholder="0" min="0" step="0.01" oninput="fCalcTotal()">
            </div>
          </div>
          <div class="sg-row">
            <div class="sg">
              <label class="sg-label">Mode de paiement</label>
              <select id="fs-paiement">
                <option value="Virement bancaire">Virement bancaire</option>
                <option value="Espèces">Espèces</option>
                <option value="Carte bancaire">Carte bancaire</option>
                <option value="Airbnb">Airbnb</option>
                <option value="Booking.com">Booking.com</option>
              </select>
            </div>
            <div class="sg">
              <label class="sg-label">Statut</label>
              <select id="fs-statut">
                <option value="Payée">Payée</option>
                <option value="En attente">En attente</option>
              </select>
            </div>
          </div>
        </div>
      </div>

      <div class="calc-right">
        <div class="recap-panel-title">Récapitulatif</div>
        <div style="height:6px"></div>
        <div class="rb2">
          <div class="rb2-t">Détail du séjour</div>
          <div class="rr"><span class="rrl">Nombre de nuits</span><span class="rrv" id="frecap-nuits">—</span></div>
          <div class="rr"><span class="rrl">Sous-total hébergement</span><span class="rrv" id="frecap-hebergement">— €</span></div>
          <div class="rr"><span class="rrl">Frais de ménage</span><span class="rrv" id="frecap-menage">— €</span></div>
          <div class="rr" id="frecap-taxe-row" style="display:none">
            <span class="rrl" style="display:flex;flex-direction:column;gap:2px">
              <span>Taxe de séjour</span>
              <span class="taxe-note" id="frecap-taxe-note"></span>
            </span>
            <span class="rrv" id="frecap-taxe-val">— €</span>
          </div>
          <div class="rr" id="frecap-taxe-manual-row" style="display:none">
            <span class="rrl" style="display:flex;flex-direction:column;gap:4px">
              <span>Taxe de séjour (manuelle)</span>
              <span class="taxe-note" style="color:var(--fa-red)">Ville non trouvée — saisir manuellement</span>
              <input type="number" id="fs-taxe-manuelle" placeholder="0" min="0" step="0.01" oninput="fCalcTotal()" style="margin-top:4px;font-size:12px;padding:6px 10px">
            </span>
            <span class="rrv" id="frecap-taxe-manual-val">— €</span>
          </div>
          <div class="rr" id="frecap-extra-row" style="display:none">
            <span class="rrl" id="frecap-extra-label">Frais supplémentaires</span>
            <span class="rrv" id="frecap-extra-val">— €</span>
          </div>
          <div class="rr rr-total">
            <span class="rrl" style="color:var(--fa-text);font-weight:500">Total TTC</span>
            <span class="rrv big" id="frecap-total">0,00 €</span>
          </div>
        </div>
        <div class="recap-tva-note">
          TVA non applicable, art. 293 B du CGI.<br>
          En qualité de loueur meublé non professionnel (LMNP), aucune TVA n'est collectée ni déductible.
        </div>
        <div class="recap-actions">
          <button class="btn-sm accent" style="width:100%;justify-content:center;height:40px;font-size:13px" onclick="fOpenPdfModal()">Aperçu PDF</button>
          <button class="btn-sm" style="width:100%;justify-content:center;height:40px;font-size:13px" onclick="fSaveInvoice()">Enregistrer</button>
        </div>
      </div>
    </div>
  </div>

  <!-- SCREEN 3 — BIENS -->
  <div id="fscreen-biens" class="screen">
    <div class="dashboard">
      <div class="dash-header">
        <div>
          <h2 class="dash-title">Mes <em>biens</em></h2>
          <div class="dash-sub">Gérez vos propriétés LCD (calcul taxe de séjour automatique)</div>
        </div>
        <button class="btn-sm accent" onclick="fOpenBienModal(null)">+ Ajouter un bien</button>
      </div>
      <div id="fbiens-list" class="biens-grid"></div>
    </div>
  </div>

  <!-- MODAL LOGIN -->
  <div id="fmodal-login" class="modal-overlay" onclick="fCloseModalOnBg(event, 'fmodal-login')">
    <div class="modal-inner" style="max-width:420px">
      <div class="modal-header">
        <div class="modal-title">Se connecter</div>
        <div class="modal-actions"><button class="modal-close" onclick="fCloseModal('fmodal-login')">×</button></div>
      </div>
      <div class="modal-body" style="padding:24px">
        <p style="font-size:13px;color:var(--fa-muted);margin-bottom:20px">Pour sauvegarder vos factures et les retrouver depuis n'importe quel appareil.</p>
        <button class="btn-sm accent" onclick="fLogin()" style="width:100%;padding:12px;font-size:14px;margin-bottom:16px">Se connecter avec Google</button>
        <div style="text-align:center;font-size:12px;color:var(--fa-muted2);margin-bottom:16px">ou</div>
        <div style="display:flex;gap:8px">
          <input type="email" id="flogin-email" placeholder="email@exemple.com" style="flex:1;padding:10px 12px;border:1px solid var(--fa-border);border-radius:6px;font-size:13px">
          <button class="btn-sm" onclick="fSendMagicLink()">Envoyer le lien</button>
        </div>
        <div id="flogin-feedback" style="display:none;font-size:12px;margin-top:10px"></div>
      </div>
    </div>
  </div>

  <!-- MODAL PDF -->
  <div id="fmodal-pdf" class="modal-overlay" onclick="fCloseModalOnBg(event, 'fmodal-pdf')">
    <div class="modal-inner">
      <div class="modal-header">
        <div class="modal-title">Aperçu de la facture</div>
        <div class="modal-actions">
          <button class="btn-sm accent" onclick="fExportPdf()">↓ Télécharger PDF</button>
          <button class="modal-close" onclick="fCloseModal('fmodal-pdf')">×</button>
        </div>
      </div>
      <div class="modal-body">
        <div class="invoice-doc" id="finvoice-preview"></div>
      </div>
    </div>
  </div>

  <!-- SCREEN 4 — SETTINGS -->
  <div id="fscreen-settings" class="screen">
    <div class="dashboard">
      <div class="dash-header">
        <div>
          <h2 class="dash-title">Vos <em>paramètres</em></h2>
          <div class="dash-sub">Informations utilisées automatiquement sur toutes vos factures</div>
        </div>
        <button class="btn-sm accent" onclick="fSaveSettings()">✓ Sauvegarder</button>
      </div>
      <div style="max-width:560px">
        <div style="margin-bottom:26px">
          <div class="sec-t" style="font-size:14px;margin-bottom:16px"><span class="sec-num">01</span> Informations loueur</div>
          <div class="sg">
            <label class="sg-label">Nom / Prénom ou Société</label>
            <input type="text" id="fset-nom" placeholder="Jean Dupont">
          </div>
          <div class="sg">
            <label class="sg-label">Adresse complète</label>
            <input type="text" id="fset-adresse" placeholder="12 rue de la Paix, 75001 Paris">
          </div>
          <div class="sg">
            <label class="sg-label">SIRET (optionnel)</label>
            <input type="text" id="fset-siret" placeholder="123 456 789 00010">
          </div>
        </div>
        <div>
          <div class="sec-t" style="font-size:14px;margin-bottom:16px"><span class="sec-num">02</span> Mention légale personnalisée</div>
          <div class="sg">
            <label class="sg-label">Texte affiché en bas de facture</label>
            <textarea id="fset-mention" placeholder="TVA non applicable, art. 293 B du CGI. En qualité de loueur en meublé non professionnel (LMNP), je ne suis pas assujetti à la TVA."></textarea>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- MODAL BIEN -->
  <div id="fmodal-bien" class="modal-overlay" onclick="fCloseModalOnBg(event, 'fmodal-bien')">
    <div class="modal-inner">
      <div class="modal-header">
        <div class="modal-title" id="fmodal-bien-title">Ajouter un bien</div>
        <div class="modal-actions">
          <button class="btn-sm accent" onclick="fSaveBien()">✓ Enregistrer</button>
          <button class="modal-close" onclick="fCloseModal('fmodal-bien')">×</button>
        </div>
      </div>
      <div class="modal-body">
        <input type="hidden" id="fbien-edit-id">
        <div class="sg">
          <label class="sg-label">Nom du bien</label>
          <input type="text" id="fbien-nom" placeholder="Studio Marais">
        </div>
        <div class="sg">
          <label class="sg-label">Adresse complète</label>
          <input type="text" id="fbien-adresse" placeholder="12 rue des Rosiers, 75004 Paris">
        </div>
        <div class="sg">
          <label class="sg-label">Ville</label>
          <div class="autocomplete-wrap">
            <input type="text" id="fbien-ville" placeholder="Paris" autocomplete="off" oninput="fVilleAutocomplete(this)" onblur="setTimeout(fCloseVilleList,200)">
            <div class="autocomplete-list" id="fville-autocomplete-list"></div>
          </div>
        </div>
        <div class="sg">
          <label class="sg-label">Catégorie</label>
          <select id="fbien-categorie" onchange="fUpdateBienTaxePreview()">
            <option value="Meublé de tourisme non classé">Meublé de tourisme non classé</option>
            <option value="Meublé de tourisme 1★">Meublé de tourisme 1★</option>
            <option value="Meublé de tourisme 2★">Meublé de tourisme 2★</option>
            <option value="Meublé de tourisme 3★">Meublé de tourisme 3★</option>
            <option value="Meublé de tourisme 4★">Meublé de tourisme 4★</option>
            <option value="Meublé de tourisme 5★">Meublé de tourisme 5★</option>
            <option value="Chambre d'hôtes">Chambre d'hôtes</option>
          </select>
        </div>
        <div class="sg">
          <label class="sg-label">Capacité d'accueil</label>
          <input type="number" id="fbien-capacite" placeholder="4" min="1" max="50">
        </div>
        <div id="fbien-taxe-preview" style="margin-top:12px;padding:12px 14px;background:var(--fa-mid);border:1px solid var(--fa-border);font-size:11px;color:var(--fa-muted);display:none;border-radius:4px">
          Taxe de séjour estimée : <strong id="fbien-taxe-preview-val"></strong>
        </div>
      </div>
    </div>
  </div>

  <div id="ftoast" class="ftoast"></div>
</div>

<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/dist/umd/supabase.min.js" is:inline></script>
<script src="/jspdf.min.js" is:inline></script>
<script src="/facturation-tool.js" is:inline></script>

---
interface Props {
  variant?: 'marketing' | 'tool';
  currentTool?: 'simulateur' | 'facture' | 'contrat';
  ctaLabel?: string;
  ctaHref?: string;
}

const { variant = 'marketing', currentTool, ctaLabel, ctaHref } = Astro.props;
const isTool = variant === 'tool';
---

<header class="eh">
  <div class="eh-inner">
    <!-- Logo -->
    <a href="/" class="eh-logo">
      <div class="eh-logo-icon">
        <div class="bar"></div><div class="bar"></div><div class="bar"></div>
      </div>
      <div class="eh-logo-text">
        <span class="eh-logo-name">Enomia</span>
        <span class="eh-logo-tagline">Un flux parfait. Pour tous.</span>
      </div>
    </a>

    <!-- Nav center -->
    <nav class="eh-nav">
      <a href="/blog" class="eh-nav-link">Blog</a>

      <div class="eh-dropdown">
        <button class="eh-dropdown-trigger" aria-expanded="false" aria-haspopup="true">
          Outils
          <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M3 4.5L6 7.5L9 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
        <div class="eh-dropdown-menu">
          <a href="/simulateur-rentabilite-airbnb" class:list={["eh-dropdown-item", { active: currentTool === 'simulateur' }]}>
            <div class="eh-tool-info">
              <span class="eh-tool-name">Simulateur rentabilité LCD</span>
              <span class="eh-tool-desc">Estimez vos revenus locatifs</span>
            </div>
            <span class="eh-badge-free">Gratuit</span>
          </a>
          <a href="/contrat-location-saisonniere" class:list={["eh-dropdown-item", { active: currentTool === 'contrat' }]}>
            <div class="eh-tool-info">
              <span class="eh-tool-name">Contrat de location</span>
              <span class="eh-tool-desc">Générez vos contrats LCD</span>
            </div>
            <span class="eh-badge-free">Gratuit</span>
          </a>
          <a href="/facture-location-saisonniere" class:list={["eh-dropdown-item", { active: currentTool === 'facture' }]}>
            <div class="eh-tool-info">
              <span class="eh-tool-name">Factures LCD</span>
              <span class="eh-tool-desc">Facturez vos locations</span>
            </div>
            <span class="eh-badge-free">Gratuit</span>
          </a>
        </div>
      </div>
    </nav>

    <!-- CTA right (empty — tools have their own nav) -->
    <div class="eh-right"></div>

    <!-- Mobile hamburger -->
    <button class="eh-mobile-btn" aria-label="Menu" id="eh-mobile-toggle">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M3 5h14M3 10h14M3 15h14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div class="eh-mobile-menu" id="eh-mobile-menu">
    <a href="/blog" class="eh-mobile-link">Blog</a>
    <a href="/simulateur-rentabilite-airbnb" class="eh-mobile-link">Simulateur rentabilité LCD</a>
    <a href="/contrat-location-saisonniere" class="eh-mobile-link">Contrat de location</a>
    <a href="/facture-location-saisonniere" class="eh-mobile-link">Factures LCD</a>
  </div>
</header>

<script>
  const toggle = document.getElementById('eh-mobile-toggle');
  const menu = document.getElementById('eh-mobile-menu');
  if (toggle && menu) {
    toggle.addEventListener('click', () => {
      const open = menu.classList.toggle('open');
      toggle.setAttribute('aria-expanded', String(open));
    });
  }
</script>

<style>
  /* ═══ HEADER COMPONENT ═══ */
  .eh {
    position: sticky; top: 0; z-index: 100;
    background: rgba(247,246,243,0.92);
    backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--border, #e5e3de);
  }

  .eh-inner {
    display: flex; align-items: center; justify-content: space-between;
    padding: 0 40px; height: 64px;
    max-width: var(--max-w, 1120px); margin: 0 auto;
    position: relative;
  }

  /* ─── Logo ─── */
  .eh-logo {
    display: flex; align-items: center; gap: 10px;
    text-decoration: none; flex-shrink: 0;
  }

  .eh-logo-icon {
    width: 30px; height: 30px;
    background: var(--bg-dark, #2b2d2b);
    border-radius: 7px;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    gap: 2.5px; padding: 7px;
  }

  .eh-logo-icon .bar {
    width: 100%; height: 1.5px;
    background: var(--text-light, #e8e4dc);
    border-radius: 1px;
  }

  .eh-logo-icon .bar:nth-child(2) {
    width: 65%; align-self: flex-start;
  }

  .eh-logo-text {
    display: flex; flex-direction: column;
  }

  .eh-logo-name {
    font-size: 16px; font-weight: 700;
    color: var(--text, #1a1a1a);
    letter-spacing: -0.01em; line-height: 1.2;
  }

  .eh-logo-tagline {
    font-size: 11px;
    color: var(--text-secondary, #52524e);
    letter-spacing: 0.01em; line-height: 1.2;
  }

  /* ─── Nav center ─── */
  .eh-nav {
    display: flex; align-items: center; gap: 32px;
    position: absolute; left: 50%; transform: translateX(-50%);
  }

  .eh-nav-link {
    font-size: 13px; font-weight: 500;
    color: var(--text-secondary, #52524e);
    text-decoration: none; transition: color 0.2s;
  }

  .eh-nav-link:hover { color: var(--text, #1a1a1a); }

  /* ─── Dropdown ─── */
  .eh-dropdown { position: relative; }

  .eh-dropdown-trigger {
    font-size: 13px; font-weight: 500;
    color: var(--text-secondary, #52524e);
    background: none; border: none; cursor: pointer;
    font-family: inherit;
    display: flex; align-items: center; gap: 4px;
    padding: 4px 0; transition: color 0.2s;
  }

  .eh-dropdown-trigger:hover { color: var(--text, #1a1a1a); }

  .eh-dropdown-trigger svg { transition: transform 0.2s; }
  .eh-dropdown:hover .eh-dropdown-trigger svg { transform: rotate(180deg); }

  .eh-dropdown-menu {
    position: absolute;
    top: calc(100% + 12px); left: 50%; transform: translateX(-50%);
    min-width: 260px;
    background: #ffffff;
    border: 1px solid var(--border, #e5e3de);
    border-radius: 10px; padding: 6px;
    opacity: 0; visibility: hidden;
    transition: opacity 0.15s, visibility 0.15s;
    box-shadow: 0 8px 32px rgba(0,0,0,0.08);
  }

  .eh-dropdown:hover .eh-dropdown-menu {
    opacity: 1; visibility: visible;
  }

  .eh-dropdown-item {
    display: flex; align-items: center; justify-content: space-between;
    padding: 10px 14px; text-decoration: none;
    color: var(--text, #1a1a1a);
    font-size: 13px; font-weight: 500;
    border-radius: 7px; transition: background 0.15s;
  }

  .eh-dropdown-item:hover { background: var(--bg, #f7f6f3); }
  .eh-dropdown-item.active { background: var(--bg, #f7f6f3); }

  .eh-tool-info { display: flex; flex-direction: column; gap: 1px; }
  .eh-tool-name { font-size: 13px; font-weight: 500; color: var(--text, #1a1a1a); }
  .eh-tool-desc { font-size: 11px; color: var(--text-tertiary, #8a8985); }

  .eh-badge-free {
    font-size: 10px; font-weight: 600;
    color: var(--green, #3fbd71);
    background: rgba(63,189,113,0.1);
    padding: 2px 8px; border-radius: 20px;
    letter-spacing: 0.03em; flex-shrink: 0;
  }

  /* ─── CTA right ─── */
  .eh-right {
    display: flex; align-items: center; gap: 12px; flex-shrink: 0;
  }

  .eh-btn {
    font-family: inherit;
    font-size: 12px; font-weight: 600;
    padding: 8px 18px; border-radius: 8px;
    text-decoration: none; cursor: pointer;
    transition: all 0.2s; border: none;
    white-space: nowrap; display: inline-flex; align-items: center;
    line-height: 1;
  }

  .eh-btn-green {
    background: var(--green, #3fbd71);
    color: #ffffff;
  }

  .eh-btn-green:hover { background: #36a863; }

  /* ─── Mobile ─── */
  .eh-mobile-btn {
    display: none;
    background: none; border: none; cursor: pointer;
    padding: 8px; color: var(--text, #1a1a1a);
  }

  .eh-mobile-btn svg { width: 20px; height: 20px; }

  .eh-mobile-menu {
    display: none; flex-direction: column;
    border-top: 1px solid var(--border, #e5e3de);
    background: rgba(247,246,243,0.98);
    padding: 8px 20px 12px;
  }

  .eh-mobile-link {
    font-size: 14px; font-weight: 500;
    color: var(--text-secondary, #52524e);
    text-decoration: none;
    padding: 10px 0;
    border-bottom: 1px solid var(--border, #e5e3de);
    transition: color 0.15s;
  }

  .eh-mobile-link:last-child { border-bottom: none; }
  .eh-mobile-link:hover { color: var(--text, #1a1a1a); }

  @media (max-width: 768px) {
    .eh-inner { padding: 0 20px; }
    .eh-nav { display: none; }
    .eh-right { margin-left: auto; margin-right: 8px; }
    .eh-btn { font-size: 11px; padding: 6px 12px; }
    .eh-logo-tagline { display: none; }
    .eh-mobile-btn { display: flex; }
    .eh-mobile-menu.open { display: flex; }
  }
</style>

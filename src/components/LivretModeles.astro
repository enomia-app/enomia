---
// Galerie des 10 modèles de livret d'accueil (Claude Design) + téléchargement PPTX + pop-up slider.
const designs = [
  { file: '01-aquarelle-botanique', label: 'Aquarelle botanique' },
  { file: '02-moderne-colore', label: 'Moderne coloré' },
  { file: '03-chic-elegant', label: 'Chic & élégant' },
  { file: '04-mediterraneen', label: 'Méditerranéen' },
  { file: '05-scandinave-nature', label: 'Scandinave nature' },
  { file: '06-minimaliste-editorial', label: 'Minimaliste éditorial' },
  { file: '07-sombre-nuit', label: 'Sombre nuit' },
  { file: '08-champetre-kraft', label: 'Champêtre kraft' },
  { file: '09-tropical-jungle', label: 'Tropical jungle' },
  { file: '10-art-deco', label: 'Art déco' },
];
const PPTX = '/livret-accueil/livret-accueil-enomia.pptx';
const imgsJson = JSON.stringify(designs.map((d) => ({ src: `/livret-accueil/${d.file}.jpg`, label: d.label })));
---

<section class="lm" id="livret-modeles" data-imgs={imgsJson}>
  <div class="lm-head">
    <h2 class="lm-title">10 modèles de livret d'accueil à télécharger</h2>
    <p class="lm-sub">Gratuits, éditables, sans inscription. Choisissez un design, téléchargez le fichier PowerPoint, remplacez les champs et imprimez-le.</p>
  </div>

  <div class="lm-grid">
    {designs.map((d) => (
      <button class="lm-thumb" type="button" aria-label={`Agrandir le modèle ${d.label}`}>
        <img src={`/livret-accueil/${d.file}.jpg`} alt={`Modèle de livret d'accueil Airbnb ${d.label}`} loading="lazy" width="920" height="1301" />
        <span class="lm-thumb-cap">{d.label}</span>
      </button>
    ))}
  </div>

  <div class="lm-dl">
    <a class="lm-dl-btn" id="lm-download" href={PPTX} download>Télécharger les 10 modèles (.pptx)</a>
    <span class="lm-dl-note">Un seul fichier, 10 designs. Compatible PowerPoint, Google Slides et Canva.</span>
  </div>

  <div class="lm-modal" role="dialog" aria-modal="true" aria-label="Aperçu du modèle de livret">
    <button class="lm-close" type="button" aria-label="Fermer">&times;</button>
    <button class="lm-prev" type="button" aria-label="Modèle précédent">&lsaquo;</button>
    <figure class="lm-modal-fig">
      <img class="lm-modal-img" src="" alt="" width="920" height="1301" />
      <figcaption class="lm-modal-cap"></figcaption>
    </figure>
    <button class="lm-next" type="button" aria-label="Modèle suivant">&rsaquo;</button>
    <a class="lm-modal-dl" href={PPTX} download>Télécharger les 10 modèles (.pptx)</a>
  </div>
</section>

<style>
  .lm { margin: 2.5rem 0; }
  .lm-head { margin-bottom: 1.25rem; }
  .lm-title { font-size: 1.5rem; line-height: 1.25; margin: 0 0 .4rem; }
  .lm-sub { color: #555; margin: 0; font-size: 1rem; }

  .lm-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
    gap: .9rem;
  }
  .lm-thumb {
    appearance: none; border: 1px solid #e6e3dd; background: #fff; padding: 0;
    border-radius: 12px; overflow: hidden; cursor: pointer; display: flex;
    flex-direction: column; transition: transform .15s ease, box-shadow .15s ease;
  }
  .lm-thumb:hover, .lm-thumb:focus-visible {
    transform: translateY(-3px); box-shadow: 0 10px 24px rgba(0,0,0,.12); outline: none;
  }
  .lm-thumb img { width: 100%; aspect-ratio: 920 / 1301; object-fit: cover; display: block; background: #f3f0ea; }
  .lm-thumb-cap { font-size: .8rem; color: #444; padding: .5rem .4rem; text-align: center; font-weight: 600; }

  .lm-dl { margin: 1.4rem 0 .5rem; display: flex; flex-wrap: wrap; align-items: center; gap: .5rem 1rem; }
  .lm-dl-btn {
    display: inline-block; background: #2f6f72; color: #fff !important; font-weight: 700;
    padding: .8rem 1.4rem; border-radius: 10px; text-decoration: none; font-size: 1.02rem;
    box-shadow: 0 6px 16px rgba(47,111,114,.28); transition: background .15s ease;
  }
  .lm-dl-btn:hover { background: #255b5e; }
  .lm-dl-note { color: #666; font-size: .88rem; }

  /* Modal / lightbox (déplacée dans <body> par le script pour couvrir tout l'écran) */
  .lm-modal { position: fixed; inset: 0; z-index: 1000; display: none;
    align-items: center; justify-content: center; background: rgba(18,20,22,.92);
    padding: 4vh 1rem; overflow: hidden; }
  .lm-modal.open { display: flex; }
  .lm-modal-fig { margin: 0; max-width: 540px; width: auto; max-height: 86vh; display: flex;
    flex-direction: column; align-items: center; }
  .lm-modal-img { max-width: 100%; max-height: 80vh; width: auto; height: auto;
    object-fit: contain; border-radius: 6px; display: block; }
  .lm-modal-cap { color: #fff; margin-top: .8rem; font-size: .95rem; text-align: center; }
  .lm-close, .lm-prev, .lm-next { position: fixed; background: rgba(255,255,255,.14); color: #fff;
    border: none; cursor: pointer; border-radius: 999px; width: 48px; height: 48px; font-size: 1.9rem;
    line-height: 1; display: flex; align-items: center; justify-content: center; padding: 0; }
  .lm-close:hover, .lm-prev:hover, .lm-next:hover { background: rgba(255,255,255,.3); }
  .lm-close { top: 1.1rem; right: 1.1rem; font-size: 1.6rem; }
  .lm-prev { left: 1.1rem; top: 50%; transform: translateY(-50%); }
  .lm-next { right: 1.1rem; top: 50%; transform: translateY(-50%); }
  .lm-modal-dl { position: fixed; bottom: 1.3rem; left: 50%; transform: translateX(-50%);
    background: #2f6f72; color: #fff; padding: .7rem 1.2rem; border-radius: 10px;
    text-decoration: none; font-weight: 700; font-size: .95rem; white-space: nowrap; }

  @media (max-width: 520px) {
    .lm-grid { grid-template-columns: repeat(2, 1fr); gap: .6rem; }
    .lm-prev { left: .4rem; } .lm-next { right: .4rem; }
    .lm-close, .lm-prev, .lm-next { width: 42px; height: 42px; }
  }
</style>

<script is:inline>
  (function () {
    var root = document.getElementById('livret-modeles');
    if (!root || root.dataset.lmInit) return;
    root.dataset.lmInit = '1';
    var imgs = [];
    try { imgs = JSON.parse(root.dataset.imgs || '[]'); } catch (e) {}
    var modal = root.querySelector('.lm-modal');
    // Déplacer la modale dans <body> pour échapper au containing-block (transform de la colonne article)
    if (modal && modal.parentElement !== document.body) document.body.appendChild(modal);
    var modalImg = modal.querySelector('.lm-modal-img');
    var modalCap = modal.querySelector('.lm-modal-cap');
    var idx = 0;
    function show(i) {
      idx = (i + imgs.length) % imgs.length;
      modalImg.src = imgs[idx].src;
      modalImg.alt = 'Modèle de livret d\'accueil ' + imgs[idx].label;
      modalCap.textContent = imgs[idx].label + ' · ' + (idx + 1) + ' / ' + imgs.length;
    }
    function open(i) { show(i); modal.classList.add('open'); document.body.style.overflow = 'hidden'; }
    function close() { modal.classList.remove('open'); document.body.style.overflow = ''; }
    root.querySelectorAll('.lm-thumb').forEach(function (t, i) { t.addEventListener('click', function () { open(i); }); });
    modal.querySelector('.lm-next').addEventListener('click', function (e) { e.stopPropagation(); show(idx + 1); });
    modal.querySelector('.lm-prev').addEventListener('click', function (e) { e.stopPropagation(); show(idx - 1); });
    modal.querySelector('.lm-close').addEventListener('click', close);
    modal.addEventListener('click', function (e) { if (e.target === modal) close(); });
    document.addEventListener('keydown', function (e) {
      if (!modal.classList.contains('open')) return;
      if (e.key === 'Escape') close();
      else if (e.key === 'ArrowRight') show(idx + 1);
      else if (e.key === 'ArrowLeft') show(idx - 1);
    });

    // Hook téléchargement (pour brancher la pop-up Méthode 97% plus tard)
    var dl = document.getElementById('lm-download');
    if (dl) dl.addEventListener('click', function () {
      if (typeof window.onLivretDownload === 'function') { try { window.onLivretDownload(); } catch (e) {} }
    });
  })();
</script>

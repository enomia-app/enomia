---
interface Props { id?: string; source?: string; compact?: boolean; }
const { id = 'page-nl-form', source = 'NL', compact = false } = Astro.props;
---

{compact ? (
<div class="nl-compact">
  <div class="nl-badge">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="nl-badge-icon"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
    Guide PDF offert
  </div>
  <div class="nlc-title">La M&eacute;thode 97%&nbsp;&copy;</div>
  <p class="nlc-desc">Le guide en 10 &eacute;tapes pour atteindre <strong>12&ndash;18% de rendement net</strong> sur 9 biens &mdash; gratuit, sans jargon.</p>
  <form id={id} class="nl-form">
    <input type="text" placeholder="Pr&eacute;nom" required class="nl-input" />
    <input type="email" placeholder="votre@email.com" required class="nl-input" />
    <button type="submit" class="nl-btn">Recevoir le guide &rarr;</button>
  </form>
  <p class="nlc-weekly">1 email/semaine &mdash; Anecdotes &amp; chiffres r&eacute;els, pas de spam</p>
  <p class="nl-note">D&eacute;sinscription en 1 clic</p>
</div>
) : (
<div class="nl-block">
  <div class="nl-cols">
    <div class="nl-left">
      <div class="nl-badge">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="nl-badge-icon"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
        Guide PDF offert + Newsletter
      </div>
      <div class="nl-title">Recevez La M&eacute;thode 97%&nbsp;&copy; compl&egrave;te, gratuitement</div>
      <p class="nl-desc">Le guide PDF en 10 &eacute;tapes que j'ai utilis&eacute; pour atteindre <strong class="nl-highlight">12&ndash;18% de rendement net</strong> sur 9 biens &mdash; expliqu&eacute; de A &agrave; Z, sans jargon.</p>
      <ul class="nl-checks">
        <li>
          <svg viewBox="0 0 20 20" fill="none" class="nl-check-icon"><circle cx="10" cy="10" r="10" fill="#3fbd71" opacity="0.15"/><path d="M6 10.5l2.5 2.5L14 8" stroke="#3fbd71" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          Guide PDF La M&eacute;thode 97%&nbsp;&copy; &mdash; 40+ pages, de A &agrave; Z
        </li>
        <li>
          <svg viewBox="0 0 20 20" fill="none" class="nl-check-icon"><circle cx="10" cy="10" r="10" fill="#3fbd71" opacity="0.15"/><path d="M6 10.5l2.5 2.5L14 8" stroke="#3fbd71" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          Acc&egrave;s au simulateur de rentabilit&eacute; Enomia
        </li>
        <li>
          <svg viewBox="0 0 20 20" fill="none" class="nl-check-icon"><circle cx="10" cy="10" r="10" fill="#3fbd71" opacity="0.15"/><path d="M6 10.5l2.5 2.5L14 8" stroke="#3fbd71" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          1 email/semaine &mdash; Anecdotes &amp; chiffres r&eacute;els, pas de spam
        </li>
      </ul>
    </div>
    <div class="nl-right">
      <form id={id} class="nl-form">
        <input type="text" placeholder="Pr&eacute;nom" required class="nl-input nl-input-name" />
        <input type="email" placeholder="votre@email.com" required class="nl-input nl-input-email" />
        <button type="submit" class="nl-btn">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="nl-btn-icon"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
          Recevoir La M&eacute;thode 97%&nbsp;&copy;
        </button>
      </form>
      <p class="nl-note">D&eacute;sinscription en 1 clic &middot; Email jamais partag&eacute;</p>
    </div>
  </div>
</div>
)}

<script define:vars={{ id, source }}>
(function(){
  var f=document.getElementById(id);if(!f)return;
  f.addEventListener('submit',async function(e){
    e.preventDefault();
    var ins=f.querySelectorAll('input'),fn=ins[0].value.trim(),em=ins[1].value.trim();
    if(!fn||!em)return;
    var btn=f.querySelector('button'),orig=btn.innerHTML;
    btn.disabled=true;btn.textContent='Envoi\u2026';
    try{
      var r=await fetch('/api/subscribe',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({email:em,firstName:fn,source:source})});
      if(r.ok){btn.textContent='\u2713 Envoy\u00e9 !';btn.style.background='#2b2d2b';ins.forEach(function(i){i.disabled=true;i.style.opacity='0.5'});}
      else{btn.textContent='Erreur';btn.disabled=false;setTimeout(function(){btn.innerHTML=orig},2000);}
    }catch(_){btn.textContent='Erreur';btn.disabled=false;setTimeout(function(){btn.innerHTML=orig},2000);}
  });
})();
</script>

<style>
  .nl-block {
    background: linear-gradient(135deg, #2b2d2b 0%, #3a3c3a 100%);
    border-radius: 14px;
    padding: 36px 40px;
    color: #e8e4dc;
    margin: 48px 0 40px;
  }
  .nl-cols {
    display: flex;
    gap: 36px;
    align-items: center;
  }
  .nl-left {
    flex: 1;
    min-width: 0;
  }
  .nl-right {
    flex: 0 0 320px;
  }
  .nl-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: rgba(63, 189, 113, 0.15);
    color: #3fbd71;
    font-size: 9.5px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 5px 11px;
    border-radius: 20px;
    border: 1px solid rgba(63, 189, 113, 0.3);
    margin-bottom: 14px;
    font-family: 'Inter', sans-serif;
  }
  .nl-badge-icon {
    width: 11px;
    height: 11px;
  }
  .nl-title {
    font-family: 'Newsreader', Georgia, serif;
    font-size: 23px;
    font-weight: 700;
    color: #fff;
    line-height: 1.22;
    margin-bottom: 8px;
  }
  .nl-desc {
    font-size: 13px;
    color: #6e6b65;
    line-height: 1.6;
    margin-bottom: 14px;
    font-family: 'Inter', sans-serif;
  }
  .nl-highlight {
    color: #e8e4dc;
  }
  .nl-checks {
    list-style: none;
    padding: 0;
    margin: 0 0 18px;
    display: flex;
    flex-direction: column;
    gap: 7px;
  }
  .nl-checks li {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    color: #e8e4dc;
    font-family: 'Inter', sans-serif;
  }
  .nl-check-icon {
    width: 17px;
    height: 17px;
    flex-shrink: 0;
  }
  .nl-form {
    display: flex;
    flex-direction: column;
    gap: 8px;
    width: 100%;
  }
  .nl-input {
    padding: 12px 14px;
    background: rgba(255, 255, 255, 0.07);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 8px;
    color: #e8e4dc;
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    outline: none;
    width: 100%;
    box-sizing: border-box;
  }
  .nl-input-email {
    border-radius: 8px;
  }
  .nl-btn {
    background: #3fbd71;
    color: #fff;
    border: none;
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    font-weight: 700;
    padding: 12px 20px;
    border-radius: 8px;
    cursor: pointer;
    white-space: nowrap;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 5px;
    width: 100%;
  }
  .nl-btn-icon {
    width: 13px;
    height: 13px;
  }
  .nl-note {
    font-size: 10.5px;
    color: rgba(255, 255, 255, 0.4);
    margin-top: 10px;
    text-align: center;
    font-family: 'Inter', sans-serif;
  }
  /* ─── Compact variant (sidebar) ─── */
  .nl-compact {
    background: linear-gradient(135deg, #2b2d2b 0%, #3a3c3a 100%);
    border-radius: 12px;
    padding: 22px 20px;
    color: #e8e4dc;
  }
  .nl-compact .nl-badge {
    margin-bottom: 12px;
  }
  .nlc-title {
    font-family: 'Newsreader', Georgia, serif;
    font-size: 18px;
    font-weight: 700;
    color: #fff;
    line-height: 1.2;
    margin-bottom: 6px;
  }
  .nlc-desc {
    font-size: 12px;
    color: #8a8985;
    line-height: 1.55;
    margin-bottom: 14px;
    font-family: 'Inter', sans-serif;
  }
  .nlc-desc strong {
    color: #e8e4dc;
    font-weight: 600;
  }
  .nl-compact .nl-form {
    gap: 7px;
  }
  .nl-compact .nl-input {
    padding: 10px 12px;
    font-size: 12px;
  }
  .nl-compact .nl-btn {
    padding: 10px 16px;
    font-size: 12px;
  }
  .nlc-weekly {
    font-size: 11px;
    color: #8a8985;
    margin: 10px 0 0;
    font-family: 'Inter', sans-serif;
    text-align: center;
    line-height: 1.4;
  }
  .nl-compact .nl-note {
    font-size: 9.5px;
    margin-top: 4px;
  }

  @media (max-width: 700px) {
    .nl-block {
      padding: 28px 24px;
    }
    .nl-cols {
      flex-direction: column;
      gap: 20px;
    }
    .nl-right {
      flex: none;
      width: 100%;
    }
  }
</style>

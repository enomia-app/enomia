---
// Explorateur rentabilité par ville : searchbox + filtres (affichage, régions) + classement.
// Data 100% réelle (DVF + AirDNA), depuis src/data/rentabilite-villes.json.
// Style de tableau aligné sur les articles de blog (header foncé #2b2d2b), accents verts (charte).
import data from '../data/rentabilite-villes.json';

const villes = data.villes;
const regions = data.regions.filter((r) => r.classables > 0);
const classables = villes.filter((v) => v.classable).sort((a, b) => b.ratio - a.ratio);

const payload = villes.map((v) => ({
  s: v.slug, v: v.ville, r: v.region, rs: v.region_slug,
  ra: v.ratio, o: v.occupation, n: v.prix_nuit, m: v.prix_bien,
  a: v.annonces, c: v.classable, p: v.published, src: v.prix_source, t: v.tier,
}));
---

<section class="rex">
  <div class="rex-head">
    <h2>Classement rentabilité Airbnb par ville</h2>
    <p class="rex-sub">
      Classement de <strong>{classables.length} villes françaises</strong> par <strong>rendement brut</strong> (revenu annuel ÷ prix d'achat).
      Ce sont les villes ayant <strong>au moins 100 annonces Airbnb actives</strong> (seuil de couverture AirDNA) et un prix de marché connu.
      Occupation et prix par nuit : <strong>AirDNA</strong>. Prix du bien : <strong>DVF</strong> (DGFiP).
    </p>
  </div>

  <div class="rex-controls">
    <input type="search" id="rex-search" class="rex-search" placeholder="Cherchez votre ville (ex : Bordeaux, Annecy…)" autocomplete="off" />

    <div class="rex-fgroup">
      <span class="rex-flabel">Affichage</span>
      <div class="rex-chips" id="rex-limit">
        <button class="rex-chip active" data-limit="0">Tout</button>
        <button class="rex-chip" data-limit="100">Top 100</button>
        <button class="rex-chip" data-limit="10">Top 10</button>
      </div>
    </div>

    <div class="rex-fgroup">
      <span class="rex-flabel">Région</span>
      <div class="rex-chips" id="rex-regions">
        <button class="rex-chip active" data-region="">Toutes</button>
        {regions.map((r) => (
          <button class="rex-chip" data-region={r.slug}>{r.region} <span>{r.classables}</span></button>
        ))}
      </div>
    </div>

    <p class="rex-fiab-explain">
      Toutes les villes ont <strong>≥ 100 annonces Airbnb</strong> (marché fiable partout). La pastille
      <span class="rex-dot rex-dot-forte"></span> reflète la taille de l'échantillon de <strong>ventes DVF</strong> servant au prix :
      <span class="rex-dot rex-dot-forte"></span> forte (≥ 50 ventes) ·
      <span class="rex-dot rex-dot-bonne"></span> bonne (≥ 30) ·
      <span class="rex-dot rex-dot-faible"></span> faible (10-30).
    </p>
  </div>

  <div class="rex-count" id="rex-count"></div>

  <div class="rex-scroll">
    <table class="rex-table">
      <thead>
        <tr>
          <th>#</th>
          <th>Ville</th>
          <th>Rendement brut</th>
          <th>Occupation</th>
          <th>Prix/nuit<sup>*</sup></th>
          <th class="rex-th-fiab">Fiab.</th>
          <th>Prix médian (bien)</th>
          <th>Annonces</th>
          <th>Région</th>
        </tr>
      </thead>
      <tbody id="rex-body">
        {classables.map((v, i) => (
          <tr>
            <td class="rex-rank">{i + 1}</td>
            <td>{v.published ? <a href={`/rentabilite-airbnb/${v.region_slug}/${v.slug}`}>{v.ville}</a> : <span class="rex-soon" title="Fiche détaillée à venir">{v.ville}</span>}</td>
            <td class="rex-ratio"><strong>{v.ratio}%</strong></td>
            <td>{v.occupation}%</td>
            <td>{v.prix_nuit}&nbsp;€</td>
            <td class="rex-td-fiab"><span class={`rex-dot rex-dot-${v.tier}`}></span></td>
            <td>{v.prix_bien?.toLocaleString('fr-FR')}&nbsp;€{v.prix_source === 'Efficity' ? <sup>†</sup> : ''}</td>
            <td>{v.annonces?.toLocaleString('fr-FR')}</td>
            <td class="rex-reg">{v.region}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <p class="rex-notes">
    <sup>*</sup> Prix moyen par nuit réservée (ADR), source AirDNA.<br>
    Prix du bien : médiane des biens vendus dans la commune (<strong>DVF</strong>, DGFiP), sauf en Alsace-Moselle (<sup>†</sup>) où DVF
    est indisponible (livre foncier) : estimation <strong>Efficity</strong>.<br>
    Ratio = revenu annuel (prix/nuit × occupation × 365) ÷ (prix médian du bien + 700&nbsp;€/m² de travaux). On utilise le prix réel d'un bien type, pas un 40&nbsp;m² fixe.
  </p>

  <script type="application/json" id="rex-data" set:html={JSON.stringify(payload)}></script>
  <script is:inline>
    (function () {
      const all = JSON.parse(document.getElementById('rex-data').textContent);
      const body = document.getElementById('rex-body');
      const search = document.getElementById('rex-search');
      const count = document.getElementById('rex-count');
      const regionsEl = document.getElementById('rex-regions');
      const limitEl = document.getElementById('rex-limit');
      let region = '', limit = 0;
      const fr = (n) => n == null ? '–' : n.toLocaleString('fr-FR');

      const ranked = all.filter((v) => v.c).sort((a, b) => (b.ra ?? -1) - (a.ra ?? -1));
      const rankMap = {};
      ranked.forEach((v, i) => { rankMap[v.s] = i + 1; });

      function render() {
        const q = search.value.trim().toLowerCase();
        let rows;
        if (q) {
          rows = all.filter((v) => v.v.toLowerCase().includes(q) && (!region || v.rs === region));
        } else {
          rows = all.filter((v) => v.c && (!region || v.rs === region));
        }
        rows.sort((a, b) => (b.ra ?? -1) - (a.ra ?? -1));
        const shown = rows.slice(0, limit === 0 ? rows.length : limit);
        body.innerHTML = shown.map((v) => `
          <tr>
            <td class="rex-rank">${rankMap[v.s] || '–'}</td>
            <td>${v.p ? `<a href="/rentabilite-airbnb/${v.rs}/${v.s}">${v.v}</a>` : `<span class="rex-soon" title="Fiche détaillée à venir">${v.v}</span>`}</td>
            <td class="rex-ratio">${v.ra != null ? '<strong>' + v.ra + '%</strong>' : '<span class="rex-na">n/a</span>'}</td>
            <td>${v.o != null ? v.o + '%' : '–'}</td>
            <td>${v.n != null ? fr(v.n) + ' €' : '–'}</td>
            <td class="rex-td-fiab"><span class="rex-dot rex-dot-${v.t}"></span></td>
            <td>${v.m != null ? fr(v.m) + ' €' + (v.src === 'Efficity' ? '<sup>†</sup>' : '') : '<span class="rex-na">n/a</span>'}</td>
            <td>${fr(v.a)}</td>
            <td class="rex-reg">${v.r}</td>
          </tr>`).join('');
        if (q && rows.length === 0) {
          count.textContent = `Aucune ville « ${search.value.trim()} » dans notre base (on suit ${all.length} villes au marché Airbnb significatif).`;
        } else if (q) {
          count.textContent = `${rows.length} ville(s) trouvée(s)` + (rows[0] && rankMap[rows[0].s] ? ` · ${rows[0].v} : ${rankMap[rows[0].s]}ᵉ du classement` : '');
        } else {
          count.textContent = `${shown.length} villes affichées sur ${rows.length}`;
        }
      }

      search.addEventListener('input', render);
      regionsEl.addEventListener('click', (e) => {
        const btn = e.target.closest('.rex-chip'); if (!btn) return;
        region = btn.dataset.region;
        regionsEl.querySelectorAll('.rex-chip').forEach((c) => c.classList.toggle('active', c === btn));
        render();
      });
      limitEl.addEventListener('click', (e) => {
        const btn = e.target.closest('.rex-chip'); if (!btn) return;
        limit = parseInt(btn.dataset.limit, 10);
        limitEl.querySelectorAll('.rex-chip').forEach((c) => c.classList.toggle('active', c === btn));
        render();
      });
      render();
    })();
  </script>
</section>

<style is:global>
  .rex { margin: 40px 0 28px; }
  .rex-head h2 { margin-top: 0; margin-bottom: 6px; }
  .rex-sub { color: #555; font-size: 15px; line-height: 1.5; margin: 0; }
  .rex-controls { margin: 28px 0 14px; }
  .rex-search { width: 100%; box-sizing: border-box; padding: 13px 16px; font-size: 16px; border: 1px solid #d8d2c6; border-radius: 10px; background: #fff; }
  .rex-search:focus { outline: none; border-color: #3fbd71; box-shadow: 0 0 0 3px rgba(63,189,113,.18); }
  .rex-fgroup { margin-top: 16px; }
  .rex-flabel { display: block; font-size: 11px; text-transform: uppercase; letter-spacing: .5px; color: #999; margin-bottom: 8px; }
  .rex-chips { display: flex; flex-wrap: wrap; gap: 8px; }
  .rex-chip { padding: 6px 12px; border: 1px solid #e2ddd2; border-radius: 20px; background: #faf8f3; font-size: 13px; cursor: pointer; transition: all .15s; color: inherit; font-family: inherit; }
  .rex-chip:hover { border-color: #3fbd71; }
  .rex-chip.active { background: #3fbd71; color: #fff; border-color: #3fbd71; }
  .rex-chip span { opacity: .6; font-size: 11px; }
  .rex-chip.active span { opacity: .85; }
  .rex-fiab-explain { font-size: 12px; color: #777; margin: 14px 0 0; line-height: 1.7; }
  .rex-count { font-size: 13px; color: #888; margin: 14px 2px 8px; font-family: var(--font-mono, monospace); }
  /* Table : même style que les articles de blog (header foncé) */
  .rex-scroll { max-height: 72vh; overflow: auto; -webkit-overflow-scrolling: touch; border: 1px solid #e8e4dc; border-radius: 8px; }
  .rex-table { width: 100%; min-width: 720px; border-collapse: separate; border-spacing: 0; margin: 0; font-size: 14px; line-height: 1.5; }
  .rex-table tbody td { border-bottom: none; }
  .rex-table thead th { position: sticky; top: 0; z-index: 3; background: #2b2d2b; color: #fff; font-size: 13px; font-weight: 600; padding: 11px 10px; text-align: left; white-space: nowrap; }
  .rex-table tbody td { padding: 11px 10px; color: #555; border-top: 1px solid #e8e4dc; vertical-align: middle; white-space: nowrap; }
  .rex-table tbody tr:hover { background: rgba(0,0,0,0.02); }
  .rex-table a { color: #1f7a3d; text-decoration: none; font-weight: 600; }
  .rex-table a:hover { text-decoration: underline; }
  .rex-rank { color: #aaa; font-variant-numeric: tabular-nums; }
  .rex-ratio strong { color: #1f7a3d; }
  .rex-reg { color: #888; font-size: 13px; }
  .rex-soon { color: #444; font-weight: 600; }
  .rex-th-fiab, .rex-td-fiab { text-align: center; padding-left: 8px; padding-right: 8px; }
  .rex-na { color: #bbb; font-size: 12px; font-style: italic; }
  .rex-dot { display: inline-block; width: 8px; height: 8px; border-radius: 50%; vertical-align: middle; }
  .rex-dot-forte { background: #1f7a3d; }
  .rex-dot-bonne { background: #3fbd71; }
  .rex-dot-faible { background: #c08a2d; }
  .rex-notes { font-size: 12px; color: #999; line-height: 1.6; margin-top: 12px; }
  .rex-notes .rex-dot { margin: 0 2px; }
  /* Le tableau reste aligné sur la colonne de texte (même marge que le reste de l'article).
     Le scroll horizontal éventuel est géré dans la boîte .rex-scroll (overflow auto). */
  @media (max-width: 640px) {
    .rex-table { min-width: 560px; }
    .rex-table thead th, .rex-table tbody td { padding: 7px 6px; font-size: 12px; }
    .rex-th-fiab, .rex-td-fiab { padding-left: 4px; padding-right: 4px; }
    /* colonnes # + Ville figées à gauche pour ne pas se perdre en scrollant horizontalement */
    .rex-table th:nth-child(1), .rex-table td:nth-child(1) { position: sticky; left: 0; z-index: 2; box-sizing: border-box; width: 30px; min-width: 30px; padding-left: 7px; padding-right: 3px; }
    .rex-table th:nth-child(2), .rex-table td:nth-child(2) { position: sticky; left: 30px; z-index: 2; box-shadow: 3px 0 5px rgba(0,0,0,0.07); }
    .rex-table tbody td:nth-child(1), .rex-table tbody td:nth-child(2) { background: #fff; }
    /* coin haut-gauche : sticky top ET left → z-index supérieur */
    .rex-table thead th:nth-child(1), .rex-table thead th:nth-child(2) { background: #2b2d2b; z-index: 4; }
  }
</style>

    </div>
    <div class="comp-col">
      <h4>Division (60-90&nbsp;m&sup2; en 2 lots)</h4>
      <ul>
        <li>2× les chiffres T2 ci-dessus</li>
        <li>CA annuel combiné&nbsp;: {Math.round(city.t2.caAnnualMin * 1.9).toLocaleString('fr-FR')}-{Math.round(city.t2.caAnnualMax * 1.9).toLocaleString('fr-FR')}&nbsp;€</li>
      </ul>
    </div>
  </div>


---
/**
 * Composant principal pour /rentabilite-airbnb/[ville] (live + preview).
 *
 * Skill SEO + retours Marc intégrés (29 avril 2026) :
 * - Pitch « La Méthode 97%© » : court, accrocheur, CTA vers article blog
 * - Calcul cashflow réaliste : priceM2 × 35m² + frais notaire 7,5% + travaux 700€/m² + ameublement 10K + frais bancaires 1% + 10% apport
 * - Rendement net calculé dynamiquement (pas lu BDD)
 * - Module fiscalité reformulé : régime réel non impacté Loi Le Meur, plus-value à la revente
 * - Module conciergerie : 80% si bien sous-perf / 50% si perf + investir près de chez vous
 * - Module réglementation : compensation L631-7 détaillée + alternative local commercial + commercialité 700€/m²
 * - Encadré « Ce qu'il faut savoir » (pas « ignorent »)
 * - Pas de Vrbo (Marc utilise pas)
 * - Avocat copro 500€ après prêt, condition suspensive, IA pré-lecture
 *
 * Schemas : AuthorSchema (Marc) + FAQPage
 */
import ContratLandingStyles from './ContratLandingStyles.astro';
import NewsletterBlock from './NewsletterBlock.astro';
import type { CityRentabilite } from '../data/cities-rentabilite';
import { getConciergerieLinkForVille } from '../utils/getConciergeriePathForVille';

interface Props {
  city: CityRentabilite;
  neighbors: CityRentabilite[];
  previewMode?: boolean;
}

const { city, neighbors, previewMode = false } = Astro.props;

const conciergerieLink = getConciergerieLinkForVille(city.slug, city.name);

// ─── Constantes calcul cashflow ─────────────────────────────────────
const SURFACE_T2 = 35;
const FRAIS_NOTAIRE_PCT = 0.075;
const AMEUBLEMENT_T2 = 10000;
const FRAIS_BANCAIRES_PCT = 0.01;
const APPORT_PCT = 0.10;
const TRAVAUX_M2 = 700;
const TAUX_CREDIT = 0.035;
const DUREE_CREDIT_ANS = 20;

const priceM2Mid = Math.round((city.priceM2.min + city.priceM2.max) / 2);
const prixAchat = priceM2Mid * SURFACE_T2;
const fraisNotaire = Math.round(prixAchat * FRAIS_NOTAIRE_PCT);
const travauxT2 = TRAVAUX_M2 * SURFACE_T2;
const coutAvantBancaires = prixAchat + fraisNotaire + travauxT2 + AMEUBLEMENT_T2;
const apport = Math.round(coutAvantBancaires * APPORT_PCT);
const montantEmprunte = coutAvantBancaires - apport;
const fraisBancaires = Math.round(montantEmprunte * FRAIS_BANCAIRES_PCT);
const coutTotalProjet = coutAvantBancaires + fraisBancaires;

// Mensualité crédit (formule annuité constante)
const mensuelTaux = TAUX_CREDIT / 12;
const nbMois = DUREE_CREDIT_ANS * 12;
const mensualiteCredit = Math.round(
  (montantEmprunte * mensuelTaux) / (1 - Math.pow(1 + mensuelTaux, -nbMois))
);

// ─── 3 scénarios distincts (conciergerie / médian / Méthode 97%©) ──────
const caMid = Math.round((city.t2.caAnnualMin + city.t2.caAnnualMax) / 2);
const occupancyMid = Math.round((city.t2.occupancyMin + city.t2.occupancyMax) / 2);
const nightlyMid = Math.round((city.t2.nightlyMin + city.t2.nightlyMax) / 2);
const mensualiteAnnuelle = mensualiteCredit * 12;

// Scénario 1 — Avec conciergerie classique (CA médian, charges 38% + 28% conciergerie = 66%)
const caConciergerie = caMid;
const chargesConciergerie = Math.round(caConciergerie * 0.66);
const cashFlowAnnuelConcierge = caConciergerie - chargesConciergerie - mensualiteAnnuelle;
const cashFlowMensuelConcierge = Math.round(cashFlowAnnuelConcierge / 12);
const rendementConcierge = ((cashFlowAnnuelConcierge / coutTotalProjet) * 100).toFixed(1);

// Scénario 2 — Médian (gestion en direct mais sans optim, CA médian, charges 38%)
const caMedian = caMid;
const chargesMedian = Math.round(caMedian * 0.38);
const cashFlowAnnuelMedian = caMedian - chargesMedian - mensualiteAnnuelle;
const cashFlowMensuelMedian = Math.round(cashFlowAnnuelMedian / 12);
const rendementMedian = ((cashFlowAnnuelMedian / coutTotalProjet) * 100).toFixed(1);

// Scénario 3 — Méthode 97%© (CA optimisé, charges 28% car gestion directe + pricing dynamique)
const caOptimise = city.t2.caAnnualMax;
const chargesOptimise = Math.round(caOptimise * 0.28);
const cashFlowAnnuelOptimise = caOptimise - chargesOptimise - mensualiteAnnuelle;
const cashFlowMensuelOptimise = Math.round(cashFlowAnnuelOptimise / 12);
const rendementOptimise = ((cashFlowAnnuelOptimise / coutTotalProjet) * 100).toFixed(1);

// Coût conciergerie pour le module conciergerie plus bas
const coutConciergerie = Math.round(caMid * 0.28);

// Pour le hero : afficher le rendement médian (référence)
const rendementNetCalcule = rendementMedian;

// ─── Labels ─────────────────────────────────────────────────────────
const reliabilityLabel = {
  low: { icon: '🟡', text: 'Fiabilité indicative : peu d\'annonces de référence sur cette ville. Ordres de grandeur basés sur la catégorie de marché.' },
  medium: { icon: '🟢', text: 'Fiabilité moyenne : données calibrées sur un échantillon représentatif d\'annonces actives.' },
  high: { icon: '⭐', text: 'Fiabilité élevée : marché mature avec données abondantes et calibration croisée.' },
}[city.reliability];

const categoryLabel = {
  metropole: 'Métropole',
  'tourisme-balneaire': 'Tourisme balnéaire',
  'station-ski': 'Station de ski',
  patrimoine: 'Ville patrimoniale',
  peripherie: 'Périphérie',
  'tourisme-affaires': 'Tourisme & affaires',
}[city.category];

const regulationStatusLabel = {
  libre: { icon: '🟢', text: 'Marché libre' },
  restreint: { icon: '🟡', text: 'Marché restreint' },
  tendu: { icon: '🔴', text: 'Marché tendu' },
  'interdit-residence-principale': { icon: '⛔', text: 'Résidence principale interdite' },
}[city.regulation.status];

const isRegulationTendu = city.regulation.status === 'tendu' || city.regulation.status === 'restreint' || city.regulation.status === 'interdit-residence-principale';

const previewStatusLabel = previewMode
  ? city.status === 'en-ligne'
    ? '✅ Publiée'
    : `⏳ Publication prévue le ${city.publishAt}`
  : '';

// ─── FAQ Schema ─────────────────────────────────────────────────────
const ldFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: `Combien rapporte un Airbnb à ${city.name} en 2026 ?`,
      acceptedAnswer: {
        '@type': 'Answer',
        text: `Un T2 bien équipé à ${city.name} génère ${city.t2.caAnnualMin.toLocaleString('fr-FR')} à ${city.t2.caAnnualMax.toLocaleString('fr-FR')} € de chiffre d'affaires annuel en 2026, avec un tarif moyen de ${city.t2.nightlyMin} à ${city.t2.nightlyMax} €/nuit et un taux d'occupation de ${city.t2.occupancyMin} à ${city.t2.occupancyMax}%.`,
      },
    },
    {
      '@type': 'Question',
      name: `Quelle est la rentabilité d'un Airbnb à ${city.name} ?`,
      acceptedAnswer: {
        '@type': 'Answer',
        text: `Sur un T2 standard à ${city.name} avec 10% d'apport, la rentabilité nette se situe entre ${rendementConserv}% (scénario conservateur, gestion classique) et ${rendementOptimise}% (scénario optimisé avec La Méthode 97%© en gestion directe). L'écart vient principalement du coût de gestion : conciergerie classique = jusqu'à 80% du cash flow net mangé.`,
      },
    },
    {
      '@type': 'Question',
      name: `Quel taux d'occupation viser pour un Airbnb à ${city.name} ?`,
      acceptedAnswer: {
        '@type': 'Answer',
        text: `Le taux d'occupation moyen visé à ${city.name} se situe entre ${city.t2.occupancyMin}% et ${city.t2.occupancyMax}% selon la qualité du produit. La Méthode 97%© atteint 97% sur les 9 biens de Marc Chenut grâce au minimum 1 nuit (au lieu de 2), à la double plateforme Airbnb + Booking et au pricing dynamique.`,
      },
    },
    {
      '@type': 'Question',
      name: `Quelles sont les règles Loi Le Meur à ${city.name} ?`,
      acceptedAnswer: {
        '@type': 'Answer',
        text: city.regulation.detail,
      },
    },
    {
      '@type': 'Question',
      name: `Faut-il une conciergerie pour son Airbnb à ${city.name} ?`,
      acceptedAnswer: {
        '@type': 'Answer',
        text: `Une conciergerie classique facture 20% du CA mais mange en réalité 50 à 80% du cash flow net selon la performance du bien. Sur ${city.name} (CA médian ${caMid.toLocaleString('fr-FR')} €), c'est ${coutConciergerie.toLocaleString('fr-FR')} €/an de cash flow perdu. La gestion en direct avec automatisation est nettement plus rentable, surtout si vous habitez à moins de 30 minutes du bien.`,
      },
    },
  ],
};
---
{previewMode && (
  <div style="background:#ffe9b3; border-bottom:2px solid #d4a040; padding:14px 20px; text-align:center; font-size:14px; position:sticky; top:0; z-index:100;">
    <strong>📝 MODE PREVIEW</strong> · {city.name} · Status: {previewStatusLabel} ·
    <a href={`/rentabilite-airbnb/${city.slug}`} style="color:#5a3a00; text-decoration:underline;">Voir la version live</a> ·
    <a href="/preview/rentabilite-airbnb" style="color:#5a3a00; text-decoration:underline;">Liste preview</a>
  </div>
)}

<ContratLandingStyles />

<div class="landing-hero">
  <div class="landing-tag">Rentabilité Airbnb à {city.name}</div>
  <h1 class="landing-h1">Rentabilité Airbnb à {city.name}&nbsp;:<br><em>revenus, estimation et cashflow 2026</em></h1>
  <p class="landing-sub">{categoryLabel} · {city.region} · Données 2026 calibrées par catégorie de marché</p>
  <div class="landing-stats">
    <div class="landing-stat"><div class="landing-stat-val">{caMid.toLocaleString('fr-FR')}&euro;</div><div class="landing-stat-lbl">CA T2 moyen / an</div></div>
    <div class="landing-stat"><div class="landing-stat-val">{occupancyMid}%</div><div class="landing-stat-lbl">occupation visée</div></div>
    <div class="landing-stat"><div class="landing-stat-val">{rendementNetCalcule}%</div><div class="landing-stat-lbl">rendement net calculé</div></div>
  </div>
  <a href={`/simulateur-lcd?ville=${city.slug}&type=t2&surface=35&apport=10`} class="landing-cta">Estimer ma rentabilité &rarr;</a>
  <p class="landing-note">Calculateur préremplit avec les données de {city.name}</p>
</div>

<div class="seo-wrap"><div class="seo-body">

  <p style="background:#faf8f3; padding:12px 16px; border-left:3px solid #c4ad7a; font-size:14px; margin:24px 0;">
    {reliabilityLabel.icon} <strong>{reliabilityLabel.icon === '⭐' ? 'Fiabilité élevée' : reliabilityLabel.icon === '🟢' ? 'Fiabilité moyenne' : 'Fiabilité indicative'}</strong> : {reliabilityLabel.text}
  </p>

  <!-- TL;DR / réponse directe -->
  <h2>Rentabilité Airbnb à {city.name} : la réponse en 30 secondes</h2>
  <p>Pour un T2 de 35&nbsp;m&sup2; bien équipé à {city.name}, géré avec un pricing dynamique en 2026&nbsp;: <strong>{city.t2.caAnnualMin.toLocaleString('fr-FR')} à {city.t2.caAnnualMax.toLocaleString('fr-FR')}&nbsp;€</strong> de chiffre d'affaires annuel, <strong>{city.t2.occupancyMin} à {city.t2.occupancyMax}%</strong> d'occupation, <strong>{rendementConserv} à {rendementOptimise}%</strong> de rendement net après charges et financement (10% d'apport).</p>
  <p>{city.context}</p>

  <!-- Encadré peur conditionnel -->
  {isRegulationTendu && (
    <div style="background:#fff4f0; border-left:4px solid #c14; padding:18px 22px; margin:28px 0; border-radius:6px;">
      <h3 style="margin-top:0; color:#c14;">🚨 Ce qu'il faut savoir avant d'investir à {city.name}</h3>
      <p style="margin-bottom:8px;">{city.name} est en zone <strong>{regulationStatusLabel.text.toLowerCase()}</strong>. La Loi Le Meur (novembre 2024) a déjà durci le cadre, et certaines communes peuvent renforcer encore les règles localement.</p>
      <p style="margin:0;">Trois sujets à anticiper avant l'achat&nbsp;: numéro d'enregistrement obligatoire en mairie (5&nbsp;000 à 50&nbsp;000&nbsp;€ d'amende sans), seuil 23&nbsp;000&nbsp;€/an de revenus LCD qui bascule en LMP avec affiliation URSSAF (1&nbsp;348&nbsp;€/an minimum), et règles locales de compensation. <a href="/blog/loi-le-meur-airbnb" style="color:#c14;"><strong>Lire le guide Loi Le Meur complet à {city.name} →</strong></a></p>
    </div>
  )}

  <!-- Estimation détaillée -->
  <h2>Estimation détaillée des revenus d'un Airbnb à {city.name}</h2>
  <p>Voici les ordres de grandeur de chiffre d'affaires et de rentabilité pour un T2 standard à {city.name} en 2026.</p>
  <div class="comparison">
    <div class="comp-col">
      <h4>Scénario conservateur (gestion classique)</h4>
      <ul>
        <li>Tarif moyen&nbsp;: <strong>{city.t2.nightlyMin}&nbsp;€/nuit</strong></li>
        <li>Occupation&nbsp;: <strong>{city.t2.occupancyMin}%</strong></li>
        <li>CA brut annuel&nbsp;: <strong>{city.t2.caAnnualMin.toLocaleString('fr-FR')}&nbsp;€</strong></li>
        <li>Charges 42% (avec conciergerie)</li>
        <li>Rendement net&nbsp;: <strong>{rendementConserv}%</strong></li>
      </ul>
    </div>
    <div class="comp-col">
      <h4>Scénario optimisé (Méthode 97%©)</h4>
      <ul>
        <li>Tarif moyen&nbsp;: <strong>{city.t2.nightlyMax}&nbsp;€/nuit</strong></li>
        <li>Occupation&nbsp;: <strong>{city.t2.occupancyMax}%</strong></li>
        <li>CA brut annuel&nbsp;: <strong>{city.t2.caAnnualMax.toLocaleString('fr-FR')}&nbsp;€</strong></li>
        <li>Charges 35% (gestion directe)</li>
        <li>Rendement net&nbsp;: <strong>{rendementOptimise}%</strong></li>
      </ul>
    </div>
  </div>
  <p>L'écart entre les deux scénarios représente <strong>{Math.round(((parseFloat(rendementOptimise) - parseFloat(rendementConserv)) / parseFloat(rendementConserv)) * 100)}% de rendement net en plus</strong> sur le même bien à {city.name}. La différence se joue sur trois facteurs principaux&nbsp;: la qualité de l'annonce (photos, équipement), le pricing dynamique, et le mode de gestion (en direct vs conciergerie).</p>

  <!-- Investissement total -->
  <h2>Combien rapporte vraiment un Airbnb à {city.name}&nbsp;? Le calcul détaillé</h2>
  <p>Voici un calcul détaillé pour un T2 de 35&nbsp;m&sup2; à {city.name} en 2026, avec 10% d'apport et un crédit sur 20 ans à 3,5%. Les ordres de grandeur de prix au m&sup2; sont issus du marché immobilier local.</p>
  <div class="comparison">
    <div class="comp-col">
      <h4>Investissement total</h4>
      <ul>
        <li>Prix d'achat T2 35&nbsp;m&sup2; (~{priceM2Mid.toLocaleString('fr-FR')}&nbsp;€/m&sup2;) : <strong>{prixAchat.toLocaleString('fr-FR')}&nbsp;€</strong></li>
        <li>Frais de notaire (7,5%) : {fraisNotaire.toLocaleString('fr-FR')}&nbsp;€</li>
        <li>Travaux (700&nbsp;€/m&sup2;) : {travauxT2.toLocaleString('fr-FR')}&nbsp;€</li>
        <li>Ameublement T2 : {AMEUBLEMENT_T2.toLocaleString('fr-FR')}&nbsp;€</li>
        <li>Frais bancaires (1%) : {fraisBancaires.toLocaleString('fr-FR')}&nbsp;€</li>
        <li><strong>Coût total du projet : {coutTotalProjet.toLocaleString('fr-FR')}&nbsp;€</strong></li>
        <li>Apport (10%) : {apport.toLocaleString('fr-FR')}&nbsp;€</li>
        <li>Montant emprunté : {montantEmprunte.toLocaleString('fr-FR')}&nbsp;€</li>
        <li>Mensualité crédit : <strong>{mensualiteCredit.toLocaleString('fr-FR')}&nbsp;€/mois</strong></li>
      </ul>
    </div>
    <div class="comp-col">
      <h4>Pourquoi 3 scénarios&nbsp;?</h4>
      <p style="font-size:14px; margin:6px 0 0;">Sur le <strong>même bien</strong> à {city.name}, le cash flow varie du simple au triple selon le mode de gestion. Voici les 3 scénarios chiffrés ci-dessous, du moins rentable au plus rentable.</p>
    </div>
  </div>

  <!-- 3 cards cashflow comparées -->
  <h3 style="margin-top:32px;">Cash flow mensuel comparé&nbsp;: 3 scénarios à {city.name}</h3>
  <div class="comparison" style="margin-top:14px;">
    <div class="comp-col" style="background:#fff4f0; border-left:4px solid #c14;">
      <h4 style="margin-top:0; color:#c14;">Avec conciergerie classique</h4>
      <ul>
        <li>CA brut mensuel : {Math.round(caConciergerie / 12).toLocaleString('fr-FR')}&nbsp;€</li>
        <li>Charges (38%) + conciergerie (28%) : -{Math.round(chargesConciergerie / 12).toLocaleString('fr-FR')}&nbsp;€</li>
        <li>Mensualité crédit : -{mensualiteCredit.toLocaleString('fr-FR')}&nbsp;€</li>
        <li><strong style={cashFlowMensuelConcierge < 0 ? 'color:#c14' : ''}>Cash flow net : {cashFlowMensuelConcierge.toLocaleString('fr-FR')}&nbsp;€/mois</strong></li>
        <li><strong>Rendement net : {rendementConcierge}%</strong></li>
      </ul>
    </div>
    <div class="comp-col" style="background:#faf8f3;">
      <h4 style="margin-top:0;">Médian (gestion en direct, sans optim)</h4>
      <ul>
        <li>CA brut mensuel : {Math.round(caMedian / 12).toLocaleString('fr-FR')}&nbsp;€</li>
        <li>Charges (38% du CA) : -{Math.round(chargesMedian / 12).toLocaleString('fr-FR')}&nbsp;€</li>
        <li>Mensualité crédit : -{mensualiteCredit.toLocaleString('fr-FR')}&nbsp;€</li>
        <li><strong>Cash flow net : {cashFlowMensuelMedian.toLocaleString('fr-FR')}&nbsp;€/mois</strong></li>
        <li><strong>Rendement net : {rendementMedian}%</strong></li>
      </ul>
    </div>
  </div>
  <div class="comparison" style="margin-top:14px;">
    <div class="comp-col" style="background:#e8f4ec; border-left:4px solid #3fbd71;">
      <h4 style="margin-top:0; color:#1f7a44;">🏆 Méthode 97%© en gestion directe</h4>
      <ul>
        <li>CA brut mensuel optimisé : {Math.round(caOptimise / 12).toLocaleString('fr-FR')}&nbsp;€</li>
        <li>Charges (28% du CA, sans conciergerie) : -{Math.round(chargesOptimise / 12).toLocaleString('fr-FR')}&nbsp;€</li>
        <li>Mensualité crédit : -{mensualiteCredit.toLocaleString('fr-FR')}&nbsp;€</li>
        <li><strong style="color:#1f7a44;">Cash flow net : {cashFlowMensuelOptimise.toLocaleString('fr-FR')}&nbsp;€/mois</strong></li>
        <li><strong style="color:#1f7a44;">Rendement net : {rendementOptimise}%</strong></li>
      </ul>
    </div>
    <div class="comp-col" style="background:#faf8f3;">
      <h4 style="margin-top:0;">L'écart sur 10 ans</h4>
      <p style="font-size:14px; margin:6px 0;">Différentiel cash flow entre conciergerie et Méthode 97%© en gestion directe&nbsp;:</p>
      <ul>
        <li>Par mois&nbsp;: <strong>+{(cashFlowMensuelOptimise - cashFlowMensuelConcierge).toLocaleString('fr-FR')}&nbsp;€</strong></li>
        <li>Par an&nbsp;: <strong>+{((cashFlowMensuelOptimise - cashFlowMensuelConcierge) * 12).toLocaleString('fr-FR')}&nbsp;€</strong></li>
        <li>Sur 10 ans&nbsp;: <strong>+{((cashFlowMensuelOptimise - cashFlowMensuelConcierge) * 120).toLocaleString('fr-FR')}&nbsp;€</strong></li>
      </ul>
      <p style="font-size:13px; color:#666; margin:8px 0 0;"><em>De quoi rembourser l'apport en quelques mois ou financer un deuxième bien.</em></p>
    </div>
  </div>
  <p style="font-size:13px; color:#666; margin-top:14px;"><em>Calcul indicatif basé sur les fourchettes de prix au m&sup2; du marché local. Pour ajuster sur votre projet réel, lancez le <a href={`/simulateur-lcd?ville=${city.slug}&type=t2&surface=35&apport=10`}>simulateur préremplit avec les données de {city.name}</a>.</em></p>

  <!-- PITCH La Méthode 97%© -->
  <div style="background:linear-gradient(135deg, #2b2d2b 0%, #3a3c3a 100%); color:#e8e4dc; padding:32px 36px; border-radius:14px; margin:36px 0;">
    <h2 style="color:#fff; font-family:'Newsreader', serif; margin-top:0; font-size:28px;">La Méthode 97%© : ce qui change la rentabilité à {city.name}</h2>
    <p style="font-size:18px; line-height:1.5; margin:14px 0 18px;"><strong style="color:#c14;">{rendementConcierge}% de rendement</strong> avec une conciergerie classique. <strong style="color:#3fbd71;">{rendementOptimise}% net</strong> avec La Méthode 97%© en gestion directe. Sur le même bien à {city.name}.</p>
    <p style="font-size:15px; line-height:1.55; opacity:0.92; margin:8px 0;">L'écart vient de trois leviers concrets que la quasi-totalité des propriétaires ignorent&nbsp;:</p>
    <ol style="font-size:15px; line-height:1.6; opacity:0.92; margin:10px 0 18px; padding-left:22px;">
      <li><strong>Louer à la nuit.</strong> Pas un minimum 2 nuits qui plafonne mécaniquement votre occupation à 70%. À la nuit, vous prenez 70% du marché des hôtels qui se loue 365 jours par an, avec un produit deux à trois fois plus grand, mieux équipé et mieux noté. Les jours orphelins du calendrier (le jeudi entre deux week-ends) deviennent des nuits payées au lieu de nuits perdues.</li>
      <li><strong>Hacker les algorithmes.</strong> Ne jamais donner l'exclusivité à Airbnb&nbsp;: présent simultanément sur Airbnb et Booking, les deux plateformes se concurrencent pour pousser votre annonce. Lancement à prix cassé (40-50&nbsp;€) pour faire monter votre annonce dans les recherches en quelques semaines, puis montée progressive vers le prix cible. Pricing dynamique pour capturer les pics&nbsp;: +24% de CA en moyenne. Vous pouvez finir à +40% au-dessus des autres biens du quartier.</li>
      <li><strong>Diviser un grand bien en 2 ou 3 lots.</strong> Une maison de 90&nbsp;m&sup2; s'achète à 2&nbsp;000&nbsp;€/m&sup2; quand un studio neuf est à 5&nbsp;000&nbsp;€/m&sup2;. Vous divisez en 2 T2 qui se louent cher au m&sup2;. Rendement multiplié par 2 sur le même bien. Bonus gestion&nbsp;: une femme de ménage qui fait 2-3 logements groupés à la suite vous coûte 20&nbsp;€/heure. La même, qui doit faire 40 minutes de trajet aller-retour pour un seul bien, va demander 40&nbsp;€/heure ou refuser le contrat.</li>
    </ol>
    <p style="font-size:15px; line-height:1.55; opacity:0.92; margin:8px 0 18px;">Marc Chenut applique La Méthode 97%© sur 9 biens depuis 2019. Résultat&nbsp;: 97% d'occupation moyen, 12 à 18% de rendement net, 5-6 heures de gestion par mois.</p>
    <a href="/blog/louer-airbnb-rentable" style="display:inline-block; background:#3fbd71; color:#fff; padding:12px 24px; border-radius:8px; font-weight:600; text-decoration:none; font-size:15px;">→ Découvrir La Méthode 97%© en détail</a>
  </div>

  <!-- Fiscalité (reformulée) -->
  <h2>La fiscalité de votre Airbnb à {city.name}&nbsp;: ce qui change vraiment</h2>
  <p>Contrairement à ce qu'on lit souvent, la Loi Le Meur (novembre 2024) ne change quasiment rien pour les investisseurs en régime réel LMNP. C'est uniquement le micro-BIC qui a été réduit (50% à 30% d'abattement), or le régime réel reste presque toujours plus avantageux dès que vos charges dépassent 30% du CA.</p>
  <p>Trois points concrets qui touchent réellement votre rentabilité à {city.name}&nbsp;:</p>
  <ul>
    <li><strong>Régime réel LMNP</strong>&nbsp;: l'amortissement du bien et du mobilier permet de neutraliser l'impôt pendant 10 à 15 ans. Inchangé par la Loi Le Meur. C'est le régime à viser dès que possible.</li>
    <li><strong>Plus-value à la revente</strong>&nbsp;: depuis la Loi Le Meur, les amortissements sont réintégrés dans le calcul de la plus-value au moment de la revente. Concrètement, vous payez l'impôt sur la plus-value que vous aviez mis « en suspens » via l'amortissement. Toujours rentable globalement, mais moins qu'avant.</li>
    <li><strong>Seuil URSSAF / LMP</strong>&nbsp;: si vos revenus locatifs dépassent 23&nbsp;000&nbsp;€/an, vous payez 1&nbsp;348&nbsp;€/an minimum d'URSSAF. Si en plus ces revenus dépassent ceux de votre foyer, vous basculez automatiquement en LMP, avec une charge fiscale qui peut atteindre 80% (TMI + prélèvements sociaux + cotisations sociales).</li>
  </ul>
  <p>Pour comprendre quel régime fiscal optimiser sur votre projet à {city.name} et anticiper les seuils&nbsp;: <a href="/blog/fiscalite-airbnb">guide complet fiscalité Airbnb 2026</a>.</p>

  <!-- Conciergerie (avec chiffres annuels) -->
  <h2>Comment vous gérez votre Airbnb à {city.name} change tout</h2>
  <p>Le coût de gestion réel est le levier le plus puissant sur votre rentabilité, après la qualité du produit. La règle généralement énoncée&nbsp;: « la conciergerie prend 20% ». La réalité&nbsp;: <strong>elle prend 50 à 80% de votre cash flow net</strong>, selon la performance du bien.</p>
  <p>Sur un bien type à {city.name} (CA moyen {caMid.toLocaleString('fr-FR')}&nbsp;€), une conciergerie à 20% du CA + frais cachés représente environ <strong>{coutConciergerie.toLocaleString('fr-FR')}&nbsp;€/an</strong>. Comparé au cash flow net annuel projeté de {cashFlowAnnuelMid.toLocaleString('fr-FR')}&nbsp;€, ça mange&nbsp;:</p>
  <ul>
    <li><strong>~50% du cash flow</strong> si votre bien performe (occupation 80%+, pricing dynamique actif, photos pro)</li>
    <li><strong>~80% du cash flow</strong> si votre bien sous-performe (60-70% d'occupation, prix fixe, équipement standard)</li>
    <li><strong>Sur 10 ans</strong>, ça représente {(coutConciergerie * 10).toLocaleString('fr-FR')}&nbsp;€ que vous laissez à votre conciergerie au lieu de les rembourser de votre crédit ou d'investir dans un deuxième bien.</li>
  </ul>
  <p>La règle simple : <strong>si vous habitez à moins de 30 minutes du bien, gérez en direct</strong>. C'est aussi pour ça que beaucoup d'investisseurs LCD performants commencent par investir près de chez eux. Pour creuser le sujet selon votre profil&nbsp;: <a href={conciergerieLink.href}>{conciergerieLink.label}</a>.</p>

  <!-- Réglementation (détaillée pour Lyon, Paris, etc.) -->
  <h2>Réglementation Airbnb à {city.name}</h2>
  <p style="background:#f7f5f0; padding:14px 18px; border-left:3px solid #888; margin:18px 0;">
    <strong>{regulationStatusLabel.icon} {regulationStatusLabel.text}</strong>
  </p>
  <p>{city.regulation.detail}</p>

  {city.regulation.compensation && (
    <>
      <h3>La compensation à {city.name} : comment ça marche concrètement</h3>
      <p>Le mécanisme de compensation est encadré par l'article L631-7 du Code de la Construction et de l'Habitation. Pour transformer un logement en meublé de tourisme à {city.name}, vous devez simultanément <strong>compenser en transformant un local commercial en logement</strong> sur une surface équivalente (parfois doublée selon les arrondissements ou zones).</p>
      <p>En pratique, c'est strict et coûteux. À {city.name}, peu de locaux commerciaux sont disponibles, et le marché de la « commercialité » (le droit de transformer un local commercial en logement, déjà acquis par des marchands de bien) se vend autour de <strong>700&nbsp;€/m&sup2;</strong>. Pour un T2 de 35&nbsp;m&sup2;, la compensation peut donc coûter 24&nbsp;500&nbsp;€ supplémentaires, à intégrer dans votre coût total d'investissement. Source&nbsp;: <a href="https://www.legifrance.gouv.fr/codes/article_lc/LEGIARTI000044870604" target="_blank" rel="nofollow">Légifrance L631-7</a>.</p>
    </>
  )}

  {city.regulation.localCommercialAlternative && (
    <>
      <h3>L'alternative : acheter directement un local commercial à {city.name}</h3>
      <p>Plutôt que d'acheter un logement et de payer la compensation, certains investisseurs achètent directement un <strong>local commercial avec une sous-destination « hôtellerie »</strong> (au sens du PLU). Cela permet de faire de la location courte durée sans compensation puisque le bien n'est pas un logement.</p>
      <p>La méthode pratique&nbsp;:</p>
      <ol>
        <li><strong>Identifier un local commercial</strong> dans la zone visée. Vérifier le règlement de copropriété et le PLU local pour s'assurer que la sous-destination « hôtellerie » est compatible.</li>
        <li><strong>Mettre en condition suspensive</strong> du compromis l'obtention de l'autorisation préalable de changement de sous-destination. Cela vous protège si la mairie refuse.</li>
        <li><strong>Faire valider par un avocat spécialisé</strong> le règlement de copropriété (~500&nbsp;€). À engager <strong>uniquement après obtention de votre prêt</strong>, pour ne pas avancer les frais sur un projet qui pourrait ne pas se faire.</li>
        <li><strong>Pré-lecture par IA</strong> du règlement de copropriété pour avoir une première idée avant de payer l'avocat.</li>
      </ol>
      <p style="background:#f7f5f0; padding:14px 18px; border-left:3px solid #888; font-size:14px;"><strong>Le piège du marché à {city.name}&nbsp;:</strong> les locaux commerciaux compatibles avec du LCD se vendent souvent <strong>en off market à un réseau d'investisseurs professionnels</strong> qui les enchaînent (comme à Paris). Sans réseau local solide, vous n'aurez accès qu'aux biens publics, qui sont déjà valorisés à +1&nbsp;000&nbsp;€/m&sup2; au-dessus du marché classique car les agents savent que la sous-destination est obtenue.</p>
    </>
  )}

  <!-- Saisonnalité spécifique -->
  <h2>Saisonnalité Airbnb à {city.name}</h2>
  {city.category === 'tourisme-balneaire' && (
    <p>{city.name} est une destination à <strong>forte saisonnalité estivale</strong>. Typiquement, juillet-août concentre 45 à 55% du chiffre d'affaires annuel, les ailes (mai-juin et septembre-octobre) apportent 25-30%, et la basse saison ne pèse que 20-25%. Cette concentration impose un pricing dynamique agressif pour capturer les pics et un effort de visibilité multi-canal pour maintenir un taux d'occupation correct hors saison.</p>
  )}
  {city.category === 'station-ski' && (
    <p>{city.name} bénéficie d'une <strong>double saison</strong>&nbsp;: hiver (ski, décembre-mars) et été (alpinisme, randonnée, lacs ; juillet-août). Cette double saison est un avantage majeur car elle réduit la dépendance à une seule période. La saison hiver concentre généralement 50-60% du CA, la saison été 25-30%, et les inter-saisons (avril-mai et octobre-novembre) sont les périodes creuses.</p>
  )}
  {city.category === 'metropole' && (
    <p>{city.name}, métropole, présente une <strong>saisonnalité modérée</strong>. La demande mixe tourisme + voyageurs d'affaires + événements professionnels, ce qui lisse l'occupation sur l'année. Pic d'activité typique au printemps (avril-juin) et automne (septembre-octobre). Janvier et août restent les mois les moins chargés. Cette stabilité facilite le pilotage du cash flow et présente un dossier bancaire plus prévisible.</p>
  )}
  {city.category === 'patrimoine' && (
    <p>{city.name} est une destination patrimoniale avec une saisonnalité <strong>concentrée sur avril-octobre</strong>. La haute saison (juillet-août) représente typiquement 35-45% du CA, les ailes (mai-juin et septembre) 30-35%, et la basse saison (novembre-mars) 20-30%. Les courts séjours patrimoniaux week-end soutiennent l'occupation hors-saison.</p>
  )}
  {city.category === 'peripherie' && (
    <p>{city.name} en périphérie offre une <strong>saisonnalité quasi plate</strong> grâce à une demande lissée par les voyageurs d'affaires, artisans en mission et familles entre deux logements. Typiquement 7 à 10% du CA chaque mois, avec un creux limité en novembre-février. Profil très prévisible pour un dossier bancaire et plus reposant à exploiter.</p>
  )}
  {city.category === 'tourisme-affaires' && (
    <p>{city.name} combine tourisme et voyageurs d'affaires, ce qui donne une <strong>saisonnalité étalée</strong>. La haute saison touristique (juin-septembre) coïncide avec un creux affaires, et inversement (octobre-mai chargé en B2B). Cette complémentarité maintient un taux d'occupation stable toute l'année.</p>
  )}

  <!-- Estimation par type de bien -->

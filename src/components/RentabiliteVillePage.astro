      <ul>
        <li>Tarif moyen&nbsp;: {Math.round(city.t2.nightlyMin * 1.3)}-{Math.round(city.t2.nightlyMax * 1.3)}&nbsp;€/nuit</li>
        <li>Occupation typique&nbsp;: {Math.max(city.t2.occupancyMin - 5, 50)}-{Math.max(city.t2.occupancyMax - 5, 60)}%</li>

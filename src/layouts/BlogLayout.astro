---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  canonical?: string;
}

const { title, description, ogImage, canonical } = Astro.props;
---
<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  {canonical && <link rel="canonical" href={canonical} />}
  {ogImage && <meta property="og:image" content={ogImage} />}
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preconnect" href="https://res.cloudinary.com" crossorigin />
  <link
    rel="preload"
    as="style"
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Newsreader:ital,wght@0,400;0,600;1,400&display=swap"
    onload="this.onload=null;this.rel='stylesheet'"
  />
  <noscript>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Newsreader:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet" />
  </noscript>
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link rel="icon" href="/favicon.png" type="image/png" />
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #f7f6f3;
      --bg-card: #ffffff;
      --bg-elevated: #ffffff;
      --bg-dark: #2b2d2b;
      --bg-dark-soft: #343634;
      --border: #e5e3de;
      --border-dark: #3e403e;
      --text: #1a1a1a;
      --text-secondary: #52524e;
      --text-tertiary: #8a8985;
      --text-light: #e8e4dc;
      --text-dim: #6e6b65;
      --green: #3fbd71;
      --green-soft: rgba(63,189,113,0.08);
      --font: 'Inter', -apple-system, sans-serif;
      --serif: 'Newsreader', Georgia, serif;
      --max-w: 1120px;
      --radius: 10px;
    }

    html { scroll-behavior: smooth; }
    body { background: var(--bg); color: var(--text); font-family: var(--font); font-weight: 400; line-height: 1.6; -webkit-font-smoothing: antialiased; }
    a { color: inherit; text-decoration: none; }

    /* Header styles are in Header.astro component */

    /* Category pills */
    .cat-bar { border-top: 1px solid var(--border); }
    .cat-bar-inner { max-width: var(--max-w); margin: 0 auto; padding: 10px 40px; display: flex; gap: 6px; overflow-x: auto; -webkit-overflow-scrolling: touch; }
    .cat-pill { font-size: 12px; font-weight: 500; color: var(--text-tertiary); padding: 6px 14px; border: 1px solid var(--border); border-radius: 100px; white-space: nowrap; transition: all 0.15s; cursor: pointer; background: transparent; font-family: var(--font); text-decoration: none; display: inline-block; }
    .cat-pill:hover { border-color: var(--text-tertiary); color: var(--text-secondary); }
    .cat-pill.active { background: var(--bg-dark); color: #fff; border-color: var(--bg-dark); }

    /* ═══ LAYOUT ═══ */
    .wrap { max-width: var(--max-w); margin: 0 auto; padding: 0 40px; }

    /* ═══ TAGS ═══ */
    .tag { display: inline-flex; align-items: center; font-size: 11px; font-weight: 600; letter-spacing: 0.04em; text-transform: uppercase; color: var(--green); background: var(--green-soft); padding: 4px 10px; border-radius: 4px; width: fit-content; margin-bottom: 14px; }

    /* ═══ HERO FEATURED ═══ */
    .blog-hero { padding: 48px 0 0; }

    .featured {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0;
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: 14px;
      overflow: hidden;
      transition: box-shadow 0.2s;
      text-decoration: none;
      color: inherit;
    }
    .featured:hover { box-shadow: 0 4px 24px rgba(0,0,0,0.06); }

    .featured-img {
      aspect-ratio: 4/3;
      background: linear-gradient(145deg, #e0ded8 0%, #cccac4 100%);
      display: flex; align-items: center; justify-content: center;
      overflow: hidden;
    }
    .featured-img img { width: 100%; height: 100%; object-fit: cover; }
    .featured-img span { font-size: 12px; color: var(--text-tertiary); }

    .featured-body {
      padding: 36px 32px;
      display: flex; flex-direction: column; justify-content: center;
    }

    .featured-title {
      font-family: var(--serif);
      font-size: 26px;
      font-weight: 600;
      line-height: 1.3;
      color: var(--text);
      margin-bottom: 12px;
    }
    .featured:hover .featured-title { text-decoration: underline; text-underline-offset: 3px; text-decoration-thickness: 1px; }

    .featured-excerpt { font-size: 15px; color: var(--text-secondary); line-height: 1.65; margin-bottom: 16px; }

    .meta { font-size: 12px; color: var(--text-tertiary); display: flex; align-items: center; gap: 10px; }
    .meta-dot { width: 3px; height: 3px; border-radius: 50%; background: var(--text-tertiary); }

    /* Author block in featured */
    .featured-author { display: flex; align-items: center; gap: 10px; }
    .featured-author-photo { width: 32px; height: 32px; border-radius: 50%; background: #c4c2bc; border: 2px solid var(--border); display: flex; align-items: center; justify-content: center; overflow: hidden; }
    .featured-author-photo span { font-size: 11px; color: var(--text-tertiary); }
    .featured-author-info { font-size: 13px; }
    .featured-author-name { font-weight: 600; color: var(--text); }

    /* ═══ NEWSLETTER INLINE ═══ */
    .nl-block {
      background: linear-gradient(135deg, #2b2d2b 0%, #343634 100%);
      border-radius: 16px;
      padding: 40px 40px;
      margin: 48px 0;
      border: 1px solid var(--border-dark);
      box-shadow: 0 20px 50px -20px rgba(0,0,0,0.25);
      position: relative;
      overflow: hidden;
    }
    .nl-block::before {
      content: '';
      position: absolute;
      top: -60px; right: -60px;
      width: 220px; height: 220px;
      background: radial-gradient(circle, rgba(63,189,113,0.18) 0%, transparent 70%);
      pointer-events: none;
    }
    .nl-row { display: flex; gap: 40px; align-items: center; position: relative; z-index: 1; }
    .nl-content { flex: 1.2; }
    .nl-pdf-pill { display: inline-flex; align-items: center; gap: 6px; background: rgba(63,189,113,0.15); color: var(--green); font-size: 10px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; padding: 6px 12px; border-radius: 20px; border: 1px solid rgba(63,189,113,0.3); margin-bottom: 14px; }
    .nl-pdf-pill svg { width: 12px; height: 12px; }
    .nl-tag { font-size: 10px; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: var(--green); margin-bottom: 10px; }
    .nl-title { font-family: var(--serif); font-size: 26px; font-weight: 700; color: var(--text-light); line-height: 1.2; margin-bottom: 10px; letter-spacing: -0.01em; }
    .nl-desc { font-size: 13.5px; color: var(--text-dim); line-height: 1.55; margin-bottom: 16px; }
    .nl-bullets { display: flex; flex-direction: column; gap: 7px; }
    .nl-bullet { display: flex; align-items: flex-start; gap: 10px; font-size: 13px; color: var(--text-light); line-height: 1.4; }
    .nl-bullet-icon { flex-shrink: 0; width: 16px; height: 16px; background: rgba(63,189,113,0.2); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin-top: 2px; }
    .nl-bullet-icon svg { width: 9px; height: 9px; color: var(--green); }
    .nl-bullet strong { color: var(--text-light); font-weight: 600; }
    .nl-form-wrap { flex: 1; max-width: 340px; }
    .nl-form { display: flex; flex-direction: column; gap: 10px; }
    .nl-input { padding: 13px 16px; background: rgba(255,255,255,0.06); border: 1px solid var(--border-dark); border-radius: 10px; color: var(--text-light); font-family: var(--font); font-size: 13.5px; outline: none; transition: all 0.2s; }
    .nl-input::placeholder { color: var(--text-dim); }
    .nl-input:focus { border-color: var(--green); background: rgba(255,255,255,0.09); }
    .nl-btn { padding: 13px 18px; background: var(--green); color: #fff; border: none; border-radius: 10px; font-family: var(--font); font-size: 14px; font-weight: 700; cursor: pointer; transition: all 0.15s; letter-spacing: -0.01em; box-shadow: 0 4px 12px -2px rgba(63,189,113,0.4); }
    .nl-btn:hover { background: #35a862; transform: translateY(-1px); box-shadow: 0 6px 16px -2px rgba(63,189,113,0.5); }
    .nl-note { font-size: 11px; color: var(--text-dim); margin-top: 4px; text-align: center; }

    /* ═══ SECTION HEADER ═══ */
    .sec-head { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 20px; }
    .sec-title { font-size: 14px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: var(--text-tertiary); }
    .sec-link { font-size: 13px; font-weight: 500; color: var(--text-tertiary); }
    .sec-link:hover { color: var(--text); }

    /* ═══ CARD GRID ═══ */
    .grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-bottom: 56px; }

    .card {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      overflow: hidden;
      transition: box-shadow 0.2s, transform 0.15s;
      text-decoration: none;
      color: inherit;
      display: block;
    }
    .card:hover { box-shadow: 0 4px 16px rgba(0,0,0,0.06); transform: translateY(-2px); }

    .card-img {
      aspect-ratio: 16/10;
      background: linear-gradient(145deg, #e4e2dc 0%, #d5d3cd 100%);
      display: flex; align-items: center; justify-content: center;
      overflow: hidden;
    }
    .card-img img { width: 100%; height: 100%; object-fit: cover; }
    .card-img-placeholder {
      aspect-ratio: 16/10;
      background: linear-gradient(145deg, #e4e2dc 0%, #d5d3cd 100%);
    }
    .card-img span { font-size: 11px; color: var(--text-tertiary); }

    .card-body { padding: 18px 20px 20px; }
    .card-cat { font-size: 11px; font-weight: 600; color: var(--green); text-transform: uppercase; letter-spacing: 0.04em; margin-bottom: 8px; }

    .card-title {
      font-family: var(--serif);
      font-size: 17px;
      font-weight: 600;
      line-height: 1.35;
      color: var(--text);
      margin-bottom: 8px;
    }
    .card:hover .card-title { text-decoration: underline; text-underline-offset: 2px; text-decoration-thickness: 1px; }

    .card-excerpt { font-size: 13px; color: var(--text-secondary); line-height: 1.55; margin-bottom: 12px; }
    .card-meta { font-size: 12px; color: var(--text-tertiary); }

    /* ═══ ARTICLE PAGE ═══ */
    .article-wrap {
      display: grid;
      grid-template-columns: 1fr 280px;
      grid-template-rows: auto auto;
      gap: 48px 48px;
      max-width: var(--max-w);
      margin: 0 auto;
      padding: 40px 40px 0;
    }

    .article-main { max-width: 720px; grid-column: 1; grid-row: 1; }
    .sidebar { position: sticky; top: 124px; display: flex; flex-direction: column; gap: 20px; grid-column: 2; grid-row: 1 / 3; align-self: start; max-height: calc(100vh - 140px); overflow-y: auto; scrollbar-width: thin; scrollbar-color: rgba(0,0,0,0.12) transparent; }
    .sidebar::-webkit-scrollbar { width: 4px; }
    .sidebar::-webkit-scrollbar-thumb { background: rgba(0,0,0,0.12); border-radius: 4px; }
    .sidebar::-webkit-scrollbar-track { background: transparent; }
    .related { grid-column: 1; grid-row: 2; padding-top: 32px; border-top: 1px solid var(--border); padding-bottom: 56px; }

    .article-breadcrumb { font-size: 12px; color: var(--text-tertiary); margin-bottom: 20px; }
    .article-breadcrumb a { color: var(--text-tertiary); }
    .article-breadcrumb a:hover { color: var(--text); }
    .bc-sep { margin: 0 6px; }

    .article-h1 {
      font-family: var(--serif);
      font-size: 36px;
      font-weight: 600;
      line-height: 1.2;
      letter-spacing: -0.02em;
      margin-bottom: 20px;
    }

    /* Author block */
    .author-block {
      display: flex; align-items: center; gap: 12px;
      margin-bottom: 8px;
    }
    .author-avatar { width: 36px; height: 36px; border-radius: 50%; background: var(--bg-dark); display: flex; align-items: center; justify-content: center; font-size: 13px; font-weight: 600; color: var(--text-light); flex-shrink: 0; }
    .author-info { font-size: 14px; }
    .author-name { font-weight: 600; color: var(--text); }
    .author-date { color: var(--text-tertiary); font-size: 13px; }
    .author-bio-line { font-size: 13px; color: var(--text-secondary); margin-bottom: 16px; font-style: italic; }

    /* Credibility bar */
    .cred-bar {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      overflow: hidden;
      margin-bottom: 32px;
    }
    .cred-item {
      text-align: center;
      padding: 14px 8px;
      border-right: 1px solid var(--border);
      background: var(--bg-card);
    }
    .cred-item:last-child { border-right: none; }
    .cred-value { font-size: 17px; font-weight: 800; color: var(--text); letter-spacing: -0.02em; }
    .cred-label { font-size: 10px; color: var(--text-tertiary); margin-top: 2px; line-height: 1.3; }

    /* Article cover */
    .article-cover {
      aspect-ratio: 16/9;
      background: linear-gradient(145deg, #e0ded8 0%, #cccac4 100%);
      border-radius: 12px;
      margin-bottom: 36px;
      display: flex; align-items: center; justify-content: center;
      overflow: hidden;
    }
    .article-cover img { width: 100%; height: 100%; object-fit: cover; }
    .article-cover span { font-size: 12px; color: var(--text-tertiary); }

    /* Article body */
    .article-body h2 { font-family: var(--serif); font-size: 24px; font-weight: 600; margin: 36px 0 14px; letter-spacing: -0.01em; }
    .article-body h3 { font-size: 18px; font-weight: 600; margin: 28px 0 10px; }
    .article-body p { font-size: 16px; line-height: 1.8; color: var(--text-secondary); margin-bottom: 18px; }
    .article-body ul, .article-body ol { font-size: 16px; line-height: 1.8; color: var(--text-secondary); margin-bottom: 18px; padding-left: 24px; }
    .article-body li { margin-bottom: 6px; }
    .article-body a { color: var(--green); text-decoration: underline; text-underline-offset: 2px; }
    .article-body blockquote { border-left: 3px solid var(--green); padding: 16px 24px; margin: 28px 0; background: var(--green-soft); border-radius: 0 var(--radius) var(--radius) 0; font-family: var(--serif); font-style: italic; font-size: 17px; color: var(--text); line-height: 1.6; }
    .article-body strong { color: var(--text); font-weight: 600; }
    .article-body code { font-size: 14px; background: rgba(0,0,0,0.05); padding: 2px 6px; border-radius: 4px; }
    .article-body pre { background: var(--bg-dark); color: var(--text-light); padding: 20px 24px; border-radius: var(--radius); margin-bottom: 18px; overflow-x: auto; }
    .article-body pre code { background: none; padding: 0; font-size: 14px; }
    .article-body hr { border: none; border-top: 1px solid var(--border); margin: 36px 0; }
    .article-body img { max-width: 100%; height: auto; display: block; border-radius: var(--radius); margin: 28px auto; }

    /* Tables */
    .article-body table { width: 100%; border-collapse: collapse; margin: 24px 0 28px; border-radius: 8px; overflow: hidden; font-size: 14px; line-height: 1.5; }
    .article-body thead th { background: #2b2d2b; color: #fff; font-size: 13px; font-weight: 600; padding: 12px 16px; text-align: left; white-space: nowrap; }
    .article-body tbody td { padding: 12px 16px; color: var(--text-secondary); border-top: 1px solid var(--border); vertical-align: top; }
    .article-body tbody tr:hover { background: rgba(0,0,0,0.02); }
    .article-body tbody td:first-child { font-weight: 600; color: var(--text); }
    @media (max-width: 640px) {
      .article-body table { display: block; overflow-x: auto; -webkit-overflow-scrolling: touch; }
      .article-body thead th, .article-body tbody td { padding: 10px 12px; font-size: 13px; white-space: nowrap; }
    }

    /* Grid 2 cols */
    .grid-2 { display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px; }

    /* Sidebar simulateur */
    .sb-sim { background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius); padding: 18px 16px; }
    .sb-sim-header { display: flex; align-items: center; gap: 10px; margin-bottom: 6px; }
    .sb-sim-icon { width: 30px; height: 30px; min-width: 30px; background: var(--bg-dark); border-radius: 7px; display: flex; align-items: center; justify-content: center; }
    .sb-sim-icon svg { width: 14px; height: 14px; color: var(--text-light); }
    .sb-sim-title { font-size: 14px; font-weight: 700; line-height: 1.2; }
    .sb-sim-desc { font-size: 11px; color: var(--text-secondary); line-height: 1.55; margin-bottom: 12px; }
    .sb-sim-stats { display: flex; gap: 0; margin-bottom: 12px; border: 1px solid var(--border); border-radius: 8px; overflow: hidden; }
    .sb-sim-stat { flex: 1; text-align: center; padding: 8px 4px; border-right: 1px solid var(--border); }
    .sb-sim-stat:last-child { border-right: none; }
    .sb-sim-stat-val { font-size: 13px; font-weight: 800; }
    .sb-sim-stat-lbl { font-size: 9px; color: var(--text-tertiary); margin-top: 1px; line-height: 1.2; }
    .sb-sim-btn { display: flex; align-items: center; justify-content: center; gap: 6px; width: 100%; padding: 9px 12px; background: var(--bg-dark); color: #fff; border: none; border-radius: 8px; font-family: var(--font); font-size: 13px; font-weight: 600; cursor: pointer; transition: opacity 0.15s; text-decoration: none; }
    .sb-sim-btn svg { width: 14px; height: 14px; flex-shrink: 0; }
    .sb-sim-btn:hover { opacity: 0.88; }

    /* Simulator badge */
    .sb-sim-badge { display: inline-block; font-size: 10px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; background: var(--green-soft); color: var(--green); border-radius: 4px; padding: 2px 7px; margin-bottom: 8px; }

    /* Star rating */
    .rating-block { margin: 36px 0 32px; padding: 24px; background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius); text-align: center; }
    .rating-label { font-size: 14px; font-weight: 600; color: var(--text); margin-bottom: 12px; }
    .rating-stars { display: flex; justify-content: center; gap: 6px; margin-bottom: 8px; }
    .star { font-size: 30px; color: #f59e0b; cursor: pointer; transition: color 0.15s, transform 0.1s; line-height: 1; }
    .star:hover, .star.active { color: #f59e0b; transform: scale(1.15); }
    .rating-count { font-size: 12px; color: var(--text-tertiary); margin-top: 4px; }
    .rating-thanks { font-size: 13px; color: var(--green); font-weight: 600; margin-top: 6px; }

    /* Newsletter end of article */
    .article-nl {
      background: linear-gradient(135deg, #2b2d2b 0%, #343634 100%);
      border-radius: 14px;
      padding: 32px 32px;
      margin: 0 0 40px;
      border: 1px solid var(--border-dark);
      position: relative;
      overflow: hidden;
    }
    .article-nl::before {
      content: '';
      position: absolute;
      top: -50px; right: -50px;
      width: 180px; height: 180px;
      background: radial-gradient(circle, rgba(63,189,113,0.15) 0%, transparent 70%);
      pointer-events: none;
    }
    .article-nl-content { position: relative; z-index: 1; }
    .article-nl-pdf-pill { display: inline-flex; align-items: center; gap: 6px; background: rgba(63,189,113,0.15); color: var(--green); font-size: 9.5px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; padding: 5px 11px; border-radius: 20px; border: 1px solid rgba(63,189,113,0.3); margin-bottom: 12px; }
    .article-nl-pdf-pill svg { width: 11px; height: 11px; }
    .article-nl-tag { font-size: 10px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--green); margin-bottom: 10px; }
    .article-nl-title { font-family: var(--serif); font-size: 23px; font-weight: 700; color: var(--text-light); line-height: 1.22; margin-bottom: 8px; letter-spacing: -0.01em; }
    .article-nl-desc { font-size: 13px; color: var(--text-dim); line-height: 1.6; margin-bottom: 16px; }
    .article-nl-bullets { display: flex; flex-direction: column; gap: 7px; margin-bottom: 18px; }
    .article-nl-bullet { display: flex; align-items: flex-start; gap: 9px; font-size: 12.5px; color: var(--text-light); line-height: 1.4; }
    .article-nl-bullet-icon { flex-shrink: 0; width: 15px; height: 15px; background: rgba(63,189,113,0.2); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin-top: 1.5px; }
    .article-nl-bullet-icon svg { width: 8px; height: 8px; color: var(--green); }
    .article-nl-bullet strong { color: var(--text-light); font-weight: 600; }
    .article-nl-form { display: flex; flex-direction: column; gap: 8px; }
    .article-nl-input { padding: 12px 14px; background: rgba(255,255,255,0.07); border: 1px solid var(--border-dark); border-radius: 8px; color: var(--text-light); font-family: var(--font); font-size: 13px; outline: none; width: 100%; box-sizing: border-box; transition: all 0.2s; }
    .article-nl-input::placeholder { color: var(--text-dim); }
    .article-nl-input:focus { border-color: var(--green); background: rgba(255,255,255,0.1); }
    .article-nl-row { display: flex; gap: 0; }
    .article-nl-email { border-radius: 8px 0 0 8px !important; border-right: none !important; flex: 1; }
    .article-nl-btn { background: var(--green); color: #fff; border: none; font-family: var(--font); font-size: 13px; font-weight: 700; padding: 12px 20px; border-radius: 0 8px 8px 0; cursor: pointer; white-space: nowrap; transition: all 0.15s; letter-spacing: -0.01em; box-shadow: 0 3px 10px -2px rgba(63,189,113,0.4); }
    .article-nl-btn:hover { background: #35a862; }
    .article-nl-note { font-size: 10.5px; color: var(--text-dim); margin-top: 10px; text-align: center; }

    /* Author avatar photo */
    .author-avatar img { width: 100%; height: 100%; object-fit: cover; border-radius: 50%; }

    /* Sidebar NL */
    .sb-nl {
      background: linear-gradient(160deg, #2b2d2b 0%, #343634 100%);
      border-radius: var(--radius);
      padding: 22px 20px;
      border: 1px solid var(--border-dark);
      position: relative;
      overflow: hidden;
    }
    .sb-nl::before {
      content: '';
      position: absolute;
      top: -40px; right: -40px;
      width: 140px; height: 140px;
      background: radial-gradient(circle, rgba(63,189,113,0.18) 0%, transparent 70%);
      pointer-events: none;
    }
    .sb-nl-content { position: relative; z-index: 1; }
    .sb-nl-pdf-pill { display: inline-flex; align-items: center; gap: 5px; background: rgba(63,189,113,0.15); color: var(--green); font-size: 9px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; padding: 4px 9px; border-radius: 20px; border: 1px solid rgba(63,189,113,0.3); margin-bottom: 10px; }
    .sb-nl-pdf-pill svg { width: 10px; height: 10px; }
    .sb-nl-tag { font-size: 10px; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--green); margin-bottom: 8px; }
    .sb-nl-title { font-family: var(--serif); font-size: 16px; font-weight: 700; color: var(--text-light); line-height: 1.25; margin-bottom: 6px; letter-spacing: -0.01em; }
    .sb-nl-desc { font-size: 11.5px; color: var(--text-dim); line-height: 1.5; margin-bottom: 12px; }
    .sb-nl-bullets { display: flex; flex-direction: column; gap: 5px; margin-bottom: 13px; }
    .sb-nl-bullet { display: flex; align-items: flex-start; gap: 7px; font-size: 11px; color: var(--text-light); line-height: 1.35; }
    .sb-nl-bullet-icon { flex-shrink: 0; width: 13px; height: 13px; background: rgba(63,189,113,0.2); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin-top: 1px; }
    .sb-nl-bullet-icon svg { width: 7px; height: 7px; color: var(--green); }
    .sb-nl input { width: 100%; padding: 10px 12px; background: rgba(255,255,255,0.06); border: 1px solid var(--border-dark); border-radius: 7px; color: var(--text-light); font-family: var(--font); font-size: 12px; margin-bottom: 6px; outline: none; box-sizing: border-box; transition: all 0.2s; }
    .sb-nl input::placeholder { color: var(--text-dim); }
    .sb-nl input:focus { border-color: var(--green); background: rgba(255,255,255,0.09); }
    .sb-nl button { width: 100%; padding: 11px; background: var(--green); color: #fff; border: none; border-radius: 7px; font-family: var(--font); font-size: 12px; font-weight: 700; cursor: pointer; transition: all 0.15s; letter-spacing: -0.01em; box-shadow: 0 3px 10px -2px rgba(63,189,113,0.4); }
    .sb-nl button:hover { background: #35a862; }
    .sb-nl-note { font-size: 10px; color: var(--text-dim); margin-top: 8px; text-align: center; }

    /* Footer styles are in Footer.astro component */

    /* ═══ RESPONSIVE ═══ */
    @media (max-width: 900px) {
      .featured { grid-template-columns: 1fr; }
      .featured-img { aspect-ratio: 16/9; }
      .featured-body { padding: 28px 24px; }
    }
    @media (max-width: 768px) {
      .wrap, .cat-bar-inner { padding-left: 20px; padding-right: 20px; }
      .featured-body { padding: 24px 20px; }
      .grid-3 { grid-template-columns: 1fr 1fr; }
      .nl-row { flex-direction: column; gap: 20px; }
      .nl-form-wrap { max-width: 100%; width: 100%; }
      .article-wrap { grid-template-columns: 1fr; padding-left: 20px; padding-right: 20px; gap: 32px; }
      .article-main { grid-column: 1; grid-row: auto; order: 1; }
      .sidebar { position: static; grid-column: 1; grid-row: auto; order: 2; }
      .related { grid-column: 1; grid-row: auto; order: 3; }
      .cred-bar { grid-template-columns: repeat(2, 1fr); }
      .cred-item:nth-child(2) { border-right: none; }
      .grid-2 { grid-template-columns: 1fr; }
    }
    @media (max-width: 480px) {
      .grid-3 { grid-template-columns: 1fr; }
      .featured-title { font-size: 22px; }
      .article-h1 { font-size: 28px; }
    }
  </style>
</head>
<body>

  <Header variant="marketing" />

  <main>
    <slot />
  </main>

  <Footer />
  <script>
    import { inject } from '@vercel/analytics';
    inject();
  </script>
</body>
</html>

---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CookieBanner from '../components/CookieBanner.astro';
import NewsletterPopup from '../components/NewsletterPopup.astro';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  currentTool?: 'simulateur' | 'facture' | 'contrat' | 'taxe-sejour' | 'none';
  ctaLabel?: string;
  ctaHref?: string;
  /** Empêche l'indexation Google (utilisé par les pages /preview/*) */
  noindex?: boolean;
  /**
   * Pop-up newsletter :
   *  'on'     (défaut) → 45s + exit-intent, tous visiteurs
   *  'authed'          → 90s, uniquement si connecté (pages outils avec login)
   *  'off'             → désactivée (home, /livre, /la-methode-97 : capture déjà présente)
   */
  newsletterPopup?: 'on' | 'authed' | 'off';
}

const { title, description, canonical, ogImage, currentTool = 'none', ctaLabel, ctaHref, noindex = false, newsletterPopup = 'on' } = Astro.props;
const headerTool = currentTool === 'none' ? undefined : currentTool;
---
<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  {canonical && <link rel="canonical" href={canonical} />}
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  {ogImage && <meta property="og:image" content={ogImage} />}
  {noindex && <meta name="robots" content="noindex,nofollow" />}
  <link rel="preload" href="/fonts/inter-latin-wght-normal.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link rel="icon" href="/favicon.png" type="image/png" />
  <style is:global>
    @font-face {
      font-family: 'Inter';
      font-style: normal;
      font-display: swap;
      font-weight: 100 900;
      src: url('/fonts/inter-latin-wght-normal.woff2') format('woff2');
    }
    @font-face {
      font-family: 'Newsreader';
      font-style: normal;
      font-display: swap;
      font-weight: 200 800;
      src: url('/fonts/newsreader-latin-wght-normal.woff2') format('woff2');
    }
    @font-face {
      font-family: 'Newsreader';
      font-style: italic;
      font-display: swap;
      font-weight: 200 800;
      src: url('/fonts/newsreader-latin-wght-italic.woff2') format('woff2');
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #f7f6f3;
      --bg-card: #ffffff;
      --bg-dark: #2b2d2b;
      --bg-dark-soft: #343634;
      --border: #e5e3de;
      --border-dark: #3e403e;
      --text: #1a1a1a;
      --text-secondary: #52524e;
      --text-tertiary: #8a8985;
      --text-light: #e8e4dc;
      --text-dim: #6e6b65;
      --green: #3fbd71;
      --green-soft: rgba(63,189,113,0.08);
      --accent: #2b2d2b;
      --font: 'Inter', -apple-system, sans-serif;
      --serif: 'Newsreader', Georgia, serif;
      --max-w: 1120px;
      --radius: 10px;
    }

    html { scroll-behavior: smooth; }
    body { background: var(--bg); color: var(--text); font-family: var(--font); font-weight: 400; line-height: 1.6; -webkit-font-smoothing: antialiased; }
    /* Garde-fou responsive global : empêche tout scroll horizontal de page (ex. sliders d'avis
       overflow-x:auto qui "fuient" sur iOS Safari). Posé sur <main> et non <body> pour ne pas
       casser le header position:sticky. S'applique à toutes les pages ToolLayout. */
    main { overflow-x: hidden; }
    a { color: inherit; text-decoration: none; }

    /* Header styles are in Header.astro component */

    /* Footer styles are in Footer.astro component */
  </style>
</head>
<body>
  <Header variant="tool" currentTool={headerTool} ctaLabel={ctaLabel} ctaHref={ctaHref} />

  <main>
    <slot />
  </main>

  <Footer />
  <CookieBanner />
  {newsletterPopup !== 'off' && (
    <NewsletterPopup
      delay={newsletterPopup === 'authed' ? 90000 : 45000}
      requireAuth={newsletterPopup === 'authed'}
    />
  )}
  <script>
    import { inject } from '@vercel/analytics';
    inject();
  </script>
</body>
</html>

---
export const prerender = true;

import { getCollection, getEntry } from 'astro:content';
import BlogLayout from '../../layouts/BlogLayout.astro';
import NewsletterBlock from '../../components/NewsletterBlock.astro';
import { marcChenut } from '../../data/author';
import blogVolumes from '../../../scripts/blog-volumes-en-ligne.json';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => data.status === 'en-ligne');
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

const CAT_LABELS: Record<string, string> = {
  'chiffres-rentabilite': '💰 Chiffres & Rentabilité',
  'outils-automatisation': '🔧 Outils & Automatisation',
  'fiscal-juridique': '🏛️ Fiscal & Juridique',
  'gestion': '🏠 Gestion',
};

function formatDate(dateStr: string) {
  return new Date(dateStr).toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' });
}

function readingTime(body: string | undefined) {
  if (!body) return 1;
  const words = body.split(/\s+/).length;
  return Math.max(1, Math.round(words / 200));
}

function getInitials(name: string) {
  return name.split(' ').map(n => n.charAt(0).toUpperCase()).join('').slice(0, 2);
}

// Related articles: top traffic (by SEMrush vol), exclude current, exclude drafts
// Fallback to publishedAt desc for articles without volume data
const allPosts = await getCollection('blog', ({ data }) => data.status === 'en-ligne');
const volOf = (slug: string) => (blogVolumes as Record<string, { vol?: number }>)[slug]?.vol ?? 0;
const relatedPosts = allPosts
  .filter(p => p.slug !== post.slug)
  .sort((a, b) => {
    const vDiff = volOf(b.slug) - volOf(a.slug);
    if (vDiff !== 0) return vDiff;
    return new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime();
  })
  .slice(0, 20);

const catLabel = CAT_LABELS[post.data.category];
const readTime = readingTime(post.body);

const seeAlsoClusters = post.data.relatedClusters && post.data.relatedClusters.length > 0
  ? post.data.relatedClusters
  : [
      { label: 'Conciergerie Airbnb par région', href: '/conciergerie-airbnb' },
      { label: 'Rentabilité Airbnb : 30 villes', href: '/rentabilite-airbnb' },
    ];

// JSON-LD Article
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.data.metaTitle,
  description: post.data.metaDescription,
  datePublished: post.data.publishedAt,
  dateModified: post.data.updatedAt ?? post.data.publishedAt,
  author: marcChenut,
  publisher: {
    '@type': 'Organization',
    name: 'Enomia',
    url: 'https://www.enomia.app',
  },
  ...(post.data.featuredImage ? { image: post.data.featuredImage.src } : {}),
};

// JSON-LD FAQPage : auto-parsed from Markdoc ### headings inside ## FAQ section
function parseFaqFromBody(body: string | undefined) {
  if (!body) return [];
  // Find the FAQ section (## **FAQ ...)
  const faqMatch = body.match(/^## \*\*FAQ[^*]*\*\*/m);
  if (!faqMatch || faqMatch.index === undefined) return [];
  const faqSection = body.slice(faqMatch.index);
  // Stop at the next ## that isn't a ### (i.e., next top-level section)
  const nextH2 = faqSection.slice(faqMatch[0].length).match(/^## (?!\*\*FAQ)/m);
  const faqText = nextH2 && nextH2.index !== undefined
    ? faqSection.slice(0, faqMatch[0].length + nextH2.index)
    : faqSection;
  // Extract ### **Question** + following paragraph(s)
  const items: { q: string; a: string }[] = [];
  const qRegex = /### \*\*(.+?)\*\*\s*\n\n([\s\S]*?)(?=\n### |\n## |$)/g;
  let m;
  while ((m = qRegex.exec(faqText)) !== null) {
    const question = m[1].trim();
    // Clean answer: remove markdown bold/italic/links, keep plain text
    const answer = m[2].trim()
      .replace(/\*\*(.+?)\*\*/g, '$1')
      .replace(/\*(.+?)\*/g, '$1')
      .replace(/\[([^\]]+)\]\([^)]+\)/g, '$1')
      .replace(/`([^`]+)`/g, '$1')
      .split('\n\n')[0] // first paragraph only
      .slice(0, 300); // cap at 300 chars
    if (question && answer) items.push({ q: question, a: answer });
  }
  return items;
}

const faqItems = parseFaqFromBody(post.body);
const faqLd = faqItems.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map(f => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
} : null;
---

<BlogLayout
  title={post.data.metaTitle}
  description={post.data.metaDescription}
  ogImage={post.data.featuredImage?.src}
  canonical={`https://www.enomia.app/blog/${post.slug}`}
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  {faqLd && <script type="application/ld+json" set:html={JSON.stringify(faqLd)} />}

  <div class="article-wrap">

    <!-- Main content -->
    <article class="article-main">
      <!-- Breadcrumb -->
      <nav class="article-breadcrumb">
        <a href="/blog">Blog</a>
        <span class="bc-sep">›</span>
        <a href={`/blog?cat=${post.data.category}`}>{catLabel}</a>
        <span class="bc-sep">›</span>
        <span>{post.data.title}</span>
      </nav>

      <!-- Category tag -->
      <span class="tag">{catLabel}</span>

      <!-- Title -->
      <h1 class="article-h1">{post.data.title}</h1>

      <!-- Author block -->
      <div class="author-block">
        <div class="author-avatar">
          <img src="https://res.cloudinary.com/dv2btcpc2/image/upload/q_auto,f_auto,w_80/v1775507331/Marc_1_a6ndja.png" alt={post.data.authorName} />
        </div>
        <div class="author-info">
          <div class="author-name">{post.data.authorName}</div>
          <div class="author-date">
            {formatDate(post.data.publishedAt)}
            {post.data.updatedAt && (
              <span> · Mis à jour le {formatDate(post.data.updatedAt)}</span>
            )}
            <span> · {readTime} min de lecture</span>
          </div>
        </div>
      </div>

      {post.data.authorBio && (
        <p class="author-bio-line">{post.data.authorBio}</p>
      )}

      <!-- Credibility bar -->
      <div class="cred-bar">
        <div class="cred-item">
          <div class="cred-value">9</div>
          <div class="cred-label">biens en portefeuille</div>
        </div>
        <div class="cred-item">
          <div class="cred-value">12–18%</div>
          <div class="cred-label">rendement net moyen</div>
        </div>
        <div class="cred-item">
          <div class="cred-value">~1h</div>
          <div class="cred-label">par bien par mois</div>
        </div>
        <div class="cred-item">
          <div class="cred-value">6 ans</div>
          <div class="cred-label">d'expérience LCD</div>
        </div>
      </div>

      <!-- Cover image -->
      <div class="article-cover">
        {post.data.featuredImage
          ? (() => {
              const raw = post.data.featuredImage.src;
              const isCloudinary = raw.includes('res.cloudinary.com');
              const makeSrc = (w: number) =>
                isCloudinary
                  ? raw.replace(/\/upload\/[^/]*\//, `/upload/q_auto,f_auto,w_${w}/`)
                  : raw;
              return (
                <img
                  src={makeSrc(800)}
                  srcset={isCloudinary ? `${makeSrc(400)} 400w, ${makeSrc(800)} 800w, ${makeSrc(1200)} 1200w` : undefined}
                  sizes="(max-width: 768px) 100vw, 720px"
                  alt={post.data.featuredImage.alt}
                  fetchpriority="high"
                  decoding="async"
                  width="1280"
                  height="720"
                />
              );
            })()
          : <span>Image de couverture</span>
        }
      </div>

      <!-- Content -->
      <div class="article-body">
        <Content />
      </div>

      <aside class="see-also">
        <h3 class="see-also-title">Pour aller plus loin</h3>
        <div class="see-also-grid">
          {seeAlsoClusters.map((c) => (
            <a href={c.href} class="see-also-card">
              <span class="see-also-card-label">{c.label}</span>
              <span class="see-also-card-arrow">→</span>
            </a>
          ))}
        </div>
      </aside>

      <NewsletterBlock id="article-nl-form" source="NL-Blog-Inline" />
    </article>

    <!-- Sidebar -->
    <aside class="sidebar">
      <!-- Simulateur widget -->
      <div class="sb-sim">
        <div class="sb-sim-header">
          <div class="sb-sim-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect>
              <line x1="8" y1="21" x2="16" y2="21"></line>
              <line x1="12" y1="17" x2="12" y2="21"></line>
            </svg>
          </div>
          <div class="sb-sim-title">Simulateur de rendement Airbnb</div>
        </div>
        <div class="sb-sim-badge">100% gratuit</div>
        <p class="sb-sim-desc">Calculez en 2 minutes le rendement réel de votre bien Airbnb : cash flow, rentabilité nette, seuil de rentabilité.</p>
        <div class="sb-sim-stats">
          <div class="sb-sim-stat">
            <div class="sb-sim-stat-val">&infin;</div>
            <div class="sb-sim-stat-lbl">sauvegardes</div>
          </div>
          <div class="sb-sim-stat">
            <div class="sb-sim-stat-val">2min</div>
            <div class="sb-sim-stat-lbl">pour calculer</div>
          </div>
          <div class="sb-sim-stat">
            <div class="sb-sim-stat-val">100%</div>
            <div class="sb-sim-stat-lbl">gratuit</div>
          </div>
        </div>
        <a href="/estimation-airbnb" class="sb-sim-btn">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="13 17 18 12 13 7"></polyline>
            <polyline points="6 17 11 12 6 7"></polyline>
          </svg>
          Lancer le simulateur
        </a>
      </div>

      <!-- Facturation widget -->
      <div class="sb-sim">
        <div class="sb-sim-header">
          <div class="sb-sim-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
              <polyline points="14 2 14 8 20 8"/>
              <line x1="9" y1="13" x2="15" y2="13"/>
              <line x1="9" y1="17" x2="15" y2="17"/>
            </svg>
          </div>
          <div class="sb-sim-title">Facture LCD gratuite</div>
        </div>
        <div class="sb-sim-badge">Gratuit</div>
        <p class="sb-sim-desc">Générez vos factures Airbnb, Booking ou location saisonnière : taxe de séjour automatique, mentions LMNP, export PDF.</p>
        <div class="sb-sim-stats">
          <div class="sb-sim-stat">
            <div class="sb-sim-stat-val">2min</div>
            <div class="sb-sim-stat-lbl">par facture</div>
          </div>
          <div class="sb-sim-stat">
            <div class="sb-sim-stat-val">Auto</div>
            <div class="sb-sim-stat-lbl">taxe de s&eacute;jour</div>
          </div>
          <div class="sb-sim-stat">
            <div class="sb-sim-stat-val">PDF</div>
            <div class="sb-sim-stat-lbl">export</div>
          </div>
        </div>
        <a href="/facture-location-saisonniere" class="sb-sim-btn">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="13 17 18 12 13 7"></polyline>
            <polyline points="6 17 11 12 6 7"></polyline>
          </svg>
          Générer une facture
        </a>
      </div>

      <!-- Contrat widget -->
      <div class="sb-sim">
        <div class="sb-sim-header">
          <div class="sb-sim-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
              <polyline points="14 2 14 8 20 8"/>
              <path d="M9 15h6"/>
              <path d="M9 11h6"/>
            </svg>
          </div>
          <div class="sb-sim-title">Contrat de location saisonnière</div>
        </div>
        <div class="sb-sim-badge">Gratuit</div>
        <p class="sb-sim-desc">Générez un contrat LCD conforme : clauses légales, dépôt de garantie, état des lieux, signature électronique.</p>
        <div class="sb-sim-stats">
          <div class="sb-sim-stat">
            <div class="sb-sim-stat-val">3min</div>
            <div class="sb-sim-stat-lbl">par contrat</div>
          </div>
          <div class="sb-sim-stat">
            <div class="sb-sim-stat-val">FR/EN</div>
            <div class="sb-sim-stat-lbl">bilingue</div>
          </div>
          <div class="sb-sim-stat">
            <div class="sb-sim-stat-val">PDF</div>
            <div class="sb-sim-stat-lbl">export</div>
          </div>
        </div>
        <a href="/contrat-location-saisonniere" class="sb-sim-btn">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="13 17 18 12 13 7"></polyline>
            <polyline points="6 17 11 12 6 7"></polyline>
          </svg>
          Générer un contrat
        </a>
      </div>

      <!-- Taxe de séjour widget -->
      <div class="sb-sim">
        <div class="sb-sim-header">
          <div class="sb-sim-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/>
              <path d="M16 8h-6a2 2 0 1 0 0 4h4a2 2 0 1 1 0 4H8"/>
              <line x1="12" y1="6" x2="12" y2="8"/>
              <line x1="12" y1="16" x2="12" y2="18"/>
            </svg>
          </div>
          <div class="sb-sim-title">Calcul taxe de séjour</div>
        </div>
        <div class="sb-sim-badge">Gratuit</div>
        <p class="sb-sim-desc">Tarif officiel par commune française : barèmes 2026, calcul automatique par nuit et par voyageur.</p>
        <div class="sb-sim-stats">
          <div class="sb-sim-stat">
            <div class="sb-sim-stat-val">36k+</div>
            <div class="sb-sim-stat-lbl">communes</div>
          </div>
          <div class="sb-sim-stat">
            <div class="sb-sim-stat-val">Auto</div>
            <div class="sb-sim-stat-lbl">par nuit</div>
          </div>
          <div class="sb-sim-stat">
            <div class="sb-sim-stat-val">2026</div>
            <div class="sb-sim-stat-lbl">à jour</div>
          </div>
        </div>
        <a href="/calcul-taxe-de-sejour" class="sb-sim-btn">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="13 17 18 12 13 7"></polyline>
            <polyline points="6 17 11 12 6 7"></polyline>
          </svg>
          Calculer la taxe
        </a>
      </div>

      <NewsletterBlock id="sb-nl-form" compact source="NL-Blog-Sidebar" />
    </aside>

    <!-- Related articles : horizontal scroll desktop, vertical mobile -->
    {relatedPosts.length > 0 && (
      <section class="related">
        <div class="sec-head">
          <span class="sec-title">Articles liés</span>
          <a href="/blog" class="sec-link">Voir tout →</a>
        </div>
        <div class="related-rail">
          {relatedPosts.map(related => (
            <a href={`/blog/${related.slug}`} class="card related-card">
              <div class="card-img">
                {related.data.featuredImage
                  ? <img src={related.data.featuredImage.src} alt={related.data.featuredImage.alt} loading="lazy" />
                  : <div class="card-img-placeholder" style="width:100%;height:100%;"></div>
                }
              </div>
              <div class="card-body">
                <div class="card-cat">{CAT_LABELS[related.data.category]}</div>
                <div class="card-title">{related.data.title}</div>
                <p class="card-excerpt">{related.data.excerpt}</p>
                <div class="card-meta">{formatDate(related.data.publishedAt)} · {readingTime(related.body)} min</div>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

  </div>
</BlogLayout>

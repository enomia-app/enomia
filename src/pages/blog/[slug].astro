---
export const prerender = true;

import { getCollection, getEntry } from 'astro:content';
import BlogLayout from '../../layouts/BlogLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

const CAT_LABELS: Record<string, string> = {
  'chiffres-rentabilite': '💰 Chiffres & Rentabilité',
  'outils-automatisation': '🔧 Outils & Automatisation',
  'fiscal-juridique': '🏛️ Fiscal & Juridique',
  'gestion': '🏠 Gestion',
};

function formatDate(dateStr: string) {
  return new Date(dateStr).toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' });
}

function readingTime(body: string | undefined) {
  if (!body) return 1;
  const words = body.split(/\s+/).length;
  return Math.max(1, Math.round(words / 200));
}

function getInitials(name: string) {
  return name.split(' ').map(n => n.charAt(0).toUpperCase()).join('').slice(0, 2);
}

// Related articles: same category, exclude current
const allPosts = await getCollection('blog');
const relatedPosts = allPosts
  .filter(p => p.slug !== post.slug && p.data.category === post.data.category)
  .sort((a, b) => new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime())
  .slice(0, 2);

const catLabel = CAT_LABELS[post.data.category];
const readTime = readingTime(post.body);

// JSON-LD
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.data.metaTitle,
  description: post.data.metaDescription,
  datePublished: post.data.publishedAt,
  dateModified: post.data.updatedAt ?? post.data.publishedAt,
  author: {
    '@type': 'Person',
    name: post.data.authorName,
  },
  publisher: {
    '@type': 'Organization',
    name: 'Enomia',
    url: 'https://enomia.fr',
  },
  ...(post.data.featuredImage ? { image: post.data.featuredImage.src } : {}),
};
---

<BlogLayout
  title={post.data.metaTitle}
  description={post.data.metaDescription}
  ogImage={post.data.featuredImage?.src}
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <div class="article-wrap">

    <!-- Main content -->
    <article class="article-main">
      <!-- Breadcrumb -->
      <nav class="article-breadcrumb">
        <a href="/blog">Blog</a>
        <span class="bc-sep">›</span>
        <a href={`/blog?cat=${post.data.category}`}>{catLabel}</a>
        <span class="bc-sep">›</span>
        <span>{post.data.title}</span>
      </nav>

      <!-- Category tag -->
      <span class="tag">{catLabel}</span>

      <!-- Title -->
      <h1 class="article-h1">{post.data.title}</h1>

      <!-- Author block -->
      <div class="author-block">
        <div class="author-avatar">
          <img src="https://res.cloudinary.com/dv2btcpc2/image/upload/q_auto,f_auto,w_80/v1775507331/Marc_1_a6ndja.png" alt={post.data.authorName} />
        </div>
        <div class="author-info">
          <div class="author-name">{post.data.authorName}</div>
          <div class="author-date">
            {formatDate(post.data.publishedAt)}
            {post.data.updatedAt && (
              <span> · Mis à jour le {formatDate(post.data.updatedAt)}</span>
            )}
            <span> · {readTime} min de lecture</span>
          </div>
        </div>
      </div>

      {post.data.authorBio && (
        <p class="author-bio-line">{post.data.authorBio}</p>
      )}

      <!-- Credibility bar -->
      <div class="cred-bar">
        <div class="cred-item">
          <div class="cred-value">9</div>
          <div class="cred-label">biens en portefeuille</div>
        </div>
        <div class="cred-item">
          <div class="cred-value">12–18%</div>
          <div class="cred-label">rendement net moyen</div>
        </div>
        <div class="cred-item">
          <div class="cred-value">~1h</div>
          <div class="cred-label">par bien par mois</div>
        </div>
        <div class="cred-item">
          <div class="cred-value">6 ans</div>
          <div class="cred-label">d'expérience LCD</div>
        </div>
      </div>

      <!-- Cover image -->
      <div class="article-cover">
        {post.data.featuredImage
          ? <img src={post.data.featuredImage.src} alt={post.data.featuredImage.alt} />
          : <span>Image de couverture</span>
        }
      </div>

      <!-- Content -->
      <div class="article-body">
        <Content />
      </div>

      <!-- Star rating -->
      <div class="rating-block" data-slug={post.slug}>
        <div class="rating-label">Cet article vous a été utile ?</div>
        <div class="rating-stars" id="rating-stars">
          <span class="star" data-v="1">★</span>
          <span class="star" data-v="2">★</span>
          <span class="star" data-v="3">★</span>
          <span class="star" data-v="4">★</span>
          <span class="star" data-v="5">★</span>
        </div>
        <div class="rating-count" id="rating-count"></div>
        <div class="rating-thanks" id="rating-thanks" style="display:none">Merci pour votre avis !</div>
      </div>

      <!-- Newsletter end of article -->
      <div class="article-nl">
        <div class="article-nl-content">
          <div class="article-nl-pdf-pill">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
            Guide PDF offert + Newsletter
          </div>
          <div class="article-nl-title">Recevez ma Méthode 97%© LCD complète, gratuitement</div>
          <p class="article-nl-desc">Le guide PDF en 10 étapes que j'ai utilisé pour atteindre <strong style="color:var(--text-light);">12–18% de rendement net</strong> sur 9 biens — expliqué de A à Z, sans jargon.</p>
          <div class="article-nl-bullets">
            <div class="article-nl-bullet">
              <span class="article-nl-bullet-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></span>
              <span><strong>Guide PDF Méthode 97%©</strong> — 40+ pages</span>
            </div>
            <div class="article-nl-bullet">
              <span class="article-nl-bullet-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></span>
              <span>Accès au <strong>simulateur de rentabilité</strong> Enomia</span>
            </div>
            <div class="article-nl-bullet">
              <span class="article-nl-bullet-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></span>
              <span><strong>1 email/semaine</strong> — chiffres réels, rien à vendre</span>
            </div>
          </div>
          <form class="article-nl-form" id="article-nl-form">
            <input type="text" placeholder="Prénom" class="article-nl-input" required />
            <div class="article-nl-row">
              <input type="email" placeholder="votre@email.com" class="article-nl-input article-nl-email" required />
              <button type="submit" class="article-nl-btn">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="width:13px;height:13px;vertical-align:-1px;margin-right:4px"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                Recevoir le guide
              </button>
            </div>
          </form>
          <p class="article-nl-note">Désinscription en 1 clic · Email jamais partagé</p>
        </div>
      </div>
    </article>

    <!-- Sidebar -->
    <aside class="sidebar">
      <!-- Simulateur widget -->
      <div class="sb-sim">
        <div class="sb-sim-header">
          <div class="sb-sim-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect>
              <line x1="8" y1="21" x2="16" y2="21"></line>
              <line x1="12" y1="17" x2="12" y2="21"></line>
            </svg>
          </div>
          <div class="sb-sim-title">Simulateur de rendement Airbnb</div>
        </div>
        <div class="sb-sim-badge">100% gratuit</div>
        <p class="sb-sim-desc">Calculez en 2 minutes le rendement réel de votre bien Airbnb — cash flow, rentabilité nette, seuil de rentabilité.</p>
        <div class="sb-sim-stats">
          <div class="sb-sim-stat">
            <div class="sb-sim-stat-val">+24%</div>
            <div class="sb-sim-stat-lbl">revenus moyens</div>
          </div>
          <div class="sb-sim-stat">
            <div class="sb-sim-stat-val">2min</div>
            <div class="sb-sim-stat-lbl">pour calculer</div>
          </div>
          <div class="sb-sim-stat">
            <div class="sb-sim-stat-val">100%</div>
            <div class="sb-sim-stat-lbl">gratuit</div>
          </div>
        </div>
        <a href="/simulateur-rentabilite-airbnb" class="sb-sim-btn">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="13 17 18 12 13 7"></polyline>
            <polyline points="6 17 11 12 6 7"></polyline>
          </svg>
          Lancer le simulateur
        </a>
      </div>

      <!-- Facturation widget -->
      <div class="sb-sim">
        <div class="sb-sim-header">
          <div class="sb-sim-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
              <polyline points="14 2 14 8 20 8"/>
              <line x1="9" y1="13" x2="15" y2="13"/>
              <line x1="9" y1="17" x2="15" y2="17"/>
            </svg>
          </div>
          <div class="sb-sim-title">Facture LCD gratuite</div>
        </div>
        <div class="sb-sim-badge">Gratuit</div>
        <p class="sb-sim-desc">Générez vos factures Airbnb, Booking ou location saisonnière : taxe de séjour automatique, mentions LMNP, export PDF.</p>
        <div class="sb-sim-stats">
          <div class="sb-sim-stat">
            <div class="sb-sim-stat-val">2min</div>
            <div class="sb-sim-stat-lbl">par facture</div>
          </div>
          <div class="sb-sim-stat">
            <div class="sb-sim-stat-val">30k+</div>
            <div class="sb-sim-stat-lbl">communes taxe</div>
          </div>
          <div class="sb-sim-stat">
            <div class="sb-sim-stat-val">PDF</div>
            <div class="sb-sim-stat-lbl">export</div>
          </div>
        </div>
        <a href="/facture-location-saisonniere" class="sb-sim-btn">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="13 17 18 12 13 7"></polyline>
            <polyline points="6 17 11 12 6 7"></polyline>
          </svg>
          Générer une facture
        </a>
      </div>

      <!-- Newsletter widget -->
      <div class="sb-nl">
        <div class="sb-nl-content">
          <div class="sb-nl-pdf-pill">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
            Guide PDF offert + Newsletter
          </div>
          <div class="sb-nl-title">Méthode 97%© LCD gratuite</div>
          <p class="sb-nl-desc">Le guide en 10 étapes pour atteindre 12–18% de rendement net sur vos biens.</p>
          <div class="sb-nl-bullets">
            <div class="sb-nl-bullet">
              <span class="sb-nl-bullet-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></span>
              <span>Guide PDF 40+ pages</span>
            </div>
            <div class="sb-nl-bullet">
              <span class="sb-nl-bullet-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></span>
              <span>Accès simulateur Enomia</span>
            </div>
            <div class="sb-nl-bullet">
              <span class="sb-nl-bullet-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></span>
              <span>1 email/semaine, rien à vendre</span>
            </div>
          </div>
          <form id="sb-nl-form">
            <input type="text" placeholder="Prénom" required />
            <input type="email" placeholder="votre@email.com" required />
            <button type="submit">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="width:12px;height:12px;vertical-align:-1px;margin-right:3px"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
              Recevoir le guide
            </button>
          </form>
          <p class="sb-nl-note">Désinscription en 1 clic</p>
        </div>
      </div>
    </aside>

    <!-- Related articles -->
    {relatedPosts.length > 0 && (
      <section class="related">
        <div class="sec-head">
          <span class="sec-title">Articles liés</span>
          <a href={`/blog?cat=${post.data.category}`} class="sec-link">Voir tout →</a>
        </div>
        <div class="grid-2">
          {relatedPosts.map(related => (
            <a href={`/blog/${related.slug}`} class="card">
              <div class="card-img">
                {related.data.featuredImage
                  ? <img src={related.data.featuredImage.src} alt={related.data.featuredImage.alt} />
                  : <div class="card-img-placeholder" style="width:100%;height:100%;"></div>
                }
              </div>
              <div class="card-body">
                <div class="card-cat">{CAT_LABELS[related.data.category]}</div>
                <div class="card-title">{related.data.title}</div>
                <p class="card-excerpt">{related.data.excerpt}</p>
                <div class="card-meta">{formatDate(related.data.publishedAt)} · {readingTime(related.body)} min</div>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

  </div>
  <script>
    // Star rating interaction + API
    (async () => {
      const block  = document.querySelector('.rating-block');
      const slug   = block?.getAttribute('data-slug');
      const stars  = document.querySelectorAll('.star');
      const thanks = document.getElementById('rating-thanks');
      const count  = document.getElementById('rating-count');
      if (!slug) return;

      // Check if user already voted (localStorage)
      const VOTED_KEY = `enomia_rated_${slug}`;
      let rated = !!localStorage.getItem(VOTED_KEY);
      if (rated) stars.forEach(s => s.style.cursor = 'default');

      // Load current aggregate
      async function loadAggregate() {
        try {
          const res = await fetch('/api/ratings', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ action: 'get', slug }),
          });
          const d = await res.json();
          if (d.count > 0 && count) {
            count.textContent = `${d.average}/5 · ${d.count} avis`;
            count.style.display = 'block';
          }
        } catch (_) {}
      }
      loadAggregate();

      stars.forEach(star => {
        star.addEventListener('mouseover', () => {
          if (rated) return;
          const v = Number(star.getAttribute('data-v'));
          stars.forEach(s => s.classList.toggle('active', Number(s.getAttribute('data-v')) <= v));
        });
        star.addEventListener('mouseleave', () => {
          if (rated) return;
          stars.forEach(s => s.classList.remove('active'));
        });
        star.addEventListener('click', async () => {
          if (rated) return;
          rated = true;
          localStorage.setItem(VOTED_KEY, '1');
          const v = Number(star.getAttribute('data-v'));
          stars.forEach(s => {
            s.classList.toggle('active', Number(s.getAttribute('data-v')) <= v);
            s.style.cursor = 'default';
          });
          if (thanks) thanks.style.display = 'block';
          // Submit vote + refresh count
          try {
            const res = await fetch('/api/ratings', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ action: 'rate', slug, rating: v }),
            });
            const d = await res.json();
            if (d.count > 0 && count) {
              count.textContent = `${d.average}/5 · ${d.count} avis`;
              count.style.display = 'block';
            }
          } catch (_) {}
        });
      });
    })();

    // Newsletter subscription
    function handleNlForm(form) {
      if (!form) return;
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const inputs = form.querySelectorAll('input');
        const firstName = inputs[0].value.trim();
        const email = inputs[1].value.trim();
        if (!firstName || !email) return;
        const btn = form.querySelector('button');
        const origText = btn.textContent;
        btn.disabled = true;
        btn.textContent = 'Envoi…';
        try {
          const res = await fetch('/api/subscribe', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email, firstName }),
          });
          if (res.ok) {
            btn.textContent = '✓ Envoyé !';
            btn.style.background = '#2b2d2b';
            inputs.forEach(i => { i.disabled = true; i.style.opacity = '0.5'; });
          } else {
            btn.textContent = 'Erreur, réessayez';
            btn.disabled = false;
            setTimeout(() => { btn.textContent = origText; }, 2000);
          }
        } catch (_) {
          btn.textContent = 'Erreur, réessayez';
          btn.disabled = false;
          setTimeout(() => { btn.textContent = origText; }, 2000);
        }
      });
    }
    handleNlForm(document.getElementById('article-nl-form'));
    handleNlForm(document.getElementById('sb-nl-form'));
  </script>
</BlogLayout>

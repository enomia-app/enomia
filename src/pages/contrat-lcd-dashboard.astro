---
import ToolLayout from '../layouts/ToolLayout.astro';
import ContratTool from '../components/ContratTool.astro';
---

<ToolLayout
  title="Mes contrats — Dashboard · Enomia"
  description="Gérez tous vos contrats de location saisonnière depuis un dashboard unique. Suivi des acomptes, soldes, cautions. Génération PDF et Word gratuite."
  canonical="https://enomia.app/contrat-lcd-dashboard"
  currentTool="contrat"
>
  <div style="max-width: 1200px; margin: 0 auto; padding: 0 24px 48px;">
    <ContratTool />
  </div>

  <!-- Newsletter -->
  <div style="max-width:920px;margin:0 auto;padding:0 24px 48px">
    <div style="background:linear-gradient(135deg,#2b2d2b 0%,#3a3c3a 100%);border-radius:14px;padding:36px 40px;color:#e8e4dc">
      <div style="display:inline-flex;align-items:center;gap:6px;background:rgba(63,189,113,0.15);color:#3fbd71;font-size:9.5px;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;padding:5px 11px;border-radius:20px;border:1px solid rgba(63,189,113,0.3);margin-bottom:14px">Guide PDF offert</div>
      <div style="font-family:'Newsreader',Georgia,serif;font-size:23px;font-weight:700;color:#fff;line-height:1.22;margin-bottom:8px">Ma méthode LCD complète, gratuitement</div>
      <p style="font-size:13px;color:#6e6b65;line-height:1.6;margin-bottom:18px">Le guide PDF en 10 étapes pour atteindre <strong style="color:#e8e4dc">93–97% d'occupation</strong> — la méthode que j'applique sur mes 9 biens.</p>
      <form id="page-nl-form" style="display:flex;gap:0;max-width:440px">
        <input type="text" placeholder="Prénom" required style="padding:11px 14px;background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.15);border-radius:8px 0 0 8px;border-right:none;color:#e8e4dc;font-family:'Inter',sans-serif;font-size:13px;outline:none;width:120px">
        <input type="email" placeholder="votre@email.com" required style="padding:11px 14px;background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.15);border-radius:0;color:#e8e4dc;font-family:'Inter',sans-serif;font-size:13px;outline:none;flex:1;border-right:none">
        <button type="submit" style="background:#3fbd71;color:#fff;border:none;font-family:'Inter',sans-serif;font-size:13px;font-weight:700;padding:11px 18px;border-radius:0 8px 8px 0;cursor:pointer;white-space:nowrap">Recevoir le guide</button>
      </form>
      <p style="font-size:10px;color:rgba(255,255,255,0.4);margin-top:8px">Désinscription en 1 clic · Email jamais partagé</p>
    </div>
  </div>
  <script>
    (function(){
      var f=document.getElementById('page-nl-form');if(!f)return;
      f.addEventListener('submit',async function(e){
        e.preventDefault();
        var ins=f.querySelectorAll('input'),fn=ins[0].value.trim(),em=ins[1].value.trim();
        if(!fn||!em)return;
        var btn=f.querySelector('button'),orig=btn.textContent;
        btn.disabled=true;btn.textContent='Envoi…';
        try{
          var r=await fetch('/api/subscribe',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({email:em,firstName:fn})});
          if(r.ok){btn.textContent='✓ Envoyé !';btn.style.background='#2b2d2b';ins.forEach(function(i){i.disabled=true;i.style.opacity='0.5'});}
          else{btn.textContent='Erreur';btn.disabled=false;setTimeout(function(){btn.textContent=orig},2000);}
        }catch(_){btn.textContent='Erreur';btn.disabled=false;setTimeout(function(){btn.textContent=orig},2000);}
      });
    })();
  </script>
</ToolLayout>

<style>
  /* Padding extra pour ne pas coller au header */
  main { padding-top: 0; }
</style>

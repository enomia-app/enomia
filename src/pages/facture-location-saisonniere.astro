  <div class="seo-wrap">
    <div class="landing-hero">
      <div class="landing-tag">Facturation location courte durée</div>
      <h1 class="landing-h1">Facture de <em>location saisonnière</em> — modèle & générateur gratuit</h1>
      <p class="landing-sub">Taxe de séjour automatique. Mentions LMNP. Export PDF. Gratuit.</p>
      <div class="landing-stats">
        <div class="landing-stat"><div class="landing-stat-val">2 min</div><div class="landing-stat-lbl">par facture</div></div>
        <div class="landing-stat"><div class="landing-stat-val">30k+</div><div class="landing-stat-lbl">communes taxe séjour</div></div>
        <div class="landing-stat"><div class="landing-stat-val">PDF</div><div class="landing-stat-lbl">export gratuit</div></div>
      </div>

---
export const prerender = false;
import ToolLayout from '../layouts/ToolLayout.astro';
import NewsletterBlock from '../components/NewsletterBlock.astro';

const title = "Facture location saisonnière — Modèle & générateur gratuit LCD";
const description = "Générez gratuitement vos factures de location saisonnière : calcul automatique de la taxe de séjour, TVA LMNP (art. 293 B), mentions obligatoires. Export PDF, sans inscription.";
const canonical = "https://www.enomia.app/facture-location-saisonniere";

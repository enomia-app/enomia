---
// PREVIEW MODE — pas de prerender pour voir TOUTES les villes (même brouillons)
// avant publication. Bloqué pour Google via meta noindex (ajouté par le composant).
export const prerender = false;

import ToolLayout from '../../../layouts/ToolLayout.astro';
import RentabiliteVillePage from '../../../components/RentabiliteVillePage.astro';
import {
  getCityRentabiliteBySlug,
  getNeighborsRentabilite,
} from '../../../data/cities-rentabilite';

const { ville } = Astro.params;
const city = getCityRentabiliteBySlug(ville!);

if (!city) {
  return Astro.redirect('/preview/rentabilite-airbnb');
}

const neighbors = getNeighborsRentabilite(city.slug);

const title = `[PREVIEW] Rentabilité Airbnb à ${city.name}`;
const description = `Preview interne : Rentabilité Airbnb à ${city.name} en 2026.`;
const canonical = `https://www.enomia.app/preview/rentabilite-airbnb/${city.slug}`;
---
<ToolLayout title={title} description={description} canonical={canonical} currentTool="simulateur" ctaLabel="Estimer ma rentabilité" ctaHref="/simulateur-lcd" noindex={true}>
  <RentabiliteVillePage city={city} neighbors={neighbors} previewMode={true} />
</ToolLayout>

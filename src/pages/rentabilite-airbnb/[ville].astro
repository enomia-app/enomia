---
import ToolLayout from '../../layouts/ToolLayout.astro';
import RentabiliteVillePage from '../../components/RentabiliteVillePage.astro';
import {
  citiesRentabilite,
  getNeighborsRentabilite,
  type CityRentabilite,
} from '../../data/cities-rentabilite';

export async function getStaticPaths() {
  return citiesRentabilite
    .filter((c) => c.status === 'en-ligne')
    .map((c) => ({ params: { ville: c.slug }, props: { city: c } }));
}

interface Props {
  city: CityRentabilite;
}

const { city } = Astro.props;
const neighbors = getNeighborsRentabilite(city.slug);

const title = `Rentabilité Airbnb à ${city.name} : revenus, estimation et taux d'occupation 2026`;
const description = `Rentabilité Airbnb à ${city.name} en 2026 : CA T2 ${city.t2.caAnnualMin.toLocaleString('fr-FR')}-${city.t2.caAnnualMax.toLocaleString('fr-FR')} €/an, occupation ${city.t2.occupancyMin}-${city.t2.occupancyMax}%, rendement net ${city.t2.rendementNetMin}-${city.t2.rendementNetMax}%. Calcul cashflow + simulateur préremplit.`;
const canonical = `https://www.enomia.app/rentabilite-airbnb/${city.slug}`;
---
<ToolLayout title={title} description={description} canonical={canonical} currentTool="simulateur" ctaLabel="Estimer ma rentabilité" ctaHref="/simulateur-lcd">
  <RentabiliteVillePage city={city} neighbors={neighbors} previewMode={false} />
</ToolLayout>
